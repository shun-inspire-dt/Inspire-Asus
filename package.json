{
    "name": "asus",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro --config dev.astro.config.mjs dev --host",
        "build": "MODE=build astro --config build.astro.config.mjs build",
        "preview": "MODE=build astro --config build.astro.config.mjs preview",
        "check": "astro --config build.astro.config.mjs dev",
        "build.local": "MODE=build LOCAL=true astro --config build.astro.config.mjs build",
        "preview.local": "MODE=build LOCAL=true astro --config build.astro.config.mjs preview",
        "check.local": "LOCAL=true astro --config build.astro.config.mjs dev",
        "gitlab": "MODE=deploy astro --config gitlab.astro.config.mjs build",
        "netlify": "MODE=deploy astro --config netlify.astro.config.mjs build",
        "prettier": "npx prettier -w --plugin-search-dir=. ./src ./*.mjs ./*.ts ./src/**/*.astro",
        "tsc:check": "tsc --noEmit",
        "astro": "astro",
        "plop": "plop --plopfile ./PlopJS/plopfile.js"
    },
    "dependencies": {
        "@astrojs/check": "^0.9.5",
        "@astrojs/tailwind": "^6.0.2",
        "@mapbox/mapbox-gl-language": "^1.0.1",
        "@unocss/eslint-config": "^66.5.4",
        "@unocss/preset-attributify": "^66.5.4",
        "@unocss/preset-icons": "^66.5.4",
        "@unocss/preset-rem-to-px": "^66.5.4",
        "@unocss/preset-uno": "^66.5.4",
        "@unocss/reset": "^66.5.4",
        "@unocss/transformer-directives": "^66.5.4",
        "@unocss/transformer-variant-group": "^66.5.4",
        "air-datepicker": "^3.5.3",
        "astro": "^4.16.19",
        "bootstrap": "^5.3.3",
        "dotenv": "^17.2.3",
        "jest": "^30.2.0",
        "mapbox-gl": "^3.14.0",
        "schema-dts": "^1.1.5",
        "swiper": "^12.0.3",
        "tailwindcss": "^4.1.16",
        "ts-jest": "^29.1.5",
        "typescript": "^5.9.3",
        "unocss": "^66.5.4",
        "unocss-preset-autoprefixer": "^0.0.9"
    },
    "devDependencies": {
        "@astrojs/netlify": "^3.1.1",
        "@faker-js/faker": "^10.1.0",
        "@playwright/test": "^1.44.1",
        "@types/bootstrap": "^5.2.10",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.5",
        "@types/lodash-es": "^4.17.12",
        "@unocss/transformer-compile-class": "^66.5.4",
        "astro-compress": "2.2.28",
        "astro-google-analytics": "^1.0.3",
        "astro-html-beautifier": "^1.0.4",
        "astro-seo-meta": "^5.2.0",
        "astro-seo-schema": "^5.1.0",
        "less": "^4.2.0",
        "lodash": "^4.17.21",
        "lodash-es": "^4.17.21",
        "netlify-cli": "23.9.5",
        "prettier-plugin-astro": "^0.14.1",
        "sass": "^1.77.5",
        "stylus": "^0.64.0",
        "vite": "^7.1.12",
        "vite-plugin-compression": "^0.5.1"
    }
}
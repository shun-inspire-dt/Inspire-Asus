{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@components/*": ["src/components/*"],
            "@assets/*": ["public/assets/*"],
            "@layouts/*": ["src/layouts/*"],
            "@js/*": ["src/js/*"],
            "@scss/*": ["src/scss/*"],
            "@image/*": ["src/components/images/*"]
        },
        "allowJs": true,
        "jsx": "preserve",
        "moduleResolution": "Bundler", // "Node10", "Node16" or "NodeNext"
        "strict": true // Optional, but recommended
    },
    "include": [
        "src/**/*",
        "*.ts",
        "*.mjs"
    ],
    "exclude": [
        "node_modules",
        "dist",
        ".astro"
    ]
}
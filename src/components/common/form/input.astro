---
/** Type */
import type { HTMLAttributes } from 'astro/types';
/** Style */
import './input.scss';
export interface Props {
    id?: string;
    className?: any;
    type?: HTMLAttributes<'input'>['type'];
    name?: string;
    value?: string | number;
    maxLength?: string | number;
    minLength?: string | number;
    max?: string | number;
    min?: string | number;
    placeholder?: string;
    inputmode?: HTMLAttributes<'input'>['inputmode'];
    required?: boolean;
    disabled?: boolean;
    readonly?: 'readonly';
    autocomplete?: autocomlete;
    title?: string;
    transparent?: boolean;
    validClass?: string;
    validType?: string;
    validLabel?: string;
    validRegex?: string;
    errorFeedback?: string;
    successFeedback?: string;
    FeedbackIcon?: boolean;
    aria?: aria;
    attribute?: attribute;
}

const {
    id,
    className,
    type = 'text',
    name,
    value,
    placeholder,
    inputmode = 'text',
    maxLength,
    minLength,
    max,
    min,
    required,
    disabled,
    readonly,
    autocomplete,
    title,
    transparent,
    validClass,
    validType,
    validLabel,
    validRegex,
    errorFeedback,
    successFeedback,
    FeedbackIcon,
    attribute = {},
    aria = {}
} = Astro.props as Props;
const validAttribute = {
    'data-valid-class': validClass,
    'data-valid-type': validType,
    'data-valid-label': validLabel,
    'data-valid-regex': validRegex,
    'data-custom-feedback': errorFeedback || successFeedback ? '' : undefined,
    'data-error-feedback': errorFeedback,
    'data-success-feedback': successFeedback,
    'data-feedback-icon': FeedbackIcon ? '' : undefined
};
---

<input
    id={id}
    class:list={['control-input', { 'input-transparent': transparent }, className]}
    value={value}
    type={type}
    name={name}
    max={max}
    min={min}
    maxlength={maxLength}
    minlength={minLength}
    placeholder={placeholder}
    inputmode={inputmode}
    required={required}
    disabled={disabled}
    readonly={readonly}
    autocomplete={autocomplete}
    aria-label={title}
    {...attribute}
    {...aria}
    {...validAttribute}
/>

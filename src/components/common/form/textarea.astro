---
/** Type */
import type { Props as inputProps } from './input/input.astro';
/** Style */
import './textarea.scss';
export interface Props extends inputProps {
    noResize?: boolean;
    cols?: number;
    rows?: number;
    maxlength?: number;
    minlength?: number;
}

const {
    id,
    className,
    name,
    title,
    value,
    cols = 2,
    rows = 2,
    maxlength,
    minlength,
    placeholder,
    required,
    disabled,
    readonly,
    validClass = 'form',
    validType,
    validLabel,
    validRegex,
    errorFeedback,
    successFeedback,
    FeedbackIcon,
    attribute = {},
    size,
    noResize
} = Astro.props as Props;

/**
 * 建立 CSS 類別列表
 * 根據屬性動態組合樣式類別
 */
const inputClasses = [
    'control-input', // 基礎輸入框類別
    { [`size_${size}`]: size }, // 尺寸類別
    { noresize: noResize }, // 是否禁止調整大小
    className // 自定義類別
].filter(Boolean);

/**
 * 建立驗證相關的 data 屬性物件
 * 這些屬性會被 JavaScript 驗證腳本使用
 */
const validAttribute = {
    'data-valid-class': validClass, // 驗證成功時要套用的 CSS 類別
    'data-valid-type': validType, // 驗證類型識別
    'data-valid-label': validLabel, // 驗證標籤文字
    'data-valid-regex': validRegex, // 驗證用正規表達式
    'data-custom-feedback': errorFeedback || successFeedback ? '' : undefined, // 是否有自定義回饋訊息
    'data-error-feedback': errorFeedback, // 錯誤回饋訊息
    'data-success-feedback': successFeedback, // 成功回饋訊息
    'data-feedback-icon': FeedbackIcon ? '' : undefined // 是否顯示回饋圖標
};
---

<textarea
    id={id}
    class:list={inputClasses}
    name={name}
    cols={cols}
    rows={rows}
    maxlength={maxlength}
    minlength={minlength}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    readonly={readonly}
    aria-label={title}
    {...attribute}
    {...validAttribute}>{(value as string)?.trim()}</textarea
>

---
/** Type */
import type { Props as inputProps } from './input/input.astro';
/** Style */
import './textarea.scss';
export interface Props extends inputProps {
    noResize?: boolean;
    cols?: number;
    rows?: number;
    maxLength?: number;
    minLength?: number;
}

const {
    id,
    className,
    name,
    title,
    value,
    cols = 2,
    rows = 2,
    maxLength,
    minLength,
    placeholder,
    required,
    disabled,
    readonly,
    attribute = {},
    style,
    size,
    noResize
} = Astro.props as Props;

/**
 * 建立 CSS 類別列表
 * 根據屬性動態組合樣式類別
 */
const inputClasses = [
    'control-input', // 基礎輸入框類別
    { [`size_${size}`]: size }, // 尺寸類別
    { noresize: noResize }, // 是否禁止調整大小
    className // 自定義類別
].filter(Boolean);
---

<textarea
    id={id}
    class:list={inputClasses}
    name={name}
    cols={cols}
    rows={rows}
    maxlength={maxLength}
    minlength={minLength}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    readonly={readonly}
    aria-label={title}
    style={style}
    {...attribute}
>{(value as string)?.trim()}</textarea>

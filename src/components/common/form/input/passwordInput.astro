---
/**
 * 密碼輸入框組件 - 支援顯示/隱藏密碼功能
 * 基於 Input 組件擴展，添加密碼切換邏輯
 */

/** 類型定義 */
import type { HTMLAttributes } from 'astro/types';

/** 基礎輸入框組件 */
import InputWrapper from './inputWrapper.astro';

/** 樣式檔案 */
import './passwordInput.scss';

/**
 * 密碼輸入框組件屬性介面
 * 繼承 Input 組件的所有屬性，並強制設定密碼相關屬性
 *
 * @interface Props
 * @property {string} [id] - 輸入框的唯一識別碼
 * @property {any} [className] - 自定義 CSS 類別名稱
 * @property {string} [name] - 表單欄位名稱，用於表單提交
 * @property {string | number} [value] - 輸入框的預設值
 * @property {string | number} [maxLength] - 最大字元長度限制
 * @property {string | number} [minLength] - 最小字元長度限制
 * @property {string} [placeholder] - 佔位符文字，當輸入框為空時顯示
 * @property {HTMLAttributes<'input'>['inputmode']} [inputmode] - 輸入模式，影響行動裝置鍵盤類型
 * @property {boolean} [required] - 是否為必填欄位
 * @property {boolean} [disabled] - 是否禁用輸入框
 * @property {'readonly'} [readonly] - 是否為唯讀狀態
 * @property {autocomlete} [autocomplete] - 自動完成屬性，協助瀏覽器填入建議值
 * @property {string} [title] - 輸入框標題，用於無障礙標籤
 * @property {boolean} [transparent] - 是否使用透明樣式（無背景、無邊框）
 * @property {'xl' | 'lg' | 'md' | 'sm'} [size] - 輸入框尺寸
 * @property {'value' | 'error' | 'disabled' | 'placeholder' | 'selected' | 'placeholder-selected'} [status] - 輸入框狀態
 * @property {boolean} [focus] - 是否顯示焦點邊框
 * @property {boolean} [showPassword] - 初始是否顯示密碼（預設為 false）
 * @property {string} [validClass] - 驗證相關屬性 - CSS 類別名稱
 * @property {string} [validType] - 驗證類型
 * @property {string} [validLabel] - 驗證標籤
 * @property {string} [validRegex] - 驗證用的正規表達式
 * @property {string} [errorFeedback] - 錯誤訊息回饋文字
 * @property {string} [successFeedback] - 成功訊息回饋文字
 * @property {boolean} [FeedbackIcon] - 是否顯示回饋圖標
 * @property {aria} [aria] - ARIA 無障礙屬性
 * @property {attribute} [attribute] - 其他自定義 HTML 屬性
 */
export interface Props {
    id?: string;
    className?: any;
    name?: string;
    value?: string | number;
    maxLength?: string | number;
    minLength?: string | number;
    placeholder?: string;
    inputmode?: HTMLAttributes<'input'>['inputmode'];
    required?: boolean;
    disabled?: boolean;
    readonly?: 'readonly';
    autocomplete?: autocomlete;
    title?: string;
    transparent?: boolean;
    size?: 'xl' | 'lg' | 'md' | 'sm';
    status?: 'value' | 'error' | 'disabled' | 'placeholder' | 'selected' | 'placeholder-selected';
    focus?: boolean;
    showPassword?: boolean;
    validClass?: string;
    validType?: string;
    validLabel?: string;
    validRegex?: string;
    errorFeedback?: string;
    successFeedback?: string;
    FeedbackIcon?: boolean;
    aria?: aria;
    attribute?: attribute;
}

/**
 * 從 Astro.props 解構所有屬性
 * 設定預設值並準備傳遞給 Input 組件
 */
const {
    id, // 輸入框 ID
    className, // 自定義 CSS 類別
    name, // 表單欄位名稱
    value, // 輸入框值
    maxLength, // 最大字元長度
    minLength, // 最小字元長度
    placeholder, // 佔位符文字，預設為密碼提示
    inputmode = 'text', // 輸入模式，預設為文字
    required, // 是否必填
    disabled, // 是否禁用
    readonly, // 是否唯讀
    autocomplete = 'current-password', // 自動完成，預設為當前密碼
    title, // 標題（用於無障礙）
    transparent, // 是否透明樣式
    size = 'md', // 尺寸，預設為 md
    status, // 輸入框狀態，預設為 value
    focus = false, // 是否顯示焦點邊框，預設為 false
    showPassword = false, // 初始是否顯示密碼，預設為 false
    validClass, // 驗證 CSS 類別
    validType, // 驗證類型
    validLabel, // 驗證標籤
    validRegex, // 驗證正規表達式
    errorFeedback, // 錯誤回饋訊息
    successFeedback, // 成功回饋訊息
    FeedbackIcon, // 是否顯示回饋圖標
    attribute = {}, // 其他 HTML 屬性，預設為空物件
    aria = {} // ARIA 屬性，預設為空物件
} = Astro.props as Props;

/**
 * 生成唯一的組件 ID
 * 如果沒有提供 id，則生成一個隨機 ID
 */
const componentId = id || `password-input-${Math.random().toString(36).substr(2, 9)}`;
---

<!-- 密碼輸入框容器 --><!-- 使用 Input 組件作為基礎，強制設定密碼相關屬性 -->
<InputWrapper
    id={componentId}
    className={['password-input-wrapper', className]}
    type={showPassword ? 'text' : 'password'}
    name={name}
    value={value}
    maxLength={maxLength}
    minLength={minLength}
    placeholder={placeholder}
    inputmode={inputmode}
    required={required}
    disabled={disabled}
    readonly={readonly}
    autocomplete={autocomplete}
    title={title}
    transparent={transparent}
    size={size}
    status={status}
    focus={focus}
    pwdShowIcon
    pwdHideIcon
    validClass={validClass}
    validType={validType}
    validLabel={validLabel}
    validRegex={validRegex}
    errorFeedback={errorFeedback}
    successFeedback={successFeedback}
    FeedbackIcon={FeedbackIcon}
    aria={aria}
    attribute={{ 'data-expand': showPassword ? 'true' : 'false', 'data-component': 'password-input', ...attribute }}
/>

<!-- 密碼顯示/隱藏切換腳本 -->
<script>
    /**
     * 密碼輸入框互動邏輯
     * 處理密碼顯示/隱藏的切換功能，使用 CSS 控制圖標顯示狀態
     */
    (function () {
        'use strict';

        // 追蹤是否已初始化
        let initialized = false;

        /**
         * 設定單個密碼輸入框
         * @param {Element} wrapper - 密碼輸入框容器元素
         */
        function setupPasswordInput(wrapper: Element) {
            const input = wrapper.querySelector('input[type="password"], input[type="text"]') as HTMLInputElement | null;
            const showButton = wrapper.querySelector('.hide-show-icon.hide-show-icon--show') as HTMLButtonElement | null;
            const hideButton = wrapper.querySelector('.hide-show-icon.hide-show-icon--hide') as HTMLButtonElement | null;

            // 確保元素存在且為正確類型
            if (!input || (!showButton && !hideButton)) {
                console.warn('Password input elements not found:', { input, showButton, hideButton });
                return;
            }

            // 從容器的 data-expand 屬性獲取初始狀態
            let isPasswordVisible = (wrapper as HTMLElement).dataset.expand === 'true';

            /**
             * 更新 UI 狀態
             * @param {boolean} visible - 密碼是否可見
             */
            function updateUIState(visible: boolean) {
                // 更新輸入框類型
                input!.type = visible ? 'text' : 'password';

                // 更新容器的 data-expand 屬性，觸發 CSS 樣式變化
                (wrapper as HTMLElement).dataset.expand = visible.toString();

                // 更新按鈕的 aria-pressed 狀態
                if (showButton) {
                    showButton.setAttribute('aria-pressed', visible.toString());
                }
                if (hideButton) {
                    hideButton.setAttribute('aria-pressed', (!visible).toString());
                }
            }

            /**
             * 切換密碼顯示/隱藏
             */
            function togglePasswordVisibility() {
                isPasswordVisible = !isPasswordVisible;
                updateUIState(isPasswordVisible);

                // 觸發自定義事件，讓外部可以監聽狀態變化
                const event = new CustomEvent('passwordToggle', {
                    detail: {
                        visible: isPasswordVisible,
                        inputId: input!.id,
                        wrapper: wrapper
                    },
                    bubbles: true
                });

                wrapper.dispatchEvent(event);
            }

            /**
             * 綁定按鈕事件
             * @param {HTMLButtonElement} button - 按鈕元素
             */
            function bindButtonEvents(button: HTMLButtonElement) {
                // 點擊事件
                button.addEventListener('click', (event) => {
                    event.preventDefault();
                    togglePasswordVisibility();
                });

                // 鍵盤事件
                button.addEventListener('keydown', (event: KeyboardEvent) => {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        togglePasswordVisibility();
                    }
                });

                // 確保按鈕可以接收焦點
                if (!button.hasAttribute('tabindex')) {
                    button.setAttribute('tabindex', '0');
                }

                // 設定初始 aria 狀態
                button.setAttribute('aria-pressed', 'false');
            }

            // 綁定按鈕事件
            if (showButton) {
                bindButtonEvents(showButton);
            }

            if (hideButton) {
                bindButtonEvents(hideButton);
            }

            // 設定初始 UI 狀態
            updateUIState(isPasswordVisible);
        }

        /**
         * 初始化所有密碼輸入框
         */
        function initPasswordInputs() {
            if (initialized) return;

            const passwordWrappers = document.querySelectorAll('[data-component="password-input"]');
            passwordWrappers.forEach(setupPasswordInput);

            initialized = true;
        }

        // 當 DOM 載入完成時初始化
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initPasswordInputs);
        } else {
            initPasswordInputs();
        }
    })();
</script>

---
export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    Tag?: 'button' | 'a' | 'div' | 'span';
    size?: '48' | '32';
}

const { IDName, className, style, attribute = {}, Tag = 'button', size = '48' } = Astro.props as Props;

const cardClass = [
    ':uno-play-back: flex items-center justify-center relative bg-#070707/50 rounded-999 aspect-square [&>.play-back-pause-icon]:hidden [&.active>.play-back-icon]:hidden [&.active>.play-back-pause-icon]:block',
    { ':uno-play-back-48: size-3rem border border-white': size === '48' },
    { ':uno-play-back-32: size-2rem border-none': size === '32' },
    className
];
const cardStyle = (size: '48' | '32') => {
    const data = {
        '48': {
            '--icon-width': '1.2rem',
            '--icon-height': '1.05rem',
            ...style
        },
        '32': {
            '--icon-width': '0.875rem',
            '--icon-height': '0.75rem',
            ...style
        }
    } as { '48': { [key: string]: string }; '32': { [key: string]: string } };
    return data[size];
};
---

<Tag
    id={IDName}
    type={Tag === 'button' ? 'button' : undefined}
    class:list={[cardClass]}
    style={cardStyle(size)}
    title="play-back"
    aria-label="play-back"
    {...attribute}
>
    <svg
        class:list={['play-back-icon', 
        { ':uno-play-back-icon-48: absolute top-0.9rem left-1.125rem': size === '48' },
        { ':uno-play-back-icon-32: absolute top-0.5625rem left-0.75rem': size === '32' },
        ]}
        width="16"
        height="18"
        viewBox="0 0 16 18"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
    >
        <path
            d="M15.2804 8.00913C15.9522 8.39302 15.9522 9.36172 15.2804 9.74561L1.49594 17.6224C0.829283 18.0034 -0.000195347 17.522 -0.000195313 16.7542L-0.000194625 1.00052C-0.000194591 0.232701 0.829288 -0.248665 1.49594 0.132283L15.2804 8.00913Z"
            fill="var(--color-white, #fff)"></path>
    </svg>
    <svg
        class:list={[
            'play-back-pause-icon',
            { ':uno-play-pause-back-icon-48: absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2': size === '48' },
            { ':uno-play-pause-back-icon-32: absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2': size === '32' },
        ]}
        width="15"
        height="20"
        viewBox="0 0 15 20"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
    >
        <rect x="0.6" y="0.6" width="1.2" height="18" rx="0.6" fill="white" stroke="white" stroke-width="1.2"></rect>
        <rect x="12.6" y="0.6" width="1.2" height="18" rx="0.6" fill="white" stroke="white" stroke-width="1.2"></rect>
    </svg>
</Tag>

<script>
    const button = document.querySelectorAll('[aria-label="play-back"]') as NodeListOf<HTMLButtonElement>;
    button.forEach((item) => {
        item.addEventListener('click', () => {
            item.classList.toggle('active');
        });
    });
</script>

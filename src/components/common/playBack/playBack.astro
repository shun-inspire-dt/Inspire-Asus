---
export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    Tag?: 'button' | 'a' | 'div' | 'span';
    size?: '48' | '32';
}

const { IDName, className, style, attribute = {}, Tag = 'button', size = '48' } = Astro.props as Props;

const cardClass = [
    ':uno-play-back: flex items-center justify-center relative bg-#070707/50 rounded-999 aspect-square [&>.play-back-pause-icon]:hidden [&.active>.play-back-icon]:hidden [&.active>.play-back-pause-icon]:block',
    { ':uno-play-back-48: size-3rem border border-white': size === '48' },
    { ':uno-play-back-32: size-2rem border-none': size === '32' },
    className
];
const cardStyle = (size: '48' | '32') => {
    const data = {
        '48': {
            '--icon-width': '1.2rem',
            '--icon-height': '1.05rem',
            ...style
        },
        '32': {
            '--icon-width': '0.875rem',
            '--icon-height': '0.75rem',
            ...style
        }
    } as { '48': { [key: string]: string }; '32': { [key: string]: string } };
    return data[size];
};
---

<Tag
    id={IDName}
    type={Tag === 'button' ? 'button' : undefined}
    class:list={[cardClass]}
    style={cardStyle(size)}
    title="play-back"
    aria-label="play-back"
    {...attribute}
>
    {/** 48 */}
    {
        size === '48' && (
            <>
                <svg
                    class:list={[
                        'play-back-icon',
                        { ':uno-play-back-icon-48: absolute top-0.9rem left-1.125rem': size === '48' }
                    ]}
                    width="16"
                    height="18"
                    viewBox="0 0 16 18"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M15.2804 8.00913C15.9522 8.39302 15.9522 9.36172 15.2804 9.74561L1.49594 17.6224C0.829283 18.0034 -0.000195347 17.522 -0.000195313 16.7542L-0.000194625 1.00052C-0.000194591 0.232701 0.829288 -0.248665 1.49594 0.132283L15.2804 8.00913Z"
                        fill="var(--color-white, #fff)"
                    />
                </svg>
                <svg
                    class:list={[
                        'play-back-pause-icon',
                        {
                            ':uno-play-pause-back-icon-48: absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2':
                                size === '48'
                        }
                    ]}
                    width="15"
                    height="20"
                    viewBox="0 0 15 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect
                        x="0.6"
                        y="0.6"
                        width="1.2"
                        height="18"
                        rx="0.6"
                        fill="var(--color-white, #fff)"
                        stroke="var(--color-white, #fff)"
                        stroke-width="1.2"
                    />
                    <rect
                        x="12.6"
                        y="0.6"
                        width="1.2"
                        height="18"
                        rx="0.6"
                        fill="var(--color-white, #fff)"
                        stroke="var(--color-white, #fff)"
                        stroke-width="1.2"
                    />
                </svg>
            </>
        )
    }
    {/** 32 */}
    {
        size === '32' && (
            <>
                <svg
                    class:list={[
                        'play-back-icon',
                        { ':uno-play-back-icon-32: absolute top-0.5625rem left-0.75rem': size === '32' }
                    ]}
                    width="12"
                    height="13"
                    viewBox="0 0 12 13"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M10.5192 5.39601C11.1807 5.78188 11.1807 6.73769 10.5192 7.12356L1.50387 12.3825C0.837215 12.7714 3.84081e-07 12.2905 4.17817e-07 11.5187L8.77571e-07 1.0008C9.11307e-07 0.229013 0.837216 -0.251858 1.50387 0.137027L10.5192 5.39601Z"
                        fill="var(--color-white, #fff)"
                    />
                </svg>
                <svg
                    class:list={[
                        'play-back-pause-icon',
                        {
                            ':uno-play-pause-back-icon-32: absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2':
                                size === '32'
                        }
                    ]}
                    width="10"
                    height="13"
                    viewBox="0 0 10 13"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect
                        x="0.4"
                        y="0.4"
                        width="0.8"
                        height="12"
                        rx="0.4"
                        fill="var(--color-white, #fff)"
                        stroke="var(--color-white, #fff)"
                        stroke-width="0.8"
                    />
                    <rect
                        x="8.4"
                        y="0.4"
                        width="0.8"
                        height="12"
                        rx="0.4"
                        fill="var(--color-white, #fff)"
                        stroke="var(--color-white, #fff)"
                        stroke-width="0.8"
                    />
                </svg>
            </>
        )
    }
</Tag>

<script>
    const button = document.querySelectorAll(
        '[aria-label="play-back"]:not([data-auto="false"])'
    ) as NodeListOf<HTMLButtonElement>;
    button.forEach((item) => {
        item.addEventListener('click', () => {
            item.classList.toggle('active');
        });
    });
</script>

---
export interface Props {
    id?: string;
    className?: any;
    width?: number | string | null;
    height?: number | string | null;
    img?: string;
    blankWebpImg?: string;
    alt?: string;
    type?: string;
    loading?: 'lazy' | 'eager' | null | undefined;
    decoding?: 'async' | 'auto' | 'sync' | null | undefined;
    blank?: boolean;
    noWebp?: boolean;
    breakpoints?: {
        width: number;
        img: string;
        blankWebpImg?: string;
        noWebp?: boolean;
        type?: string;
        blank?: string;
        // 支援多種像素密度的圖片設定
        densities?: {
            '1x': string;    // 標準解析度圖片路徑
            '1.5x'?: string; // 1.5倍解析度圖片路徑
            '2x'?: string;   // 2倍解析度圖片路徑
        };
    }[];
    style?: { [key: string]: string };
    attribute?: attribute;
}

const {
    id,
    className = '',
    width = null,
    height = null,
    img = '',
    blankWebpImg = '',
    alt = '',
    type = 'png',
    loading = 'lazy',
    decoding = 'async',
    blank,
    noWebp = false,
    breakpoints,
    style,
    attribute = {}
} = Astro.props as Props;
---

<picture>
    {
        breakpoints &&
            breakpoints?.map((x) => (
                <Fragment>
                    {!noWebp && (
                        <source
                            srcset={
                                x.densities
                                    ? Object.entries(x.densities)
                                          .map(([density, imgPath]) => 
                                              !blank 
                                                  ? `${Astro.url.origin}${imgPath}.webp ${density}`
                                                  : `${imgPath}.webp ${density}`
                                          )
                                          .join(', ')
                                    : (!blank ? `${Astro.url.origin}${x.img}.webp` : `${x.blankWebpImg}`)
                            }
                            media={`(min-width:${x.width}px)`}
                            type="image/webp"
                        />
                    )}
                    <source
                        srcset={
                            x.densities
                                ? Object.entries(x.densities)
                                      .map(([density, imgPath]) => 
                                          !blank 
                                              ? `${Astro.url.origin}${imgPath}.${x.type || type} ${density}`
                                              : `${imgPath} ${density}`
                                      )
                                      .join(', ')
                                : (!blank ? `${Astro.url.origin}${x.img}.${x.type || type}` : `${x.img}`)
                        }
                        media={`(min-width:${x.width}px)`}
                        type={`image/${x.type || type}`}
                    />
                </Fragment>
            ))
    }
    {!noWebp && <source srcset={!blank ? `${Astro.url.origin}${img}.webp` : `${blankWebpImg}`} type="image/webp" />}
    <img
        id={id}
        class:list={[className]}
        width={width}
        height={height}
        src={!blank ? `${Astro.url.origin}${img}.${type}` : `${img}`}
        alt={alt}
        title={alt}
        loading={loading}
        decoding={decoding}
        style={style}
        {...attribute}
    />
</picture>

---
/** Common Components - 通用組件 */
/** Offcanvas Base Component - Offcanvas 基礎組件 */
import MyOffcanvas from '@components/common/offcanvas/offcanvas.astro';
/** Button */
import Button from '@components/common/button/button.astro';
/** Link */
import ALink from '@components/common/link/link.astro';
/** Badge */
import Badge from '@components/common/badges/badge.astro';
/** Filter */
import Filter from '../collapse/filter.astro';
/** Style */
import './articleOffcanvas.scss';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    category?: category;
}

const { IDName = 'sectionArticle', className, style, attribute = {}, category } = Astro.props as Props;
---

<MyOffcanvas
    IDName={IDName}
    postion="bottom"
    hideHeader
    className={['section-article-offcanvas', className]}
    attribute={attribute}
    style={style}
>
    <form action="" class=":uno-article-offcanvas-form: w-full h-full flex flex-col">
        <div
            class=":uno-article-offcanvas-form-header: w-full flex flex-col gap-0.75rem flex-none shrink-0 py-0.625rem px-1rem bg-white border-b border-gray-200"
        >
            <div class=":uno-article-offcanvas-form-header-top: flex items-baseline justify-between">
                <strong class=":uno-article-offcanvas-form-header-title: font-roboto text-20 lh-125 font-medium">篩選結果</strong>
                <ALink title={'清除全部'} attribute={{ 'data-category-clear': '' }}>清除全部</ALink>
            </div>
            <div data-filter-badges>
                <template>
                    <Badge Tag="span" status="filter" showCross><span></span></Badge>
                </template>
                <div class=":uno-category-badges-list: flex flex-wrap gap-y-0.75rem gap-x-0.5rem" data-filter-badges-list></div>
            </div>
        </div>
        <div
            class=":uno-article-offcanvas-form-body: w-full flex-1 grow py-0.5rem px-1rem h-6.9375rem bg-white overflow-auto scrollbar"
            data-filter
        >
            {
                category?.map((item, index) => (
                    <Filter
                        title={item.title}
                        show={item.show}
                        more={item.more}
                        data={item.children}
                        style={{
                            ...(index === 0 ? { '--collapse-border-width': '0' } : {})
                        }}
                    />
                ))
            }
        </div>
        <div
            class=":uno-article-offcanvas-form-footer: w-full flex items-center justify-center gap-1rem flex-none shrink-0 p-1rem bg-white border-t border-gray-200 [&>button]:flex-1"
        >
            <Button
                type={'reset'}
                size="sm"
                variant="blue-outline"
                title={'取消'}
                block
                attribute={{ 'data-bs-dismiss': 'offcanvas' }}>取消</Button
            >
            <Button
                type={'submit'}
                size="sm"
                variant="blue"
                title={'提交'}
                block
                attribute={{ 'data-title': '提交', 'data-category-button': '' }}
            >
                提交
            </Button>
        </div>
    </form>
</MyOffcanvas>

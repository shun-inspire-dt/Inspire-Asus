---
/** Search Icon Example Component */
import SearchIcon from './search.astro';
---

<section class="search-examples">
    <div class="container-fluid mx-auto px-4 py-8">
        <h2 class="text-2xl font-bold mb-6">Search Icons</h2>
        
        <!-- Mode 展示 -->
        <div class="mb-8">
            <h3 class="text-lg font-semibold mb-4">Mode</h3>
            <div class="grid grid-cols-2 gap-6">
                <div class="text-center p-4 border rounded-lg">
                    <h4 class="text-sm font-medium mb-3">Light Mode</h4>
                    <SearchIcon mode="light" width={18} />
                </div>
                <div class="text-center p-4 border rounded-lg bg-gray-800">
                    <h4 class="text-sm font-medium mb-3 text-white">Dark Mode</h4>
                    <SearchIcon mode="dark" width={18} />
                </div>
            </div>
        </div>
        
        <!-- State 展示 -->
        <div class="mb-8">
            <h3 class="text-lg font-semibold mb-4">State</h3>
            <div class="grid grid-cols-3 gap-6">
                <div class="text-center p-4 border rounded-lg">
                    <h4 class="text-sm font-medium mb-3">Normal</h4>
                    <SearchIcon state="normal" width={18} />
                </div>
                <div class="text-center p-4 border rounded-lg">
                    <h4 class="text-sm font-medium mb-3">Placeholder</h4>
                    <SearchIcon state="placeholder" width={18} />
                </div>
                <div class="text-center p-4 border rounded-lg">
                    <h4 class="text-sm font-medium mb-3">Disable</h4>
                    <SearchIcon state="disable" width={18} />
                </div>
            </div>
        </div>
        
        <!-- Mode + State 組合 -->
        <div class="mb-8">
            <h3 class="text-lg font-semibold mb-4">Mode + State 組合</h3>
            <div class="grid grid-cols-3 gap-4">
                <!-- Light Mode -->
                <div class="space-y-4">
                    <h4 class="text-md font-medium text-center">Light Mode</h4>
                    <div class="text-center p-4 border rounded-lg">
                        <div class="mb-2 text-sm">Normal</div>
                        <SearchIcon mode="light" state="normal" width={18} />
                    </div>
                    <div class="text-center p-4 border rounded-lg">
                        <div class="mb-2 text-sm">Placeholder</div>
                        <SearchIcon mode="light" state="placeholder" width={18} />
                    </div>
                    <div class="text-center p-4 border rounded-lg">
                        <div class="mb-2 text-sm">Disable</div>
                        <SearchIcon mode="light" state="disable" width={18} />
                    </div>
                </div>
                
                <!-- Dark Mode -->
                <div class="space-y-4">
                    <h4 class="text-md font-medium text-center text-white">Dark Mode</h4>
                    <div class="text-center p-4 border rounded-lg bg-gray-800">
                        <div class="mb-2 text-sm text-white">Normal</div>
                        <SearchIcon mode="dark" state="normal" width={18} />
                    </div>
                    <div class="text-center p-4 border rounded-lg bg-gray-800">
                        <div class="mb-2 text-sm text-white">Placeholder</div>
                        <SearchIcon mode="dark" state="placeholder" width={18} />
                    </div>
                    <div class="text-center p-4 border rounded-lg bg-gray-800">
                        <div class="mb-2 text-sm text-white">Disable</div>
                        <SearchIcon mode="dark" state="disable" width={18} />
                    </div>
                </div>
                
                <!-- 不同尺寸 -->
                <div class="space-y-4">
                    <h4 class="text-md font-medium text-center">不同尺寸</h4>
                    <div class="text-center p-4 border rounded-lg">
                        <div class="mb-2 text-sm">Small (16px)</div>
                        <SearchIcon width={16} />
                    </div>
                    <div class="text-center p-4 border rounded-lg">
                        <div class="mb-2 text-sm">Medium (20px)</div>
                        <SearchIcon width={20} />
                    </div>
                    <div class="text-center p-4 border rounded-lg">
                        <div class="mb-2 text-sm">Large (24px)</div>
                        <SearchIcon width={24} />
                    </div>
                </div>
            </div>
        </div>
        
        <!-- 實際使用範例 -->
        <div class="mb-8">
            <h3 class="text-lg font-semibold mb-4">實際使用範例</h3>
            
            <!-- 搜尋框範例 -->
            <div class="mb-6">
                <h4 class="text-md font-medium mb-3">搜尋框</h4>
                <div class="relative max-w-md">
                    <input 
                        type="text" 
                        placeholder="搜尋產品..." 
                        class="w-full pl-4 pr-12 py-3 border border-gray-300 rounded-lg"
                    />
                    <button class="h-full flex items-center justify-center w-12 absolute right-0 top-1/2 -translate-y-1/2">
                        <SearchIcon mode="light" state="normal" width={18} />
                    </button>
                </div>
            </div>
            
            <!-- 程式碼範例 -->
            <div class="mb-6">
                <h4 class="text-md font-medium mb-3">使用方式</h4>
                <div class="bg-gray-900 text-gray-100 p-4 rounded-lg overflow-x-auto">
                    <pre><code>{`<!-- 基本使用 -->
<SearchIcon />

<!-- 指定 Mode 和 State -->
<SearchIcon mode="dark" state="placeholder" />

<!-- 自定義尺寸 -->
<SearchIcon width={24} />

<!-- 在搜尋框中使用 -->
<SearchIcon mode="light" state="normal" width={20} />`}</code></pre>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .search-examples {
        .container {
            max-width: 1200px;
        }
        
        .grid {
            display: grid;
        }
        
        .grid-cols-2 {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .grid-cols-3 {
            grid-template-columns: repeat(3, 1fr);
        }
        
        .gap-4 {
            gap: 1rem;
        }
        
        .gap-6 {
            gap: 1.5rem;
        }
        
        .space-y-4 > * + * {
            margin-top: 1rem;
        }
        
        .mx-auto {
            margin-left: auto;
            margin-right: auto;
        }
        
        .px-4 {
            padding-left: 1rem;
            padding-right: 1rem;
        }
        
        .py-8 {
            padding-top: 2rem;
            padding-bottom: 2rem;
        }
        
        .p-4 {
            padding: 1rem;
        }
        
        .pl-4 {
            padding-left: 1rem;
        }
        
        .pr-12 {
            padding-right: 3rem;
        }
        
        .py-3 {
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
        }
        
        .mb-2 {
            margin-bottom: 0.5rem;
        }
        
        .mb-3 {
            margin-bottom: 0.75rem;
        }
        
        .mb-4 {
            margin-bottom: 1rem;
        }
        
        .mb-6 {
            margin-bottom: 1.5rem;
        }
        
        .mb-8 {
            margin-bottom: 2rem;
        }
        
        .text-sm {
            font-size: 0.875rem;
        }
        
        .text-md {
            font-size: 1rem;
        }
        
        .text-lg {
            font-size: 1.125rem;
        }
        
        .text-2xl {
            font-size: 1.5rem;
        }
        
        .font-medium {
            font-weight: 500;
        }
        
        .font-semibold {
            font-weight: 600;
        }
        
        .font-bold {
            font-weight: 700;
        }
        
        .text-center {
            text-align: center;
        }
        
        .text-white {
            color: white;
        }
        
        .text-gray-100 {
            color: #f3f4f6;
        }
        
        .border {
            border-width: 1px;
            border-color: #d1d5db;
        }
        
        .border-gray-300 {
            border-color: #d1d5db;
        }
        
        .rounded-lg {
            border-radius: 0.5rem;
        }
        
        .bg-gray-800 {
            background-color: #1f2937;
        }
        
        .bg-gray-900 {
            background-color: #111827;
        }
        
        .relative {
            position: relative;
        }
        
        .absolute {
            position: absolute;
        }
        
        .right-3 {
            right: 0.75rem;
        }
        
        .top-1\/2 {
            top: 50%;
        }
        
        .transform {
            transform: translate(var(--tw-translate-x), var(--tw-translate-y));
        }
        
        .-translate-y-1\/2 {
            --tw-translate-y: -50%;
        }
        
        .max-w-md {
            max-width: 28rem;
        }
        
        .w-full {
            width: 100%;
        }
        
        .overflow-x-auto {
            overflow-x: auto;
        }
    }
</style>

---
/** Common Component */
import './HideShowIcon.scss';

export interface Props {
    state?: 'show' | 'hide';
    class?: any;
}

const {
    state = 'show',
    class: className = ''
} = Astro.props;

// 根據 props 決定樣式類別
const getVariantClass = () => {
    const baseClass = 'hide-show-icon';
    const stateClass = `hide-show-icon--${state}`;
    
    return `${baseClass} ${stateClass}`;
};
---


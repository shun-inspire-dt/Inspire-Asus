---
import HideShowIconComponent from './HideShowIcon.astro';
---

<div class="hide-show-icon-examples">
    <h2 class="text-2xl font-bold mb-6">Hide/Show Icon Examples</h2>

    <!-- Basic States -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">基本狀態</h3>
        <div class="grid grid-cols-2 gap-6 p-6 bg-white rounded-lg border">
            <!-- Show State -->
            <div class="text-center">
                <div class="mb-2 p-4 bg-gray-50 rounded">
                    <HideShowIconComponent state="show" />
                </div>
                <p class="text-sm text-gray-600">顯示狀態<br />（密碼可見）</p>
            </div>

            <!-- Hide State -->
            <div class="text-center">
                <div class="mb-2 p-4 bg-gray-50 rounded">
                    <HideShowIconComponent state="hide" />
                </div>
                <p class="text-sm text-gray-600">隱藏狀態<br />（密碼隱藏）</p>
            </div>
        </div>
    </div>

    <!-- Interactive Examples -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">實際使用情境</h3>
        <div class="space-y-4 p-6 bg-gray-50 rounded-lg border">
            <!-- Password Input Example -->
            <div class="flex items-center gap-3">
                <label class="text-sm font-medium">密碼輸入框:</label>
                <div class="relative">
                    <input 
                        type="password" 
                        placeholder="請輸入密碼" 
                        class="pr-10 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    />
                    <button class="absolute right-2 top-1/2 transform -translate-y-1/2">
                        <HideShowIconComponent state="show" />
                    </button>
                </div>
            </div>

            <!-- Confirm Password Input -->
            <div class="flex items-center gap-3">
                <label class="text-sm font-medium">確認密碼:</label>
                <div class="relative">
                    <input 
                        type="text" 
                        placeholder="請再次輸入密碼" 
                        class="pr-10 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    />
                    <button class="absolute right-2 top-1/2 transform -translate-y-1/2">
                        <HideShowIconComponent state="hide" />
                    </button>
                </div>
            </div>

            <!-- Login Form Example -->
            <div class="mt-6 p-4 bg-white rounded-lg border">
                <h4 class="font-medium mb-3">登入表單範例</h4>
                <div class="space-y-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">帳號</label>
                        <input 
                            type="email" 
                            placeholder="請輸入電子郵件" 
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">密碼</label>
                        <div class="relative">
                            <input 
                                type="password" 
                                placeholder="請輸入密碼" 
                                class="w-full pr-10 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                            />
                            <button class="absolute right-2 top-1/2 transform -translate-y-1/2 hover:bg-gray-100 rounded p-1">
                                <HideShowIconComponent state="show" />
                            </button>
                        </div>
                    </div>
                    <button class="w-full bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700 transition-colors">
                        登入
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Different Sizes -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">不同尺寸展示</h3>
        <div class="flex items-center gap-6 p-6 bg-white rounded-lg border">
            <div class="text-center">
                <div class="mb-2 p-4 bg-gray-50 rounded">
                    <HideShowIconComponent state="show" class="w-4 h-4" />
                </div>
                <p class="text-sm text-gray-600">小尺寸 (16px)</p>
            </div>

            <div class="text-center">
                <div class="mb-2 p-4 bg-gray-50 rounded">
                    <HideShowIconComponent state="show" />
                </div>
                <p class="text-sm text-gray-600">預設尺寸 (24px)</p>
            </div>

            <div class="text-center">
                <div class="mb-2 p-4 bg-gray-50 rounded">
                    <HideShowIconComponent state="show" class="w-8 h-8" />
                </div>
                <p class="text-sm text-gray-600">大尺寸 (32px)</p>
            </div>
        </div>
    </div>

    <!-- Interactive Toggle Example -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">互動切換範例</h3>
        <div class="p-6 bg-white rounded-lg border">
            <p class="text-sm text-gray-600 mb-4">
                實際應用中，這些圖示通常會透過 JavaScript 來切換狀態，同時改變輸入框的 type 屬性。
            </p>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <p class="text-sm font-medium mb-2">點擊前 (密碼隱藏)</p>
                    <div class="relative">
                        <input 
                            type="password" 
                            value="mypassword123" 
                            class="w-full pr-10 px-3 py-2 border border-gray-300 rounded-md"
                            readonly
                        />
                        <button class="absolute right-2 top-1/2 transform -translate-y-1/2">
                            <HideShowIconComponent state="show" />
                        </button>
                    </div>
                </div>
                <div>
                    <p class="text-sm font-medium mb-2">點擊後 (密碼顯示)</p>
                    <div class="relative">
                        <input 
                            type="text" 
                            value="mypassword123" 
                            class="w-full pr-10 px-3 py-2 border border-gray-300 rounded-md"
                            readonly
                        />
                        <button class="absolute right-2 top-1/2 transform -translate-y-1/2">
                            <HideShowIconComponent state="hide" />
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Usage Code Examples -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">使用範例</h3>
        <div class="bg-gray-900 text-green-400 p-4 rounded-lg font-mono text-sm">
            <div class="mb-2">// 基本使用 (預設顯示狀態)</div>
            <div class="text-white">&lt;HideShowIconComponent /&gt;</div>
            <br />
            <div class="mb-2">// 顯示狀態</div>
            <div class="text-white">&lt;HideShowIconComponent state="show" /&gt;</div>
            <br />
            <div class="mb-2">// 隱藏狀態</div>
            <div class="text-white">&lt;HideShowIconComponent state="hide" /&gt;</div>
            <br />
            <div class="mb-2">// 自定義樣式</div>
            <div class="text-white">&lt;HideShowIconComponent state="show" class="w-6 h-6 text-blue-600" /&gt;</div>
        </div>
    </div>

    <!-- Props Documentation -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">Props</h3>
        <div class="overflow-x-auto">
            <table class="w-full border-collapse border border-gray-300">
                <thead>
                    <tr class="bg-gray-50">
                        <th class="border border-gray-300 px-4 py-2 text-left">Prop</th>
                        <th class="border border-gray-300 px-4 py-2 text-left">Type</th>
                        <th class="border border-gray-300 px-4 py-2 text-left">Default</th>
                        <th class="border border-gray-300 px-4 py-2 text-left">Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="border border-gray-300 px-4 py-2 font-mono">state</td>
                        <td class="border border-gray-300 px-4 py-2">'show' | 'hide'</td>
                        <td class="border border-gray-300 px-4 py-2">'show'</td>
                        <td class="border border-gray-300 px-4 py-2">圖示狀態，控制顯示哪個圖示</td>
                    </tr>
                    <tr>
                        <td class="border border-gray-300 px-4 py-2 font-mono">class</td>
                        <td class="border border-gray-300 px-4 py-2">any</td>
                        <td class="border border-gray-300 px-4 py-2">''</td>
                        <td class="border border-gray-300 px-4 py-2">額外的 CSS 類別</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Color Variables -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">顏色變數</h3>
        <div class="p-6 bg-gray-50 rounded-lg border">
            <div>
                <h4 class="font-medium mb-2">預設顏色</h4>
                <ul class="text-sm text-gray-600 space-y-1">
                    <li>• 圖示顏色: <code>var(--color-gray-700, #4d4d4d)</code></li>
                    <li>• 焦點外框: <code>var(--color-blue-500, #006ce1)</code></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- JavaScript Integration -->
    <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4">JavaScript 整合</h3>
        <div class="bg-gray-900 text-green-400 p-4 rounded-lg font-mono text-sm">
            <div class="mb-2 text-green-400">// 密碼可見性切換功能</div>
            <div class="text-white">
                <div>function togglePasswordVisibility(inputId, iconElement) &#123;</div>
                <div class="ml-4">const input = document.getElementById(inputId);</div>
                <div class="ml-4">const isPassword = input.type === 'password';</div>
                <div class="ml-4"></div>
                <div class="ml-4">// 切換輸入框類型</div>
                <div class="ml-4">input.type = isPassword ? 'text' : 'password';</div>
                <div class="ml-4"></div>
                <div class="ml-4">// 更新圖示狀態</div>
                <div class="ml-4">iconElement.setAttribute('state', isPassword ? 'hide' : 'show');</div>
                <div>&#125;</div>
            </div>
        </div>
    </div>
</div>

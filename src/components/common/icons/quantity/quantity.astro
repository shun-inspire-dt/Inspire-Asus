---
export interface Props {
    quantity?: string | number;
    class?: any;
}

const { quantity = '2', class: className = '' } = Astro.props;

// 確保 quantity 是字串
const displayQuantity = String(quantity);
---

<span class={`quantity-label ${className}`}>
    <span class="quantity-label__text">
        {displayQuantity}
    </span>
</span>

<style lang="scss">
    .quantity-label {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 16px;
        min-height: 16px;
        padding: 2px 4px;
        background-color: var(--color-blue-500, #006ce1);
        border-radius: 20px;
        box-sizing: border-box;

        &__text {
            font-family: var(--font-family-roboto);
            font-size: var(--fs-12);
            font-weight: var(--font-weight-400);
            line-height: 0;
            color: var(--color-white, #ffffff);
            text-align: center;
            white-space: nowrap;
            letter-spacing: var(--letter-spacing);
            font-variation-settings: 'wdth' 100;
        }
    }
</style>

---
/** Style */
import './SocialIcon.scss';

export interface Props {
    class?: any;
    Tag?: 'span' | 'a' | 'button' | 'div';
    type?: 'icon_microsoft' | 'icon_line' | 'icon_google' | 'icon_fb' | 'icon_apple';
    size?: 'lg' | 'md' | 'sm';
    width?: string | number;
    [key: string]: any;
}

const { width, type = 'icon_google', size = 'lg', class: className = '', Tag = 'span', ...rest } = Astro.props;

// 動態引入對應的 SVG 組件
const iconMap = {
    'icon_microsoft-lg': (await import('./svg-astro/type_icon_microsoft-size_lg.astro')).default,
    'icon_microsoft-md': (await import('./svg-astro/type_icon_microsoft-size_md.astro')).default,
    'icon_microsoft-sm': (await import('./svg-astro/type_icon_microsoft-size_sm.astro')).default,
    'icon_line-lg': (await import('./svg-astro/type_icon_line-size_lg.astro')).default,
    'icon_line-md': (await import('./svg-astro/type_icon_line-size_md.astro')).default,
    'icon_line-sm': (await import('./svg-astro/type_icon_line-size_sm.astro')).default,
    'icon_google-lg': (await import('./svg-astro/type_icon_google-size_lg.astro')).default,
    'icon_google-md': (await import('./svg-astro/type_icon_google-size_md.astro')).default,
    'icon_google-sm': (await import('./svg-astro/type_icon_google-size_sm.astro')).default,
    'icon_fb-lg': (await import('./svg-astro/type_icon_fb-size_lg.astro')).default,
    'icon_fb-md': (await import('./svg-astro/type_icon_fb-size_md.astro')).default,
    'icon_fb-sm': (await import('./svg-astro/type_icon_fb-size_sm.astro')).default,
    'icon_apple-lg': (await import('./svg-astro/type_icon_apple-size_lg.astro')).default,
    'icon_apple-md': (await import('./svg-astro/type_icon_apple-size_md.astro')).default,
    'icon_apple-sm': (await import('./svg-astro/type_icon_apple-size_sm.astro')).default
} as const;

// 獲取配置信息
const getIconConfig = (type: string, size: string) => {
    const configMap: Record<string, { displayName: string; width: number; height: number }> = {
        'icon_microsoft-lg': { displayName: 'Microsoft', width: 32, height: 32 },
        'icon_microsoft-md': { displayName: 'Microsoft', width: 24, height: 24 },
        'icon_microsoft-sm': { displayName: 'Microsoft', width: 20, height: 20 },
        'icon_line-lg': { displayName: 'Line', width: 32, height: 32 },
        'icon_line-md': { displayName: 'Line', width: 24, height: 24 },
        'icon_line-sm': { displayName: 'Line', width: 20, height: 20 },
        'icon_google-lg': { displayName: 'Google', width: 32, height: 32 },
        'icon_google-md': { displayName: 'Google', width: 24, height: 24 },
        'icon_google-sm': { displayName: 'Google', width: 20, height: 20 },
        'icon_fb-lg': { displayName: 'Facebook', width: 32, height: 32 },
        'icon_fb-md': { displayName: 'Facebook', width: 24, height: 24 },
        'icon_fb-sm': { displayName: 'Facebook', width: 20, height: 20 },
        'icon_apple-lg': { displayName: 'Apple', width: 32, height: 32 },
        'icon_apple-md': { displayName: 'Apple', width: 24, height: 24 },
        'icon_apple-sm': { displayName: 'Apple', width: 20, height: 20 }
    };

    const key = `${type}-${size}`;
    return configMap[key] || configMap['icon_google-lg'];
};

const iconKey = `${type}-${size}` as keyof typeof iconMap;
const IconComponent = iconMap[iconKey] || iconMap['icon_google-lg'];
const iconConfig = getIconConfig(type, size);

const classes = ['social-icon', `social-icon--${type.replace('icon_', '')}`, `social-icon--${size.toLowerCase()}`, className]
    .filter(Boolean)
    .join(' ');

// 根據 props.width 設定對應的 CSS 變數，用於控制圖示尺寸
const widthVar = !isNaN(width as number) ? `${parseInt(width as string) / 16}rem` : undefined;
// 將 widthVar 套用到對應的 CSS 變數上
const style = {
    '--social-icon-size-lg': widthVar,
    '--social-icon-size-md': widthVar,
    '--social-icon-size-sm': widthVar
};
---

<Tag
    class={classes}
    data-social-icon
    data-type={type}
    data-size={size}
    title={`${iconConfig.displayName} 圖示`}
    role="img"
    aria-label={`${iconConfig.displayName} 社群媒體圖示`}
    style={style}
    {...rest}
>
    <IconComponent />
</Tag>

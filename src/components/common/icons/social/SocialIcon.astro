---
/** Style */
import { undefined } from 'astro:schema';
import './SocialIcon.scss';

export interface Props {
    type?: 'icon_microsoft' | 'icon_line' | 'icon_google' | 'icon_fb' | 'icon_apple';
    size?: 'lg' | 'md' | 'sm';
    width?: string | number;
    class?: any;
    [key: string]: any;
}

const { width ,type = 'icon_google', size = 'lg', class: className = '', ...rest } = Astro.props;

// 根據 props 獲取對應的 SVG 路徑和尺寸
const getSvgConfig = (type: string, size: string) => {
    const configMap: Record<
        string,
        {
            svgPath: string;
            width: number;
            height: number;
            displayName: string;
        }
    > = {
        'icon_microsoft-lg': {
            svgPath: '/assets/images/icons/social/type_icon_microsoft-size_lg.svg',
            width: 32,
            height: 32,
            displayName: 'Microsoft'
        },
        'icon_microsoft-md': {
            svgPath: '/assets/images/icons/social/type_icon_microsoft-size_md.svg',
            width: 24,
            height: 24,
            displayName: 'Microsoft'
        },
        'icon_microsoft-sm': {
            svgPath: '/assets/images/icons/social/type_icon_microsoft-size_sm.svg',
            width: 20,
            height: 20,
            displayName: 'Microsoft'
        },
        'icon_line-lg': {
            svgPath: '/assets/images/icons/social/type_icon_line-size_lg.svg',
            width: 32,
            height: 32,
            displayName: 'Line'
        },
        'icon_line-md': {
            svgPath: '/assets/images/icons/social/type_icon_line-size_md.svg',
            width: 24,
            height: 24,
            displayName: 'Line'
        },
        'icon_line-sm': {
            svgPath: '/assets/images/icons/social/type_icon_line-size_sm.svg',
            width: 20,
            height: 20,
            displayName: 'Line'
        },
        'icon_google-lg': {
            svgPath: '/assets/images/icons/social/type_icon_google-size_lg.svg',
            width: 32,
            height: 32,
            displayName: 'Google'
        },
        'icon_google-md': {
            svgPath: '/assets/images/icons/social/type_icon_google-size_md.svg',
            width: 24,
            height: 24,
            displayName: 'Google'
        },
        'icon_google-sm': {
            svgPath: '/assets/images/icons/social/type_icon_google-size_sm.svg',
            width: 20,
            height: 20,
            displayName: 'Google'
        },
        'icon_fb-lg': {
            svgPath: '/assets/images/icons/social/type_icon_fb-size_lg.svg',
            width: 32,
            height: 32,
            displayName: 'Facebook'
        },
        'icon_fb-md': {
            svgPath: '/assets/images/icons/social/type_icon_fb-size_md.svg',
            width: 24,
            height: 24,
            displayName: 'Facebook'
        },
        'icon_fb-sm': {
            svgPath: '/assets/images/icons/social/type_icon_fb-size_sm.svg',
            width: 20,
            height: 20,
            displayName: 'Facebook'
        },
        'icon_apple-lg': {
            svgPath: '/assets/images/icons/social/type_icon_apple-size_lg.svg',
            width: 32,
            height: 32,
            displayName: 'Apple'
        },
        'icon_apple-md': {
            svgPath: '/assets/images/icons/social/type_icon_apple-size_md.svg',
            width: 24,
            height: 24,
            displayName: 'Apple'
        },
        'icon_apple-sm': {
            svgPath: '/assets/images/icons/social/type_icon_apple-size_sm.svg',
            width: 20,
            height: 20,
            displayName: 'Apple'
        }
    };

    const key = `${type}-${size}`;
    return configMap[key] || configMap['icon_google-lg'];
};

const svgConfig = getSvgConfig(type, size);

const classes = ['social-icon', `social-icon--${type.replace('icon_', '')}`, `social-icon--${size.toLowerCase()}`, className]
    .filter(Boolean)
    .join(' ');

// 獲取對應的 CSS 變數尺寸
const getSizeVariable = (size: string): string => {
    const sizeMap = {
        lg: 'var(--social-icon-size-lg, 32px)',
        md: 'var(--social-icon-size-md, 24px)',
        sm: 'var(--social-icon-size-sm, 20px)'
    };
    return sizeMap[size as keyof typeof sizeMap] || sizeMap['lg'];
};

const sizeVar = getSizeVariable(size);

// 動態載入 SVG 內容
const svgResponse = await fetch(new URL(svgConfig.svgPath, Astro.site || 'http://localhost:4321'));
const svgContent = await svgResponse.text();

// 清理 SVG 內容，移除 width 和 height 屬性以便 CSS 控制
const cleanedSvgContent = svgContent
    .replace(/width="[^"]*"/g, '')
    .replace(/height="[^"]*"/g, '')
    .replace(/<svg/, `<svg width="${svgConfig.width}" height="${svgConfig.height}"`);


// 根據 props.width 設定對應的 CSS 變數，用於控制圖示尺寸
const widthVar = !isNaN(width as number) ? `${parseInt(width as string) / 16}rem` : undefined;
// 將 widthVar 套用到對應的 CSS 變數上
const style = {
    '--social-icon-size-lg': widthVar,
    '--social-icon-size-md': widthVar,
    '--social-icon-size-sm': widthVar
};
---

<span
    class={classes}
    data-social-icon
    data-type={type}
    data-size={size}
    title={`${svgConfig.displayName} 圖示`}
    role="img"
    aria-label={`${svgConfig.displayName} 社群媒體圖示`}
    style={style}
    {...rest}
    set:html={cleanedSvgContent}
/>

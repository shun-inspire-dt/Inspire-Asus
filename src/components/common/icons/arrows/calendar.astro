---
/** Style */
import './calendar.scss';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    Tag?: 'span' | 'div' | 'button' | 'a';
    width?: string | number;
    color?: string;
}

const { IDName, className, style, attribute = {}, Tag = 'span', width = '24', color } = Astro.props as Props;

const cardStyle = {
    '--icon-width': (!isNaN(width as number) ? `${parseFloat(width as string) / 16}rem` : width).toString(),
    ...(color ? { '--icon-color': color.charAt(0) === '#' ? color : `var(--color-${color})` } : {}),
    ...style
};
---

<Tag id={IDName} class:list={[className, 'calendar-icon']} style={cardStyle} {...attribute}>
    <svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
            d="M1.5 2.09961H16.5C16.9971 2.09961 17.4004 2.50294 17.4004 3V17C17.4004 17.4971 16.9971 17.9004 16.5 17.9004H1.5C1.00294 17.9004 0.599609 17.4971 0.599609 17V3C0.59961 2.50294 1.00294 2.09961 1.5 2.09961Z"
            stroke="currentColor"
            stroke-width="1.2"></path>
        <line y1="6.9" x2="18" y2="6.9" stroke="currentColor" stroke-width="1.2"></line>
        <line x1="5.4" y1="3.9" x2="5.4" y2="0.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
        <line x1="12.9" y1="3.9" x2="12.9" y2="0.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
    </svg>
</Tag>

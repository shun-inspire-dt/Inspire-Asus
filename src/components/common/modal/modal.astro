---
/**
 * Modal 彈窗組件
 *
 * 基於 Bootstrap Modal 的可重用彈窗組件，支援多種尺寸、位置和自訂選項
 *
 * @example
 * ```astro
 * <Modal
 *   id="example"
 *   title="範例彈窗"
 *   sizes="lg"
 *   center={true}
 * >
 *   <p>彈窗內容</p>
 * </Modal>
 * ```
 */

/** Common Components */
/** Button */
import Button from '@components/common/button/button.astro';
/** Style */
import './modal.scss';

/**
 * Modal 組件的 Props 介面
 *
 * @property {string} id - Modal 的唯一識別 ID
 * @property {'sm' | 'md' | 'lg' | 'xl'} sizes - Modal 尺寸 @default 'md'
 * @property {boolean} center - 是否垂直置中 @default true
 * @property {boolean} scrollable - 是否可滾動 @default false
 * @property {string} title - Modal 標題
 * @property {boolean | 'static'} backdrop - Modal 背景 @default false
 * @property {boolean} keyboard - 是否可按 ESC 鍵關閉 @default true
 * @property {attribute} attribute - 額外的 HTML 屬性
 * @property {string} Modalclass - Modal 容器的 CSS 類別
 * @property {string} bodyClass - Modal 主體的 CSS 類別
 * @property {string} titleClass - Modal 標題的 CSS 類別
 * @property {string} dialogClass - Modal 對話框的 CSS 類別
 * @property {string} contentClass - Modal 內容的 CSS 類別
 * @property {boolean} hideHeader - 是否隱藏標題列 @default false
 * @property {boolean} hideTitle - 是否隱藏標題文字 @default false
 * @property {string} headerClass - 標題列的 CSS 類別
 * @property {boolean} hideColse - 是否隱藏關閉按鈕 @default false
 * @property {boolean} hideFooter - 是否隱藏底部按鈕列 @default false
 * @property {string} footerClass - 底部按鈕列的 CSS 類別
 * @property {string} cancelTitle - 取消按鈕文字 @default '取消'
 * @property {variant} cancelVariant - 取消按鈕樣式變體
 * @property {boolean} cancelDisabled - 取消按鈕是否禁用 @default false
 * @property {string} cancelClass - 取消按鈕的 CSS 類別
 * @property {boolean} cancelOnly - 是否只顯示取消按鈕 @default false
 * @property {string} okTitle - 確認按鈕文字 @default '儲存'
 * @property {variant} okVariant - 確認按鈕樣式變體
 * @property {boolean} okDisabled - 確認按鈕是否禁用 @default false
 * @property {string} okClass - 確認按鈕的 CSS 類別
 * @property {string[]} okAttribute - 確認按鈕的額外屬性
 * @property {boolean} okOnly - 是否只顯示確認按鈕 @default false
 */
export interface Props {
    id: string;
    sizes?: 'sm' | 'md' | 'lg' | 'xl';
    center?: boolean;
    scrollable?: boolean;
    title?: string;
    backdrop?: boolean | 'static';
    keyboard?: boolean;
    attribute?: attribute;

    Modalclass?: string;
    bodyClass?: string;
    headerClass?: string;
    titleClass?: string;
    dialogClass?: string;
    contentClass?: string;
    footerClass?: string;

    ContentTag?: string;
    contentAttribute?: attribute;

    hideHeader?: boolean;
    hideTitle?: boolean;
    hideColse?: boolean;
    hideFooter?: boolean;

    cancelTitle?: string;
    cancelVariant?: variant;
    cancelDisabled?: boolean;
    cancelClass?: string;
    cancelAttribute?: attribute;
    cancelOnly?: boolean;

    okTitle?: string;
    okVariant?: variant;
    okDisabled?: boolean;
    okClass?: string;
    okAttribute?: attribute;
    okOnly?: boolean;
}

const {
    id = 'example',
    sizes = 'md',
    center = true,
    scrollable = false,
    title = '',
    attribute = {},
    backdrop,
    keyboard,

    Modalclass = '',
    bodyClass = '',
    titleClass = '',
    dialogClass = '',
    contentClass = '',
    footerClass = '',

    ContentTag = 'div',
    contentAttribute = {},

    hideHeader = false,
    hideTitle = false,
    headerClass = '',
    hideColse = false,

    hideFooter = false,

    cancelTitle = '取消',
    cancelVariant,
    cancelDisabled = false,
    cancelClass = '',
    cancelAttribute = { 'data-bs-dismiss': 'modal' },
    cancelOnly = false,

    okTitle = '儲存',
    okVariant,
    okDisabled = false,
    okClass = '',
    okAttribute = {},
    okOnly = false
} = Astro.props as Props;

const modalSizes: { [key: string]: string } = {
    sm: 'modal-sm',
    md: '',
    lg: 'modal-lg',
    xl: 'modal-xl'
};
const modalSize = modalSizes?.[sizes];
---

<div
    class:list={['modal fade', Modalclass]}
    id={`${id}Modal`}
    tabindex="-1"
    data-bs-backdrop={backdrop}
    data-bs-keyboard={keyboard}
    aria-labelledby={`${id}ModalLabel`}
    aria-hidden="false"
    data-bs-focus="false"
    {...attribute}
>
    <div
        class:list={[
            'modal-dialog',
            modalSize,
            { 'modal-dialog-centered': center },
            { 'modal-dialog-scrollable': scrollable },
            dialogClass
        ]}
    >
        <ContentTag class:list={['modal-content', contentClass]} {...contentAttribute}>
            {
                !hideHeader && (
                    <div class:list={['modal-header', { hideHeader: hideTitle }, headerClass]}>
                        <slot name="title">
                            {!hideTitle && (
                                <div class:list={['modal-title', titleClass]} id={`${id}ModalLabel`}>
                                    <slot name="title-left" />
                                    <span>{title}</span>
                                    <slot name="title-right" />
                                </div>
                            )}
                        </slot>
                        <slot name="header-right" />
                        {!hideColse && (
                            <Button
                                IDName={id ? `${id}ModalCloseButton` : ''}
                                className={`modal-close-button`}
                                attribute={{
                                    'data-bs-dismiss': 'modal',
                                    'aria-label': 'Close'
                                }}
                                button={false}
                            />
                        )}
                    </div>
                )
            }
            <div class:list={['modal-body', { hideFooter: hideFooter }, { hideTitle: hideTitle }, bodyClass]}>
                <slot />
            </div>
            {
                !hideFooter && (
                    <div class:list={['modal-footer', footerClass]}>
                        <slot name="footer">
                            {!okOnly && (
                                <Button
                                    className={[cancelClass]}
                                    variant={cancelVariant}
                                    attribute={cancelAttribute}
                                    disabled={cancelDisabled}
                                >
                                    {cancelTitle}
                                </Button>
                            )}
                            {!cancelOnly && (
                                <Button className={[okClass]} variant={okVariant} disabled={okDisabled} attribute={okAttribute}>
                                    {okTitle}
                                </Button>
                            )}
                        </slot>
                    </div>
                )
            }
        </ContentTag>
    </div>
</div>

<script>
    /**
     * Modal 初始化腳本
     *
     * 自動初始化頁面上所有的 Modal 元素，
     * 為每個 Modal 添加事件監聽器和方法
     */

    /** Modules */
    import { Modal } from '@js/components/common/modal/modal';

    /**
     * 查找所有 Modal 元素並初始化
     */
    const modals = document.querySelectorAll('.modal') as NodeListOf<HTMLElement>;
    [...modals].forEach((modal) => {
        const backdrop = modal.getAttribute('data-bs-backdrop') === 'static' ? 'static' : true;
        const keyboard = modal.getAttribute('data-bs-keyboard') === 'false' ? false : true;
        new Modal(modal, { backdrop, keyboard }).addMethod();
    });
</script>

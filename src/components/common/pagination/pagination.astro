---
/**
 * 分頁組件 (Pagination Component)
 *
 * 功能特色：
 * - 支援 Light 和 Dark 主題
 * - 響應式設計，適配各種螢幕尺寸
 * - 完整的鍵盤導航支援
 * - 無障礙支援 (ARIA 屬性)
 * - 可自訂樣式和行為
 * - 支援省略號顯示
 *
 * @author Asus Team
 * @version 1.0.0
 */

/** 引入樣式檔案 */
import './pagination.scss';

/**
 * 組件屬性介面定義
 *
 * @interface Props
 * @property {string} [IDName] - 分頁組件唯一識別碼
 * @property {string} [className] - 自訂 CSS 類別
 * @property {attribute} [attribute] - 額外的 HTML 屬性
 * @property {{ [key: string]: string }} [style] - 內聯樣式
 * @property {number} [active] - 當前頁碼 (1-based)
 * @property {number} [total] - 總頁數
 * @property {"Light" | "Dark"} [mode] - 主題模式
 * @property {boolean} [showStartEllipsis] - 是否顯示開始省略號
 * @property {boolean} [showEndEllipsis] - 是否顯示結束省略號
 * @property {number} [visiblePages] - 可見頁碼數量
 */
export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    active?: number;
    total?: number;
    mode?: 'Light' | 'Dark';
    showStartEllipsis?: boolean;
    showEndEllipsis?: boolean;
    visiblePages?: number;
    noActive?: boolean;
    noDisabled?: boolean;
    hasDataValue?: boolean;
}

const {
    IDName,
    className,
    style,
    attribute = {},
    active = 1,
    total = 12,
    mode = 'Light',
    showStartEllipsis = false,
    showEndEllipsis = false,
    visiblePages = 7,
    noDisabled = false,
    noActive = false,
    hasDataValue = false
} = Astro.props as Props;

/**
 * 計算頁碼顯示邏輯
 */
function shouldShowPage(page: number, current: number, total: number, visible: number): boolean {
    if (total <= visible) return true;

    const half = Math.floor(visible / 2);
    let start = Math.max(1, current - half);
    let end = Math.min(total, start + visible - 1);

    if (end - start + 1 < visible) {
        start = Math.max(1, end - visible + 1);
    }

    return page >= start && page <= end;
}

const allPages = Array.from({ length: total }, (_, i) => i + 1);
---

{/** 分頁容器 - 支援 Light 和 Dark 主題 */}
<div
    id={IDName}
    class:list={['pagination', `pagination--${mode.toLowerCase()}`, className]}
    style={style}
    {...attribute}
    role="navigation"
    aria-label="分頁導航"
>
    {/** 上一頁按鈕 */}
    <a
        href={active > 1 ? `?page=${active - 1}` : undefined}
        title="上一頁"
        class:list={[
            'pagination__arrow',
            'pagination__arrow--prev',
            { 'pagination__arrow--disabled': active === 1 && !noDisabled }
        ]}
        aria-label="上一頁"
        aria-disabled={active === 1 && !noDisabled}
        tabindex={active === 1 && !noDisabled ? -1 : 0}
    >
        <span class="pagination__arrow-icon pagination__arrow-icon--prev" aria-hidden="true"></span>
    </a>

    {/** 所有頁碼和省略號 */}
    {
        allPages.map((page, index) => {
            // 省略號應該插入在最後一頁的前一位，即 total - 1 頁的後面
            const isBeforeLastPage = page === total - 1;
            // 開始省略號插入在 index 1 的位置（第 2 個頁碼前）
            const isStartEllipsisPosition = index === 1;

            return (
                <>
                    {isStartEllipsisPosition && (
                        <span
                            class="pagination__ellipsis"
                            aria-hidden="true"
                            style={{ ...(showStartEllipsis ? {} : { display: 'none' }) }}
                        >
                            ...
                        </span>
                    )}
                    <a
                        href={`?page=${page}`}
                        title={`第 ${page} 頁`}
                        class:list={['pagination__item', { 'pagination__item--active': active === page && !noActive }]}
                        aria-label={`第 ${page} 頁`}
                        aria-current={active === page ? 'page' : undefined}
                        data-index={hasDataValue ? page : undefined}
                        style={{ ...(shouldShowPage(page, active, total, visiblePages) ? {} : { display: 'none' }) }}
                    >
                        {page}
                    </a>
                    {isBeforeLastPage && (
                        <span
                            class="pagination__ellipsis"
                            aria-hidden="true"
                            style={{ ...(showEndEllipsis ? {} : { display: 'none' }) }}
                        >
                            ...
                        </span>
                    )}
                </>
            );
        })
    }

    {/** 下一頁按鈕 */}
    <a
        href={active < total ? `?page=${active + 1}` : undefined}
        title="下一頁"
        class:list={[
            'pagination__arrow',
            'pagination__arrow--next',
            { 'pagination__arrow--disabled': active === total && !noDisabled }
        ]}
        aria-label="下一頁"
        aria-disabled={active === total && !noDisabled}
        tabindex={active === total && !noDisabled ? -1 : 0}
    >
        <span class="pagination__arrow-icon pagination__arrow-icon--next" aria-hidden="true"></span>
    </a>
</div>

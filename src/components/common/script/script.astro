<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        /**
         * 國際化訊息配置
         */
        const I18N_MESSAGES = {
            'zh-TW': {
                required: '填寫這個欄位',
                pattern: '請符合要求格式',
                tel: '請輸入正確的電話號碼',
                phone: '請輸入正確的電話號碼',
                email: (value) => {
                    if (!value.includes('@')) {
                        return `請在電子郵件地址中包括「@」。「${value}」未包含「@」`;
                    } else {
                        return `請輸入「@」後面的部分。「${value}」不是完整值。`;
                    }
                },
                minLength: (minLength, currentLength) => `請將這段文字加長到 ${minLength} 個字元以上 (目前已有 ${currentLength} 個字元數)`,
                maxLength: (maxLength, currentLength) => `請將這段文字縮短到 ${maxLength} 個字元以下 (目前已有 ${currentLength} 個字元數)`,
                min: (min) => `值必須大於或等於 ${min}。`,
                max: (max) => `值必須小於或等於 ${max}。`,
                regex: '',
                passwordConfirm: '與密碼不符合'
            },
            'en-US': {
                required: 'Please fill out this field',
                pattern: 'Please match the required format',
                tel: 'Please enter a valid phone number',
                phone: 'Please enter a valid phone number',
                email: (value) => {
                    if (!value.includes('@')) {
                        return `Please include an '@' in the email address. '${value}' is missing an '@'`;
                    } else {
                        return `Please enter the part following '@'. '${value}' is not a complete value.`;
                    }
                },
                minLength: (minLength, currentLength) => `Please lengthen this text to ${minLength} characters or more (you are currently using ${currentLength} characters)`,
                maxLength: (maxLength, currentLength) => `Please shorten this text to ${maxLength} characters or less (you are currently using ${currentLength} characters)`,
                min: (min) => `Value must be greater than or equal to ${min}.`,
                max: (max) => `Value must be less than or equal to ${max}.`,
                regex: '',
                passwordConfirm: 'Passwords do not match'
            },
            'ja-JP': {
                required: 'このフィールドを入力してください',
                pattern: '要求された形式に一致させてください',
                tel: '正しい電話番号を入力してください',
                phone: '正しい電話番号を入力してください',
                email: (value) => {
                    if (!value.includes('@')) {
                        return `メールアドレスに「@」を含めてください。「${value}」には「@」がありません`;
                    } else {
                        return `「@」の後の部分を入力してください。「${value}」は完全な値ではありません。`;
                    }
                },
                minLength: (minLength, currentLength) => `このテキストを${minLength}文字以上にしてください（現在${currentLength}文字です）`,
                maxLength: (maxLength, currentLength) => `このテキストを${maxLength}文字以下にしてください（現在${currentLength}文字です）`,
                min: (min) => `値は${min}以上である必要があります。`,
                max: (max) => `値は${max}以下である必要があります。`,
                regex: '',
                passwordConfirm: 'パスワードが一致しません'
            }
        };

        /**
         * 表單驗證器類別
         */
        class FormValidator {
            constructor(form, locale = 'zh-TW', options = {}) {
                this.form = form;
                this.locale = locale;
                this.messages = I18N_MESSAGES[locale] || I18N_MESSAGES['zh-TW'];
                this.options = {
                    reportValidity: true, // 預設啟用原生驗證提示
                    ...options
                };
                this.setupEventListeners();
            }

            /**
             * 重置所有錯誤訊息
             */
            resetErrorMessages() {
                const errorTextEls = this.form.querySelectorAll('.error-text > span[data-feedback]');
                errorTextEls.forEach((errorTextEl) => {
                    const feedback = errorTextEl.getAttribute('data-feedback');
                    if (feedback) errorTextEl.textContent = feedback;
                });
            }

            /**
             * 取得錯誤訊息元素
             */
            getErrorElement(input, isSpecialInput = false) {
                if (isSpecialInput) {
                    const parent = input.closest('.form-check, .password-input-wrapper');
                    return parent?.closest('.form-input-group')?.querySelectorAll('.error-text > span')?.[1] ||
                           parent?.parentElement?.querySelectorAll('.form-check-feedback-text.error-text > span')?.[1];
                }
                return input?.closest('.form-input-group')?.querySelectorAll('.error-text > span')?.[1];
            }

            /**
             * 更新錯誤訊息
             */
            updateErrorMessage(errorTextEl, feedback, isRequired = false) {
                if (!errorTextEl) return;
                
                // 如果是 required 驗證
                if (isRequired) {
                    // 如果 errorTextEl 沒有 textContent，才使用預設訊息取代
                    if (!errorTextEl.textContent || errorTextEl.textContent.trim() === '') {
                        errorTextEl.textContent = feedback || this.messages.required;
                    }
                    // 如果有 textContent，保持原始內容不變
                    return;
                }
                
                // 其他驗證規則的處理
                if (!feedback) return;
                
                if (feedback !== errorTextEl.textContent) {
                    if (!errorTextEl.getAttribute('data-feedback')) {
                        errorTextEl.setAttribute('data-feedback', errorTextEl.textContent);
                    }
                    errorTextEl.textContent = feedback;
                }
            }

            /**
             * 設定驗證狀態
             */
            setValidationState(input, isInvalid, feedback = '', element = null) {
                const targetElement = element || input;
                
                if (!this.form.classList.contains('was-validated')) {
                    this.form.classList.toggle('was-validated', isInvalid);
                }
                
                if (!targetElement.classList.contains('is-invalid')) {
                    targetElement.classList.toggle('is-invalid', !isInvalid);
                }
                
                if (input.setCustomValidity) {
                    input.setCustomValidity(isInvalid ? feedback : '');
                }
            }

            /**
             * 通用驗證處理器
             */
            handleValidation(input, isInvalid, feedback, element = null, isRequired = false) {
                this.setValidationState(input, isInvalid, feedback, element);
                
                if (isInvalid) {
                    const errorTextEl = this.getErrorElement(input, !!element);
                    this.updateErrorMessage(errorTextEl, feedback, isRequired);
                }
            }

            /**
             * 為原生驗證屬性添加事件監聽器
             */
            addNativeValidationListener(selector, feedbackGenerator) {
                const inputs = this.form.querySelectorAll(selector);
                inputs.forEach((input) => {
                    if (input.value) {
                        input.addEventListener('invalid', () => {
                            const feedback = feedbackGenerator(input);
                            const errorTextEl = this.getErrorElement(input);
                            this.updateErrorMessage(errorTextEl, feedback);
                        }, { once: true });
                    }
                });
            }

            /**
             * 處理原生 HTML5 驗證
             */
            handleNativeValidation() {
                const nativeInputs = this.form.querySelectorAll('input[required]:not([data-valid])');
                const rules = this.getValidationRules();
                
                nativeInputs.forEach((input) => {
                    const value = input.value;
                    
                    // 定義驗證順序（優先順序從高到低）
                    const validationOrder = [
                        {
                            condition: () => !value,
                            rule: rules.required,
                            getDefaultMessage: () => rules.required.getDefaultMessage()
                        },
                        {
                            condition: () => value && input.type === 'email' && !/^\S+@\S+\.\S+$/.test(value),
                            rule: rules.email,
                            getDefaultMessage: () => rules.email.getDefaultMessage(input)
                        },
                        {
                            condition: () => value && input.minLength > 0 && value.length < parseInt(input.minLength),
                            rule: rules.minLength,
                            getDefaultMessage: () => rules.minLength.getDefaultMessage(input)
                        },
                        {
                            condition: () => value && input.maxLength > 0 && value.length > parseInt(input.maxLength),
                            rule: rules.maxLength,
                            getDefaultMessage: () => rules.maxLength.getDefaultMessage(input)
                        },
                        {
                            condition: () => value && input.min && parseFloat(value) < parseFloat(input.min),
                            rule: rules.min,
                            getDefaultMessage: () => rules.min.getDefaultMessage(input)
                        },
                        {
                            condition: () => value && input.max && parseFloat(value) > parseFloat(input.max),
                            rule: rules.max,
                            getDefaultMessage: () => rules.max.getDefaultMessage(input)
                        },
                        {
                            condition: () => value && input.pattern && !new RegExp(input.pattern).test(value),
                            rule: rules.pattern,
                            getDefaultMessage: () => rules.pattern.getDefaultMessage()
                        }
                    ];
                    
                    // 按順序檢查驗證規則，只處理第一個失敗的規則
                    for (let i = 0; i < validationOrder.length; i++) {
                        const validation = validationOrder[i];
                        if (validation.condition()) {
                            const feedback = validation.getDefaultMessage();
                            const isRequired = i === 0; // 第一個驗證是 required
                            this.handleValidation(input, true, feedback, null, isRequired);
                            return; // 找到第一個失敗的驗證就停止
                        }
                    }
                    
                    // 如果所有驗證都通過，清除錯誤狀態
                    this.handleValidation(input, false, '');
                });
            }

            /**
             * 處理包裝容器的驗證狀態
             * 針對 .form-check 和 .password-input-wrapper 底下的 input
             */
            handleWrapperValidation() {
                const wrapperInputs = this.form.querySelectorAll('.form-check input, .password-input-wrapper input');
                wrapperInputs.forEach((input) => {
                    const isInvalid = !input.checkValidity();
                    
                    // 找到最近的包裝容器
                    const wrapper = input.closest('.form-check, .password-input-wrapper');
                    if (wrapper) {
                        wrapper.classList.toggle('is-invalid', isInvalid);
                    }
                });
            }

            /**
             * 處理複選框驗證
             */
            handleCheckboxValidation() {
                const checkboxInputs = this.form.querySelectorAll('input.form-check-input[required]');
                checkboxInputs.forEach((input) => {
                    const { valid = '', validFeedback: feedback = '' } = input.dataset;
                    const isInvalid = !input.checkValidity();
                    
                    if (valid && isInvalid) {
                        const errorTextEl = this.getErrorElement(input, true);
                        this.updateErrorMessage(errorTextEl, feedback);
                    }
                });
            }

            /**
             * 驗證規則配置
             */
            getValidationRules() {
                return {
                    required: {
                        validate: (value) => !value,
                        getDefaultMessage: () => this.messages.required
                    },
                    pattern: {
                        validate: (value, input) => value && input.pattern && !new RegExp(input.pattern).test(value),
                        getDefaultMessage: () => this.messages.pattern
                    },
                    tel: {
                        validate: (value) => value && !/^09\d{8}$/.test(value),
                        getDefaultMessage: () => this.messages.tel
                    },
                    phone: {
                        validate: (value) => value && !/^09\d{8}$/.test(value),
                        getDefaultMessage: () => this.messages.phone
                    },
                    email: {
                        validate: (value) => value && !/^\S+@\S+\.\S+$/.test(value),
                        getDefaultMessage: (input) => typeof this.messages.email === 'function' 
                            ? this.messages.email(input.value) 
                            : this.messages.email
                    },
                    minLength: {
                        validate: (value, input) => value && value.length < parseInt(input.minLength),
                        getDefaultMessage: (input) => typeof this.messages.minLength === 'function'
                            ? this.messages.minLength(input.minLength, input.value.length)
                            : this.messages.minLength
                    },
                    maxLength: {
                        validate: (value, input) => value && value.length > parseInt(input.maxLength),
                        getDefaultMessage: (input) => typeof this.messages.maxLength === 'function'
                            ? this.messages.maxLength(input.maxLength, input.value.length)
                            : this.messages.maxLength
                    },
                    min: {
                        validate: (value, input) => value && parseFloat(value) < parseFloat(input.min),
                        getDefaultMessage: (input) => typeof this.messages.min === 'function'
                            ? this.messages.min(input.min)
                            : this.messages.min
                    },
                    max: {
                        validate: (value, input) => value && parseFloat(value) > parseFloat(input.max),
                        getDefaultMessage: (input) => typeof this.messages.max === 'function'
                            ? this.messages.max(input.max)
                            : this.messages.max
                    },
                    regex: {
                        validate: (value, input) => {
                            const regex = new RegExp(input.dataset.validRegex);
                            return value && !regex.test(value);
                        },
                        getDefaultMessage: () => this.messages.regex
                    },
                    confirm: {
                        validate: (value, input) => {
                            const target = input.dataset.target;
                            if (!target) return false;
                            const targetInput = document.querySelector(target);
                            const targetValue = targetInput?.value || '';
                            return value && targetValue !== value;
                        },
                        getDefaultMessage: () => this.messages.passwordConfirm
                    }
                };
            }

            /**
             * 處理客製化驗證
             */
            handleCustomValidation() {
                const validInputs = this.form.querySelectorAll('input[data-valid][required]');
                const rules = this.getValidationRules();

                validInputs.forEach((input) => {
                    const { valid = '', validFeedback = '' } = input.dataset;
                    const valids = valid.split(',');
                    const feedbacks = validFeedback.split(',');
                    const value = input.value;

                    // 處理 required 驗證（優先處理）
                    if (valids.includes('required')) {
                        const validIndex = valids.indexOf('required');
                        const rule = rules.required;
                        const isInvalid = rule.validate(value);
                        const feedback = feedbacks[validIndex] || rule.getDefaultMessage();
                        
                        this.handleValidation(input, isInvalid, feedback);
                        if (isInvalid) return; // 如果 required 驗證失敗，不繼續其他驗證
                    }

                    // 如果沒有值，跳過其他驗證
                    if (!value && !valids.includes('confirm')) return;

                    // 處理其他驗證規則
                    for (const validType of valids) {
                        if (validType === 'required') continue; // 已處理過
                        
                        const rule = rules[validType];
                        if (!rule) continue;

                        const validIndex = valids.indexOf(validType);
                        const isInvalid = rule.validate(value, input);
                        const feedback = feedbacks[validIndex] || rule.getDefaultMessage(input);
                        
                        // 特殊處理 confirm 驗證的元素選擇
                        if (validType === 'confirm') {
                            const parent = input.closest('.password-input-wrapper');
                            this.handleValidation(input, isInvalid, feedback, parent);
                        } else {
                            this.handleValidation(input, isInvalid, feedback);
                        }
                        
                        if (isInvalid) return; // 一旦有驗證失敗，停止後續驗證
                    }
                });
            }

            /**
             * 設置事件監聽器
             */
            setupEventListeners() {
                this.form.addEventListener('submit', (event) => {
                    // 重置錯誤訊息
                    this.resetErrorMessages();
                    
                    // 執行各種驗證
                    this.handleNativeValidation();
                    this.handleWrapperValidation();
                    this.handleCheckboxValidation();
                    this.handleCustomValidation();

                    // 檢查表單是否有效
                    if (!this.form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                        this.form.classList.add('was-validated');
                        
                        // 可選的原生驗證提示
                        if (this.options.reportValidity) {
                            this.form.reportValidity();
                        }
                    }
                });
            }
        }

        /**
         * 取得當前語系
         */
        function getCurrentLocale() {
            // 優先順序：data-locale 屬性 > html lang 屬性 > navigator.language > 預設值
            const htmlElement = document.documentElement;
            return htmlElement.dataset.locale || 
                   htmlElement.lang || 
                   navigator.language || 
                   'zh-TW';
        }

        // 初始化所有需要驗證的表單
        const needsValidationForms = document.querySelectorAll('form.needs-validation[novalidate]');
        const currentLocale = getCurrentLocale();
        
        needsValidationForms.forEach((form) => {
            // 可以透過 form 的 data-locale 屬性覆蓋全域語系設定
            const formLocale = form.dataset.locale || currentLocale;
            
            // 可以透過 form 的 data-report-validity 屬性控制是否顯示原生驗證提示
            const reportValidity = form.dataset.reportValidity !== 'false';
            
            new FormValidator(form, formLocale, { reportValidity });
        });
    });
</script>

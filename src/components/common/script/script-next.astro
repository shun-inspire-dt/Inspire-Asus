---
/** Style */
import './script.scss';
---

<script is:inline>
    /**
     * 國際化訊息配置
     */
    const I18N_MESSAGES = {
        'zh-TW': {
            required: '此欄位為必填',
            pattern: '請符合要求格式',
            tel: '請輸入正確的電話號碼',
            phone: '請輸入正確的電話號碼',
            email: (value) => {
                if (!value.includes('@')) {
                    return `請在電子郵件地址中包括「@」。「${value}」未包含「@」`;
                } else {
                    return `請輸入「@」後面的部分。「${value}」不是完整值。`;
                }
            },
            minLength: (minLength, currentLength) =>
                `請將這段文字加長到 ${minLength} 個字元以上 (目前已有 ${currentLength} 個字元數)`,
            maxLength: (maxLength, currentLength) =>
                `請將這段文字縮短到 ${maxLength} 個字元以下 (目前已有 ${currentLength} 個字元數)`,
            min: (min) => `值必須大於或等於 ${min}。`,
            max: (max) => `值必須小於或等於 ${max}。`,
            regex: '',
            passwordConfirm: '與密碼不符合'
        },
        'en-US': {
            required: 'This field is required',
            pattern: 'Please match the required format',
            tel: 'Please enter a valid phone number',
            phone: 'Please enter a valid phone number',
            email: (value) => {
                if (!value.includes('@')) {
                    return `Please include an '@' in the email address. '${value}' is missing an '@'`;
                } else {
                    return `Please enter the part following '@'. '${value}' is not a complete value.`;
                }
            },
            minLength: (minLength, currentLength) =>
                `Please lengthen this text to ${minLength} characters or more (you are currently using ${currentLength} characters)`,
            maxLength: (maxLength, currentLength) =>
                `Please shorten this text to ${maxLength} characters or less (you are currently using ${currentLength} characters)`,
            min: (min) => `Value must be greater than or equal to ${min}.`,
            max: (max) => `Value must be less than or equal to ${max}.`,
            regex: '',
            passwordConfirm: 'Passwords do not match'
        },
        'ja-JP': {
            required: 'このフィールドを入力してください',
            pattern: '要求された形式に一致させてください',
            tel: '正しい電話番号を入力してください',
            phone: '正しい電話番号を入力してください',
            email: (value) => {
                if (!value.includes('@')) {
                    return `メールアドレスに「@」を含めてください。「${value}」には「@」がありません`;
                } else {
                    return `「@」の後の部分を入力してください。「${value}」は完全な値ではありません。`;
                }
            },
            minLength: (minLength, currentLength) =>
                `このテキストを${minLength}文字以上にしてください（現在${currentLength}文字です）`,
            maxLength: (maxLength, currentLength) =>
                `このテキストを${maxLength}文字以下にしてください（現在${currentLength}文字です）`,
            min: (min) => `値は${min}以上である必要があります。`,
            max: (max) => `値は${max}以下である必要があります。`,
            regex: '',
            passwordConfirm: 'パスワードが一致しません'
        }
    };

    /**
     * 表單驗證器選擇器定義
     * @typedef {Object} FormValidatorSelectors
     * @property {string} form - 需要驗證的 form selector
     * @property {string} errorText - 錯誤訊息文字容器 selector
     * @property {string} formInputGroup - 欄位群組容器 selector
     * @property {string} nativeInputs - 使用原生 required/email/minLength... 的 input selector
     * @property {string} nativeSelects - 使用原生 required 的 select selector
     * @property {string} specialWrapper - 特殊 wrapper（checkbox/radio 或 password wrapper）selector
     * @property {string} wrapperInputs - 位於特殊 wrapper 內、需要同步 wrapper is-invalid 狀態的 input selector
     * @property {string} formCheckFeedbackErrorText - checkbox/radio 的錯誤文字 selector
     * @property {string} checkboxRequired - required 的 checkbox/radio selector
     * @property {string} validInputs - 使用 data-valid 的 input/select selector
     */

    /**
     * 非同步驗證回傳格式
     * @typedef {boolean | {isValid?: boolean, valid?: boolean, ok?: boolean, feedback?: string}} AsyncValidatorResult
     */

    /**
     * FormValidator 建構選項
     * @typedef {Object} FormValidatorOptions
     * @property {boolean} [reportValidity] - 是否呼叫 form.reportValidity() 顯示原生 tooltip（預設由 form 的 data-report-validity 決定）
     * @property {Record<string, (input: HTMLInputElement | HTMLSelectElement) => Promise<AsyncValidatorResult> | AsyncValidatorResult>} [asyncValidators]
     * 非同步驗證函式集合；欄位需透過 data-target 指向對應 key
     * @property {(payload: FormValidatorFormData, helpers: FormValidatorHelpers) => (void | Promise<void>)} [onValidSubmit]
     * 表單通過驗證後的回呼；若未提供則會改為 dispatch form:validated 或提交 form action
     */

    /**
     * onValidSubmit 提供的 helper
     * @typedef {Object} FormValidatorHelpers
     * @property {(input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement, isInvalid: boolean, feedback: string, element?: HTMLElement | null) => void} triggerValidation
     * 手動觸發驗證（常用於 API 回應後，將錯誤顯示在特定欄位）
     * @property {HTMLFormElement} form - 當前綁定的 form
     * @property {FormValidator} validator - 當前 validator 實例
     */

    /**
     * FormValidator 提供給 onValidSubmit / form:validated 的資料結構
     * @typedef {Object} FormValidatorFormData
     * @property {HTMLFormElement} form - 當前表單
     * @property {Record<string, (HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)>} controls - 以 id 或 name 作為 key 的表單元素集合
     * @property {HTMLElement | null} submitter - 觸發 submit 的 element（button/input）
     */

    /**
     * submit loading 的處理上下文
     * @typedef {Object} SubmitLoadingContext
     * @property {boolean} needsLoading - 是否需要啟用 loading（由 form data-needs-loading 控制）
     * @property {HTMLButtonElement | null} submitButton - 觸發 submit 的 button（若 submitter 不是 button 則為 null）
     * @property {string | null} loadingText - button data-loading-text
     * @property {string} originTextAttrName - 用於保存按鈕原始文字的 attribute 名稱
     */

    /**
     * 表單驗證器類別
     * @description
     * 封裝表單驗證、錯誤訊息呈現、非同步驗證（data-valid=async）、submit/loading、以及 invalid 自動捲動等行為。
     */
    class FormValidator {
        /** @type {FormValidatorSelectors} */
        static SELECTORS = {
            form: 'form.needs-validation[novalidate]',
            errorText: '.error-text',
            formInputGroup: '.form-input-group',
            nativeInputs:
                'input[required]:not([data-valid]):not([type="checkbox"], [type="radio"]), textarea[required]:not([data-valid])',
            nativeSelects: 'select[required]:not([data-valid])',
            specialWrapper: '.form-check, .password-input-wrapper',
            wrapperInputs: '.form-check input[required], .password-input-wrapper input[required]',
            formCheckFeedbackErrorText: '.form-check-feedback-text.error-text',
            checkboxRequired: 'input[type="checkbox"][required], input[type="radio"][required]',
            validInputs:
                'input[data-valid][required]:not([type="checkbox"], [type="radio"]), select[data-valid][required], textarea[data-valid][required]'
        };

        /** @type {number} 用於避免 async 驗證結果覆蓋最新狀態的 runId */
        _validationRunId = 0;
        // _isProgrammaticSubmit = false;

        /** @type {boolean} submit 期間鎖定，避免重複送出 */
        _isSubmitting = false;

        /**
         * @param {HTMLFormElement | null | undefined} form - 欲綁定的表單；未提供時會用 SELECTORS.form 找第一個
         * @param {FormValidatorOptions} [options={}] - 建構選項
         */
        constructor(form, options = {}) {
            console.log('Form Validator Initialized !!', form.id || form.name);
            const resolvedForm = form || document.querySelector(FormValidator.SELECTORS.form);
            if (!resolvedForm) throw new Error('FormValidator: Form Element Not Found');
            this.form = resolvedForm;

            const { locale = this.getCurrentLocale(), reportValidity = 'false' } = this.form.dataset || {};

            this.locale = locale || this.getCurrentLocale();
            const resolved = I18N_MESSAGES[this.locale] || I18N_MESSAGES['zh-TW'];
            this.messages = resolved;

            this.options = {
                reportValidity: reportValidity !== 'false',
                asyncValidators: options.asyncValidators,
                ...options
            };

            this.cacheOriginFeedbackText();
            this.setupEventListeners();
        }

        /**
         * 取得當前語系
         * @returns {string} 語系代碼（例如 zh-TW/en-US/ja-JP）
         */
        getCurrentLocale() {
            const htmlElement = document.documentElement;
            return this.form?.dataset?.locale || htmlElement.dataset.locale || htmlElement.lang || navigator.language || 'zh-TW';
        }

        /**
         * 是否啟用即時驗證
         * @description 當表單未通過 checkValidity 時，input/select 的變更會立即觸發驗證
         * @returns {boolean}
         */
        isLiveValidateEnabled() {
            const value = this.form.dataset.liveValidate;
            return value === '' || value === 'true';
        }

        /**
         * 是否啟用「invalid 自動捲動」
         * @description form 需具有 data-invalid-scrolling 才會執行
         * @returns {boolean}
         */
        isInvalidScrollingEnabled() {
            return this.form.hasAttribute('data-invalid-scrolling');
        }

        /**
         * 解析 data-scroll-offset
         * @description
         * - 數字：像素
         * - selector：元素高度（offsetHeight）
         * - array：可混合數字/selector（支援 JSON array 或逗號分隔）
         * @returns {Array<number | string>} 解析後的 offset 組合（數字代表 px；字串代表 selector）
         */
        parseScrollOffsets() {
            const raw = (this.form.dataset.scrollOffset || '').trim();
            if (!raw) return [];

            const normalizeItem = (item) => {
                if (item == null) return null;
                if (typeof item === 'number' && Number.isFinite(item)) return item;
                const str = String(item).trim();
                if (!str) return null;
                const num = Number(str);
                if (!Number.isNaN(num) && Number.isFinite(num)) return num;
                return str;
            };

            if (raw.startsWith('[')) {
                try {
                    const parsed = JSON.parse(raw);
                    if (Array.isArray(parsed)) {
                        return parsed.map(normalizeItem).filter((v) => v != null);
                    }
                } catch {
                    // ignore
                }
            }

            if (raw.includes(',')) {
                return raw
                    .split(',')
                    .map((v) => normalizeItem(v))
                    .filter((v) => v != null);
            }

            const single = normalizeItem(raw);
            return single == null ? [] : [single];
        }

        /**
         * 取得 header offset
         * @description 僅在 header 為 fixed 或 sticky 且 top 為 0 時列入
         * @returns {number} header 高度（px）
         */
        getHeaderOffset() {
            const header = document.querySelector('header');
            if (!(header instanceof HTMLElement)) return 0;

            const style = window.getComputedStyle(header);
            const position = style.position;
            const top = parseFloat(style.top || '');

            const isFixed = position === 'fixed';
            const isStickyTop = position === 'sticky' && Number.isFinite(top) && top === 0;

            if (!isFixed && !isStickyTop) return 0;
            return header.getBoundingClientRect().height || header.offsetHeight || 0;
        }

        /**
         * 計算 form 的 data-scroll-offset 總和
         * @returns {number} offset 總和（px）
         */
        getFormScrollOffset() {
            const offsets = this.parseScrollOffsets();
            if (!offsets.length) return 0;

            return offsets.reduce((sum, item) => {
                if (typeof item === 'number') return sum + item;
                const el = document.querySelector(item);
                if (el instanceof HTMLElement) return sum + (el.getBoundingClientRect().height || el.offsetHeight || 0);
                return sum;
            }, 0);
        }

        /**
         * 捲動到第一個 invalid 的 input / select
         * @description
         * - 需在 form 上設定 data-invalid-scrolling 才會啟用
         * - 會優先捲動到 wrapper（.form-input-group/.form-check/.password-input-wrapper）
         * - offset 會綜合 header offset 與 form data-scroll-offset
         * @returns {void}
         */
        scrollToFirstInvalidField() {
            if (!this.isInvalidScrollingEnabled()) return;

            const invalidEl = this.form.querySelector('input:invalid, select:invalid, textarea:invalid');
            if (!(invalidEl instanceof HTMLElement)) return;

            const target = invalidEl.closest('.form-input-group, .form-check, .password-input-wrapper') || invalidEl;
            if (!(target instanceof HTMLElement)) return;

            const headerOffset = this.getHeaderOffset();
            const formOffset = this.getFormScrollOffset();
            const totalOffset = headerOffset + formOffset;

            const rect = target.getBoundingClientRect();
            const top = rect.top + window.pageYOffset - totalOffset;

            window.scrollTo({
                top: Math.max(0, top),
                behavior: 'smooth'
            });
        }

        /**
         * 快取頁面上預設的錯誤文案
         * 避免 resetErrorMessages 將「原本就存在的提示文字」清空
         */
        cacheOriginFeedbackText() {
            const errorTextEls = this.form.querySelectorAll(FormValidator.SELECTORS.errorText);
            errorTextEls.forEach((errorTextEl) => {
                if (errorTextEl.hasAttribute('data-valid-origin-feedback')) return;
                const originText = (errorTextEl.textContent || '').trim();
                if (originText) {
                    errorTextEl.setAttribute('data-valid-origin-feedback', originText);
                }
            });
        }

        /**
         * 重置所有錯誤訊息
         * @description 依 data-valid-origin-feedback 還原或清空
         * @returns {void}
         */
        resetErrorMessages() {
            const errorTextEls = this.form.querySelectorAll(FormValidator.SELECTORS.errorText);
            errorTextEls.forEach((errorTextEl) => {
                const originFeedback = errorTextEl.getAttribute('data-valid-origin-feedback');
                errorTextEl.textContent = originFeedback || '';
            });
        }

        /**
         * 執行表單的所有驗證流程
         * - 先重置錯誤訊息（依 data-valid-origin-feedback 還原或清空）
         * - 依序執行原生驗證、checkbox/radio 驗證、客製化驗證與 wrapper 狀態更新
         */
        async runAllValidations() {
            const runId = ++this._validationRunId;
            this.resetErrorMessages();
            this.handleNativeValidation();
            this.handleSelectValidation();
            this.handleCheckboxValidation();
            await this.handleCustomValidation(runId);
            this.handleWrapperValidation();
        }

        /**
         * 取得錯誤訊息元素
         * @param {HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement} input - 欄位元素
         * @param {boolean} [isSpecialInput=false] - 是否為特殊欄位（checkbox/radio/password wrapper 等）
         * @returns {HTMLElement | null} 錯誤訊息元素
         */
        getErrorElement(input, isSpecialInput = false) {
            const parent = input.closest(FormValidator.SELECTORS.specialWrapper);
            if (isSpecialInput || parent) {
                return (() => {
                    const errorTextEl = parent
                        ?.closest(FormValidator.SELECTORS.formInputGroup)
                        ?.querySelector(FormValidator.SELECTORS.errorText);
                    if (errorTextEl) return errorTextEl || null;
                    else {
                        const nextSibling = parent?.nextElementSibling;
                        if (nextSibling?.matches(FormValidator.SELECTORS.formCheckFeedbackErrorText)) return nextSibling;
                        else
                            return (
                                parent?.parentElement?.querySelector(FormValidator.SELECTORS.formCheckFeedbackErrorText) || null
                            );
                    }
                })();
            }
            return (
                input?.closest(FormValidator.SELECTORS.formInputGroup)?.querySelector(FormValidator.SELECTORS.errorText) || null
            );
        }

        /**
         * 判斷元素的文字內容是否為空
         * @description 供錯誤訊息更新流程共用，避免重複的 textContent/trim 判斷
         * @param {HTMLElement | null | undefined} element - 目標元素
         * @returns {boolean}
         */
        isEmptyTextContent(element) {
            const text = element?.textContent;
            return !text || text.trim() === '';
        }

        /**
         * 更新錯誤訊息
         * @description
         * 僅在錯誤訊息元素原本為空時，才寫入 feedback。
         * 若錯誤訊息元素本來就有文案，則永遠不覆蓋（保留設計稿/頁面原始文案）。
         * @param {HTMLElement | null} errorTextEl - 錯誤訊息容器
         * @param {string} feedback - 欲寫入的錯誤訊息
         * @returns {void}
         */
        updateErrorMessage(errorTextEl, feedback) {
            if (!errorTextEl) return;
            if (!this.isEmptyTextContent(errorTextEl)) return;
            if (!feedback) return;
            errorTextEl.textContent = feedback;
        }

        /**
         * 取得對應錯誤訊息元素並更新錯誤訊息
         * @param {HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement} input - 欄位元素
         * @param {string} feedback - 欲寫入的錯誤訊息
         * @param {boolean} [isSpecialInput=false] - 是否為特殊欄位
         * @returns {void}
         */
        setErrorMessage(input, feedback, isSpecialInput = false) {
            const errorTextEl = this.getErrorElement(input, isSpecialInput);
            this.updateErrorMessage(errorTextEl, feedback);
        }

        /**
         * 設定驗證狀態
         * @description
         * - 負責同步 was-validated、is-invalid、以及 setCustomValidity
         * - isInvalid 為 true 代表「無效狀態」（注意：命名上與 checkValidity 的意義相反）
         * @param {HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement} input - 欄位元素
         * @param {boolean} isInvalid - 是否為無效狀態
         * @param {string} [feedback=''] - 欲寫入的 feedback（會進入 setCustomValidity）
         * @param {HTMLElement | null} [element=null] - 可指定要套用 is-invalid class 的 wrapper 元素
         * @returns {void}
         */
        setValidationState(input, isInvalid, feedback = '', element = null) {
            const targetElement = element || input;

            if (!this.form.classList.contains('was-validated')) {
                this.form.classList.toggle('was-validated', isInvalid);
            }

            if (!targetElement.classList.contains('is-invalid')) {
                targetElement.classList.toggle('is-invalid', !isInvalid);
            }

            if (input.setCustomValidity) {
                input.setCustomValidity(isInvalid ? feedback : '');
            }
        }

        /**
         * 提交前的 loading 狀態處理
         * @description 依 form data-needs-loading 控制：禁用 submit button、切換 data-loading、替換按鈕文字
         * @param {SubmitEvent} event - submit event
         * @returns {SubmitLoadingContext}
         */
        beginSubmitLoading(event) {
            const needsLoading = this.form.dataset.needsLoading === 'true';
            const submitter = event.submitter;
            const submitButton = submitter instanceof HTMLButtonElement ? submitter : null;
            const loadingText = submitButton?.getAttribute('data-loading-text') ?? null;
            const originTextAttrName = 'data-loading-origin-text';

            if (needsLoading) {
                if (submitButton) submitButton.disabled = true;
                this.form.setAttribute('data-loading', 'true');

                if (submitButton && loadingText !== null) {
                    if (!submitButton.hasAttribute(originTextAttrName)) {
                        submitButton.setAttribute(originTextAttrName, submitButton.textContent || '');
                    }

                    submitButton.textContent = loadingText === '...' ? '' : loadingText;
                }
            }

            return {
                needsLoading,
                submitButton,
                loadingText,
                originTextAttrName
            };
        }

        /**
         * 提交結束後恢復 loading 狀態
         * @param {SubmitLoadingContext} context - beginSubmitLoading 回傳的上下文
         * @returns {void}
         */
        endSubmitLoading(context) {
            if (!context?.needsLoading) return;

            const { submitButton, loadingText, originTextAttrName } = context;

            if (submitButton) submitButton.disabled = false;
            this.form.setAttribute('data-loading', 'false');

            if (submitButton && loadingText !== null && submitButton.hasAttribute(originTextAttrName)) {
                submitButton.textContent = submitButton.getAttribute(originTextAttrName) || '';
                submitButton.removeAttribute(originTextAttrName);
            }
        }

        /**
         * 取得表單資料
         * @description 將 form.elements 收斂成 controls（key 為 id 或 name）
         * @param {SubmitEvent} event - submit event
         * @returns {FormValidatorFormData}
         */
        getFormData(event) {
            const submitter = event.submitter || null;
            const inputs = {};
            Array.from(this.form.elements)
                .filter(
                    (el) => el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement
                )
                .forEach((el) => {
                    inputs[el.id || el.name] = el;
                });
            return {
                form: this.form,
                controls: inputs,
                submitter
            };
        }

        /**
         * 觸發 form:validated 自訂事件
         * @param {SubmitEvent} event - submit event
         * @returns {void}
         */
        emitValidatedEvent(event) {
            this.form.dispatchEvent(
                new CustomEvent('form:validated', {
                    detail: this.getFormData(event)
                })
            );
        }

        /**
         * 通用驗證處理器
         * @description
         * - 統一走 setValidationState
         * - 若無效則寫入錯誤訊息（遵守不覆蓋既有文案的策略）
         * @param {HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement} input - 欄位元素
         * @param {boolean} isInvalid - 是否無效
         * @param {string} feedback - 錯誤訊息
         * @param {HTMLElement | null} [element=null] - 可指定 wrapper
         * @returns {void}
         */
        handleValidation(input, isInvalid, feedback, element = null) {
            this.setValidationState(input, isInvalid, feedback, element);

            if (isInvalid) {
                this.setErrorMessage(input, feedback, !!element);
            }
        }

        /**
         * 手動觸發驗證（不依賴表單提交）
         * 用於在表單未提交時手動觸發驗證顯示
         * @param input - 要驗證的表單元素
         * @param isInvalid - 是否為無效狀態
         * @param feedback - 驗證反饋訊息
         * @param element - 可選的附加元素（如自定義錯誤訊息容器）
         */
        triggerValidation(input, isInvalid, feedback, element = null) {
            if (!this.form.classList.contains('was-validated')) {
                this.form.classList.add('was-validated');
            }
            this.handleValidation(input, isInvalid, feedback, element);
            this.handleWrapperValidation();
        }

        /**
         * 提供表單 helper 給 onValidSubmit 使用
         * @returns {FormValidatorHelpers}
         */
        getFormHelpers() {
            return {
                triggerValidation: this.triggerValidation.bind(this),
                form: this.form,
                validator: this
            };
        }

        /**
         * 處理原生 HTML5 驗證
         * @description
         * - 針對未設定 data-valid 的 required input
         * - 依序檢查 required/email/minLength/maxLength/min/max/pattern
         * @returns {void}
         */
        handleNativeValidation() {
            const nativeInputs = this.form.querySelectorAll(FormValidator.SELECTORS.nativeInputs);
            const rules = this.getValidationRules();

            nativeInputs.forEach((input) => {
                if (!(input instanceof HTMLInputElement) && !(input instanceof HTMLTextAreaElement)) return;
                const value = input.value;

                const validationOrder = [
                    {
                        condition: () => !value,
                        getDefaultMessage: () => rules.required.getDefaultMessage()
                    },
                    {
                        condition: () => value && input.type === 'email' && !/^\S+@\S+\.\S+$/.test(value),
                        getDefaultMessage: () => rules.email.getDefaultMessage(input)
                    },
                    {
                        condition: () => value && input.minLength > 0 && value.length < parseInt(String(input.minLength)),
                        getDefaultMessage: () => rules.minLength.getDefaultMessage(input)
                    },
                    {
                        condition: () => value && input.maxLength > 0 && value.length > parseInt(String(input.maxLength)),
                        getDefaultMessage: () => rules.maxLength.getDefaultMessage(input)
                    },
                    {
                        condition: () => value && input.min && parseFloat(value) < parseFloat(String(input.min)),
                        getDefaultMessage: () => rules.min.getDefaultMessage(input)
                    },
                    {
                        condition: () => value && input.max && parseFloat(value) > parseFloat(String(input.max)),
                        getDefaultMessage: () => rules.max.getDefaultMessage(input)
                    },
                    {
                        condition: () => value && input.pattern && !new RegExp(input.pattern).test(value),
                        getDefaultMessage: () => rules.pattern.getDefaultMessage()
                    }
                ];

                for (let i = 0; i < validationOrder.length; i++) {
                    const validation = validationOrder[i];
                    if (validation.condition()) {
                        const feedback = validation.getDefaultMessage();
                        this.handleValidation(input, true, feedback, null);
                        return;
                    }
                }

                this.handleValidation(input, false, '');
            });
        }

        /**
         * 處理 select 的 required 驗證
         * @returns {void}
         */
        handleSelectValidation() {
            const selects = this.form.querySelectorAll(FormValidator.SELECTORS.nativeSelects);

            selects.forEach((select) => {
                if (!(select instanceof HTMLSelectElement)) return;
                const value = select.value;
                const isInvalid = !value;
                const { validFeedback: feedback = '' } = select.dataset;

                this.handleValidation(select, isInvalid, feedback || this.messages.required);
            });
        }

        /**
         * 處理 async 驗證
         * @description
         * - 透過 input data-target 對應 options.asyncValidators 的 key
         * - 透過 runId 防止舊請求覆蓋新狀態
         * - 可選擇在 async 期間 disable input（由 data-loading 控制）
         * @param {HTMLInputElement | HTMLSelectElement} input - 欄位元素
         * @param {string[]} valids - data-valid 拆分後的驗證清單
         * @param {string[]} feedbacks - data-valid-feedback 拆分後的錯誤訊息清單
         * @param {number} runId - 本次驗證 runId
         * @returns {Promise<void>}
         */
        async handleAsyncValidation(input, valids, feedbacks, runId) {
            const asyncIndex = valids.indexOf('async');
            const asyncFeedback = feedbacks[asyncIndex] || this.messages.pattern;
            const targetKey = input.dataset.target;
            const asyncMap = this.options?.asyncValidators;
            const asyncFn = targetKey ? asyncMap?.[targetKey] : null;

            const shouldDisableInput = input.getAttribute('data-loading') !== 'false';
            const originDisabled = input.disabled;
            const originLoadingAttr = input.getAttribute('data-loading');

            if (typeof asyncFn !== 'function') {
                // eslint-disable-next-line no-console
                console.warn('FormValidator: 找不到 async validation function', { input, targetKey });
                return;
            }

            input.setAttribute('data-async-run-id', String(runId));
            input.setAttribute('data-loading', 'true');
            if (shouldDisableInput) input.disabled = true;

            try {
                const result = await asyncFn(input);

                if (runId !== this._validationRunId) return;

                const isValid = (() => {
                    if (typeof result === 'boolean') return result;
                    if (result && typeof result === 'object') {
                        if (typeof result.isValid === 'boolean') return result.isValid;
                        if (typeof result.valid === 'boolean') return result.valid;
                        if (typeof result.ok === 'boolean') return result.ok;
                    }
                    return false;
                })();

                const customFeedback =
                    result && typeof result === 'object' && typeof result.feedback === 'string' ? result.feedback : '';

                this.handleValidation(input, !isValid, customFeedback || asyncFeedback);
            } finally {
                if (input.getAttribute('data-async-run-id') !== String(runId)) return;
                input.removeAttribute('data-async-run-id');

                if (originLoadingAttr === null) input.removeAttribute('data-loading');
                else input.setAttribute('data-loading', originLoadingAttr);

                if (shouldDisableInput) input.disabled = originDisabled;
            }
        }

        /**
         * 處理包裝容器的驗證狀態
         * @description 針對 .form-check 和 .password-input-wrapper 底下的 input，同步 wrapper 的 is-invalid
         * @returns {void}
         */
        handleWrapperValidation() {
            const wrapperInputs = this.form.querySelectorAll(FormValidator.SELECTORS.wrapperInputs);
            wrapperInputs.forEach((input) => {
                if (!(input instanceof HTMLInputElement)) return;
                const isInvalid = !input.checkValidity();

                const wrapper = input.closest('.form-check, .password-input-wrapper');
                if (wrapper) {
                    wrapper.classList.toggle('is-invalid', isInvalid);
                }
            });
        }

        /**
         * 處理複選框驗證
         * @returns {void}
         */
        handleCheckboxValidation() {
            const checkboxInputs = this.form.querySelectorAll(FormValidator.SELECTORS.checkboxRequired);
            checkboxInputs.forEach((input) => {
                if (!(input instanceof HTMLInputElement)) return;
                const { validFeedback: feedback = '' } = input.dataset;
                const isInvalid = !input.checkValidity();

                if (isInvalid) {
                    const errorTextEl = this.getErrorElement(input, true);
                    const mergedFeedback = (errorTextEl?.textContent || '').trim() || feedback || this.messages.required;
                    this.setErrorMessage(input, mergedFeedback, true);
                }
            });
        }

        /**
         * 驗證規則配置
         * @description 回傳各種 validate/getDefaultMessage 的集合，供原生/客製驗證共用
         * @returns {Record<string, {validate: Function, getDefaultMessage: Function}>}
         */
        getValidationRules() {
            return {
                required: {
                    validate: (value) => !value,
                    getDefaultMessage: () => this.messages.required
                },
                pattern: {
                    validate: (value, input) => value && !!input.pattern && !new RegExp(input.pattern).test(value),
                    getDefaultMessage: () => this.messages.pattern
                },
                tel: {
                    validate: (value) => value && !/^09\d{8}$/.test(value),
                    getDefaultMessage: () => this.messages.tel
                },
                phone: {
                    validate: (value) => value && !/^09\d{8}$/.test(value),
                    getDefaultMessage: () => this.messages.phone
                },
                email: {
                    validate: (value) => value && !/^\S+@\S+\.\S+$/.test(value),
                    getDefaultMessage: (input) =>
                        typeof this.messages.email === 'function' ? this.messages.email(input.value) : this.messages.email
                },
                minLength: {
                    validate: (value, input) => value && value.length < parseInt(String(input.minLength)),
                    getDefaultMessage: (input) =>
                        typeof this.messages.minLength === 'function'
                            ? this.messages.minLength(input.minLength, input.value.length)
                            : this.messages.minLength
                },
                maxLength: {
                    validate: (value, input) => value && value.length > parseInt(String(input.maxLength)),
                    getDefaultMessage: (input) =>
                        typeof this.messages.maxLength === 'function'
                            ? this.messages.maxLength(input.maxLength, input.value.length)
                            : this.messages.maxLength
                },
                min: {
                    validate: (value, input) => value && parseFloat(value) < parseFloat(String(input.min)),
                    getDefaultMessage: (input) =>
                        typeof this.messages.min === 'function' ? this.messages.min(input.min) : this.messages.min
                },
                max: {
                    validate: (value, input) => value && parseFloat(value) > parseFloat(String(input.max)),
                    getDefaultMessage: (input) =>
                        typeof this.messages.max === 'function' ? this.messages.max(input.max) : this.messages.max
                },
                regex: {
                    validate: (value, input) => {
                        const regex = new RegExp(input.dataset.validRegex || '');
                        return value && !regex.test(value);
                    },
                    getDefaultMessage: () => this.messages.regex
                },
                confirm: {
                    validate: (value, input) => {
                        const target = input.dataset.target;
                        if (!target) return false;
                        const targetInput = document.querySelector(target);
                        const targetValue = targetInput?.value || '';
                        return value && targetValue !== value;
                    },
                    getDefaultMessage: () => this.messages.passwordConfirm
                }
            };
        }

        /**
         * 處理客製化驗證
         * @description
         * - 針對 data-valid 的 input/select
         * - 支援 required/pattern/tel/phone/email/minLength/maxLength/min/max/regex/confirm/async
         * @param {number} runId - 本次驗證 runId（提供 async 驗證使用）
         * @returns {Promise<void>}
         */
        async handleCustomValidation(runId) {
            const validInputs = this.form.querySelectorAll(FormValidator.SELECTORS.validInputs);
            const rules = this.getValidationRules();

            for (const inputEl of validInputs) {
                const input = inputEl;
                const { valid = '', validFeedback = '' } = input.dataset;
                const valids = valid.split(',');
                const feedbacks = validFeedback.split(',');
                const value = input.value;

                if (valids.includes('required') || input.required) {
                    const validIndex = valids.indexOf('required');
                    const rule = rules.required;
                    const isInvalid = rule.validate(value);
                    const feedback = feedbacks[validIndex] || rule.getDefaultMessage();

                    this.handleValidation(input, isInvalid, feedback);
                    if (isInvalid) continue;
                }

                if (!value && !valids.includes('confirm')) continue;

                for (const validType of valids) {
                    if (validType === 'required') continue;

                    if (validType === 'async') {
                        if (!(input instanceof HTMLInputElement) && !(input instanceof HTMLSelectElement)) continue;
                        if (!input.checkValidity() && !input.validity.valueMissing) continue;
                        await this.handleAsyncValidation(input, valids, feedbacks, runId);
                        if (!input.checkValidity()) break;
                        continue;
                    }

                    const rule = rules[validType];
                    if (!rule) continue;

                    const validIndex = valids.indexOf(validType);
                    const isInvalid = rule.validate(value, input);
                    const feedback = feedbacks[validIndex] || rule.getDefaultMessage(input);

                    if (validType === 'confirm') {
                        const parent = input.closest('.password-input-wrapper');
                        this.handleValidation(input, isInvalid, feedback, parent);
                    } else {
                        this.handleValidation(input, isInvalid, feedback);
                    }

                    if (isInvalid) {
                        break;
                    }
                }
            }
        }

        /**
         * 設置事件監聽器
         * @description
         * - submit：執行 runAllValidations + checkValidity
         * - reset：清除 was-validated / is-invalid / customValidity / error text
         * - live validate：當表單無效時，change 會立即觸發重新驗證
         * @returns {void}
         */
        setupEventListeners() {
            this.form.addEventListener('submit', async (event) => {
                const submitEvent = event;

                // if (this._isProgrammaticSubmit) {
                //     this._isProgrammaticSubmit = false;
                //     return;
                // }

                if (this._isSubmitting) {
                    event.preventDefault();
                    event.stopPropagation();
                    return;
                }

                this._isSubmitting = true;
                const loadingContext = this.beginSubmitLoading(submitEvent);

                event.preventDefault();
                event.stopPropagation();

                try {
                    await this.runAllValidations();

                    if (!this.form.checkValidity()) {
                        this.form.classList.add('was-validated');

                        if (this.options.reportValidity) {
                            this.form.reportValidity();
                        }

                        // 等待 DOM 更新（例如 is-invalid class、error text）後再捲動
                        setTimeout(() => {
                            this.scrollToFirstInvalidField();
                        }, 0);

                        return;
                    }

                    const { onValidSubmit } = this.options;
                    if (typeof onValidSubmit === 'function') {
                        const formData = this.getFormData(submitEvent);
                        const helpers = this.getFormHelpers();
                        await onValidSubmit(formData, helpers);
                        return;
                    }

                    this.emitValidatedEvent(submitEvent);

                    if (this.form.hasAttribute('action')) {
                        this.form.submit();
                        return;
                    }

                    // this._isProgrammaticSubmit = true;
                } finally {
                    this._isSubmitting = false;
                    this.endSubmitLoading(loadingContext);
                }
            });

            this.form.addEventListener('reset', () => {
                setTimeout(() => {
                    this.form.classList.remove('was-validated');

                    const invalidEls = this.form.querySelectorAll('.is-invalid');
                    invalidEls.forEach((el) => el.classList.remove('is-invalid'));

                    const inputs = Array.from(this.form.elements).filter(
                        (el) =>
                            el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement
                    );
                    inputs.forEach((el) => {
                        if (typeof el.setCustomValidity === 'function') {
                            el.setCustomValidity('');
                        }
                    });

                    this.resetErrorMessages();
                    // this.handleWrapperValidation();
                }, 0);
            });

            if (this.isLiveValidateEnabled()) {
                const handleLiveValidate = async (event) => {
                    const target = event.target;
                    if (!(target instanceof HTMLInputElement || target instanceof HTMLSelectElement || target instanceof HTMLTextAreaElement))
                        return;
                    if (this.form.checkValidity()) return;

                    await this.runAllValidations();
                };

                // this.form.addEventListener('input', handleLiveValidate);
                this.form.addEventListener('change', handleLiveValidate);
            }
        }
    }

    /**
     * 初始化頁面上所有需要驗證的表單
     * @description
     * 會搜尋符合 `FormValidator.SELECTORS.form` 的所有表單，並為每個表單建立一個 `FormValidator`。
     * @param {FormValidatorOptions} [options={}] - FormValidator 建構選項（例如 asyncValidators、onValidSubmit）
     * @returns {FormValidator[]} 表單驗證器實例清單
     */
    const useFormValidator = (options = {}) => {
        const forms = document.querySelectorAll(FormValidator.SELECTORS.form);
        return Array.from(forms).map((form) => new FormValidator(form, options));
    };
</script>

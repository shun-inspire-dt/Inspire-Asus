---
/** Style */
import './follower.scss';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
}

const { IDName = 'Follower', className, style, attribute = {} } = Astro.props as Props;
---

<div id={IDName} class:list={[className, 'Follower']} style={style} {...attribute}>
</div>

---
/** Common Component */
import Collapse from './collapse.astro';
import Checkbox from '@components/common/form/checkboxs/checkbox.astro';

/** Props */
export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    title?: string;
    show?: boolean;
    data?: filter;
}

const { IDName, className, style, attribute = {}, title, show, data = [] } = Astro.props as Props;
const componentId = IDName || `filter-${Math.random().toString(36).substr(2, 9)}`;
const inputId = `filter-input-${Math.random().toString(36).substr(2, 9)}`;
---

<Collapse IDName={componentId} className={className} style={style} attribute={attribute} title={title} show={show}>
    <div class=":uno-filter-content: flex flex-col gap-0.75rem [&>.form-check]:w-full">
            {data?.map((item, index) => (
                <Checkbox
                    id={`${inputId}-${index}`}
                    label={item.label}
                    value={item.value}
                    checked={item.checked}
                />
            ))}
        </div>
</Collapse>

---
/** Common Components */
/** Modal */
import Modal from '@components/common/modal/modal.astro';
/** InputGroup */
import InputGroup from '@components/common/form/group/inputGroup.astro';
/** Input */
import Input from '@components/common/form/input/input.astro';
export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
}

const { IDName = 'ResetEmail', className, style, attribute = {} } = Astro.props as Props;
---

<Modal
    id={IDName}
    title="變更信箱"
    Modalclass={className}
    cancelVariant="blue-outline"
    cancelTitle="取消"
    okVariant="blue"
    okTitle="確認寄出"
    okAttribute={{ type: 'submit' }}
    sizes="xl"
    center
    ContentTag="form"
    contentAttribute={{
        action: '',
        id: `${IDName}Form`,
        'data-report-validity': 'false',
        'data-needs-loading': 'true',
        novalidate: true
    }}
    contentClass="needs-validation"
    hideColse={true}
    attribute={attribute}
    backdrop="static"
>
    請至原本的信箱收取驗證碼，驗證成功後才能變更信箱
    <InputGroup inputID="email" label="請輸入電子郵件" block>
        <Input
            id="email"
            type="email"
            inputmode="email"
            autocomplete="email"
            attribute={{
                'data-valid': 'async',
                'data-target': 'updateEmail'
            }}
            required
        />
    </InputGroup>
</Modal>

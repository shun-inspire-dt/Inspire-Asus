---
/**
 * Header Mobile Offcanvas Component
 * 網站頭部手機版側邊選單組件
 *
 * 功能說明：
 * - 提供手機版的側邊滑出導航選單
 * - 支援多層級選單結構（最多三層）
 * - 使用 Bootstrap Collapse 實現子選單展開/收合
 * - 整合觸發按鈕和選單內容
 * - 響應式設計，僅在小螢幕顯示
 * - 自動處理選單項目的點擊關閉邏輯
 */

/** Type Definitions - 型別定義 */
import type { NavsData } from '@js/data/navs';

/** Common Components - 通用組件 */
/** Offcanvas Base Component - Offcanvas 基礎組件 */
import MyOffcanvas from '@components/common/offcanvas/offcanvas.astro';
/** Link Component - 連結組件 */
/** Link */
import ALink from '@components/common/link/link.astro';
import A from '@components/common/link/a.astro';
/** Collapse Component - 折疊組件 */
import Collapse from '@components/common/collapse/collapse.astro';
/** Styles - 樣式檔案 */
import './offcanvas.scss';

/**
 * Component Props Interface
 * 組件屬性介面定義
 *
 * @property {string} [IDName] - 組件 ID 名稱，預設為 'headerOffcanvasContainer'
 * @property {any} [className] - 自定義 CSS 類別
 * @property {NavsData} [data] - 導航資料陣列
 * @property {attribute} [attribute] - HTML 屬性物件
 * @property {{[key: string]: string}} [style] - 內聯樣式物件
 */
export interface Props {
    IDName?: string;
    className?: any;
    data?: NavsData;
    attribute?: attribute;
    style?: { [key: string]: string };
}

/**
 * Props Destructuring with Default Values
 * 屬性解構並設定預設值
 */
const { IDName = 'header', className, style, attribute = {}, data = [] } = Astro.props as Props;
---

{/** Offcanvas Container - 側邊選單容器 */}
{/* 側邊選單主體：從右側滑出 */}
<MyOffcanvas IDName={IDName} postion="end" hideHeader className={className} attribute={attribute} style={style}>
    {
        data.map((x) => (
            <Fragment>
                {Boolean(x.children && x.children.length > 0) ? (
                    <Collapse title={x.title} parent={IDName ? `#${IDName}Offcanvas` : undefined} buttonClassName=":uno-header-offcanvas-collapse-button: font-normal">
                        <div class=":uno-header-offcanvas-link-container: py-1rem bg-neutral-100">
                            <div class=":uno-header-offcanvas-link-content: container-fluid flex items-stretch gap-2rem">
                                {x.children
                                    ?.flatMap((y) => y.children)
                                    .map((y) => (
                                        <div class="menu-links">
                                            <span class="menu-link-title">{y?.title}</span>
                                            <div class="menu-link-list">
                                                {y?.links.map((z) => (
                                                    <div class="menu-link-ul">
                                                        {z?.map((u) => (
                                                            <A link={u.link} title={u.linkText} />
                                                        ))}
                                                    </div>
                                                ))}
                                            </div>
                                        </div>
                                    ))}
                            </div>
                            {x.children?.[0].link && (
                                <div class=":uno-header-offcanvas-main-link: container-fluid pt-2rem pb-0.75rem">
                                    <ALink link={x.children?.[0].link} title={x.children?.[0].linkText} showArrow />
                                </div>
                            )}
                        </div>
                    </Collapse>
                ) : (
                    <A
                        link={x.link}
                        className=":uno-header-offcanvas-link: container-fluid flex items-center py-0.75rem text-gray-900 font-tt-normal text-base lh-125 font-normal"
                        title={x.title}
                    />
                )}
            </Fragment>
        ))
    }
</MyOffcanvas>

---
/**
 * Header Navigation Component
 * 網站頭部主導航列表組件
 *
 * 功能說明：
 * - 渲染網站主要導航選單
 * - 支援多層級選單結構（透過 MegaMenu 組件）
 * - 支援兩種下拉選單模式：dropdown 和 megaMenu
 * - 響應式設計，在桌面版顯示水平導航
 */

/** Type Definitions - 型別定義 */
import type { NavsData } from '@js/data/navs';

/** Common Components - 通用組件 */
import MegaMenu from './megaMenu.astro';

/** Link Component - 連結組件 */
import ALink from '@components/common/link/a.astro';

/** Icons Component - 圖示組件 */
import Icons from '@components/common/icons/icons.astro';

/** Main Components - 主要組件 */
import Logo from './logo.astro';

/** Styles - 樣式檔案 */
import './nav.scss';

/**
 * Component Props Interface
 * 組件屬性介面定義
 *
 * @property {string} [IDName] - 組件 ID 名稱，預設為 'headerNav'
 * @property {any} [className] - 自定義 CSS 類別
 * @property {NavsData} [data] - 導航資料陣列
 * @property {attribute} [attribute] - HTML 屬性物件
 * @property {{[key: string]: string}} [style] - 內聯樣式物件
 * @property {'megaMenu' | 'dropdown'} [type] - 下拉選單類型：'megaMenu' 為大型選單，'dropdown' 為一般下拉選單
 */
export interface Props {
    IDName?: string;
    className?: any;
    data?: NavsData;
    attribute?: attribute;
    style?: { [key: string]: string };
    type?: 'megaMenu' | 'dropdown';
}

/**
 * Props Destructuring with Default Values
 * 屬性解構並設定預設值
 */
const { IDName = 'headerNav', className, style, attribute = {}, data = [], type = 'dropdown' } = Astro.props as Props;
---

<!-- Navigation Container - 導航容器 -->
<div id={IDName} class:list={[className]} style={style} {...attribute}>
    <nav>
        {
            /**
             * 遍歷導航資料陣列，渲染每個導航項目
             * 如果有子選單，添加 mega menu trigger 屬性
             * */
            data.map((x, i) => (
                <div
                    class="headerNavItem"
                    {...(x.hasOwnProperty('children') ? { 'data-mega-menu-trigger': '', 'data-mega-menu-type': type } : {})}
                >
                    {/* 主導航連結 - 包含主標題和副標題 */}
                    {x.hasOwnProperty('children') ? (
                        <div class="headerNavLink" role="button" tabindex="0">
                            <p>{x.title}</p>
                            {x.subTitle && <span>{x.subTitle}</span>}
                        </div>
                    ) : (
                        <ALink link={x.link} className="headerNavLink" attribute={{ tabindex: '0', role: 'link' }}>
                            <p>{x.title}</p>
                            {x.subTitle && <span>{x.subTitle}</span>}
                        </ALink>
                    )}

                    {/* 如果有子選單，渲染 MegaMenu 組件 */}
                    {x.hasOwnProperty('children') && (
                        <MegaMenu
                            position="center"
                            type={type}
                            attribute={{
                                /* 第一個選單項目添加特殊標記 */
                                'data-first': i === 0 ? '' : undefined
                            }}
                            data={x.children}
                        />
                    )}
                </div>
            ))
        }
    </nav>
</div>

<script>
    const headerNavRoot = document.getElementById("headerNav") as HTMLElement;

    if (headerNavRoot) {
        let openItem: HTMLElement | null = null;
        let openItemOpenedByKeyboard = false;
        let openItemMouseEntered = false;

        const closeAll = () => {
            headerNavRoot
                .querySelectorAll('[data-mega-menu-trigger][data-mega-menu-open]')
                .forEach((el) => el.removeAttribute('data-mega-menu-open'));

            openItem = null;
            openItemOpenedByKeyboard = false;
            openItemMouseEntered = false;
        };

        const setOpen = (item: HTMLElement, byKeyboard: boolean) => {
            closeAll();
            item.setAttribute('data-mega-menu-open', '');
            openItem = item;
            openItemOpenedByKeyboard = Boolean(byKeyboard);
            openItemMouseEntered = false;
        };

        const getItemFromTarget = (target: EventTarget | null): HTMLElement | null => {
            if (!(target instanceof Element)) return null;
            return target.closest('.headerNavItem[data-mega-menu-trigger]') as HTMLElement | null;
        };

        headerNavRoot.addEventListener('keydown', (event: KeyboardEvent) => {
            if (!(event instanceof KeyboardEvent)) return;

            const item = getItemFromTarget(event.target);
            if (!item) return;

            const link = item.querySelector(':scope > .headerNavLink');
            if (!link) return;

            if (event.key === 'Escape') {
                item.removeAttribute('data-mega-menu-open');
                if (openItem === item) closeAll();
                return;
            }

            if (event.key !== 'Enter' && event.key !== ' ') return;
            if (!link.matches(':focus-visible')) return;

            event.preventDefault();
            event.stopPropagation();

            const isOpen = item.hasAttribute('data-mega-menu-open');
            if (isOpen) {
                closeAll();
                return;
            }

            setOpen(item, true);
        });

        headerNavRoot.addEventListener('focusin', (event: FocusEvent) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            if (!openItem) return;
            if (openItem.contains(target)) return;
            closeAll();
        });

        headerNavRoot.addEventListener('mouseover', (event: MouseEvent) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const item = target.closest('.headerNavItem[data-mega-menu-trigger]') as HTMLElement | null;
            if (!item) return;

            if (openItem && item !== openItem) {
                closeAll();
                return;
            }

            if (openItem && item === openItem && openItemOpenedByKeyboard) {
                openItemMouseEntered = true;
            }
        });

        headerNavRoot.addEventListener('mouseout', (event: MouseEvent) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const item = target.closest('.headerNavItem[data-mega-menu-trigger]') as HTMLElement | null;
            if (!item) return;
            if (!openItem || item !== openItem) return;
            if (!openItemOpenedByKeyboard || !openItemMouseEntered) return;

            const related = event.relatedTarget;
            if (related instanceof Node && item.contains(related)) return;

            closeAll();
        });

        document.addEventListener('pointerdown', (event: PointerEvent) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            if (headerNavRoot.contains(target)) return;
            closeAll();
        });

        document.addEventListener('focusin', (event: FocusEvent) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            if (headerNavRoot.contains(target)) return;
            closeAll();
        });
    }
</script>

---
/** Common Component */
import MyRelative from '@components/common/article/relative.astro';
import Card from '@components/pages/solutions/card.astro';
/** Style */
import './relative.scss';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    title?: string;
}

const { IDName = 'IvyRelative', className, style, attribute = {}, title = '相關方案' } = Astro.props as Props;
---

<MyRelative
    title={title}
    className={[':uno-ivy-section-relative: bg-[linear-gradient(104.68deg,#F5F5F5_0%,#ECF5FF_100%)]', className]}
    IDName={IDName}
    style={style}
    attribute={attribute}
    count={12}
>
    <Card link="/ivy/0" showPlayBack={false} />
</MyRelative>

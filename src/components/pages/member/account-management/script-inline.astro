<script is:inline define:vars={{ baseURL: import.meta.env.API_BASE_URL }}>
    /**
     * 帳號管理 - 信箱變更流程管理類別
     * @description 管理信箱變更的多步驟流程，包含驗證碼發送、確認和重設
     * @author ASUS Team
     * @version 1.0.0
     */
    const authClient = new AuthClient({ baseURL, cookies });
    const Fetch = authClient.fetchWithAuth.bind(authClient);
    /** ---------- 實作 ---------- */
    // 全局 Toast 實例
    const toastEl = document.getElementById('toastModal');

    /**
     * API 請求封裝
     * @description 統一處理此頁面「帳號管理／信箱變更」流程所需的 API 呼叫與 headers 設定
     */
    class API {
        headers = new Headers({
            'Content-Type': 'application/json',
            Authorization: `Bearer ${authClient.cookies.get('access_token')}`
        });

        /**
         * 取得帳號
         * @returns {Promise<string>} 目前帳號字串（失敗則回傳空字串）
         */
        getAccountApi = async () => {
            const requestOptions = {
                method: 'GET',
                headers: this.headers
            };

            return await Fetch(baseURL + '/api/form/account', requestOptions)
                .then((response) => response.json())
                .then((result) => (result.success ? result.account : ''))
                .catch((error) => {
                    console.error('Send code error:', error);
                    return '';
                });
        };

        /**
         * 更新帳號
         * @param {string} account - 新帳號（Email）
         * @returns {Promise<Response | {success: boolean, message?: string}>} API 回應
         */
        updateAccountApi = async (account) => {
            const raw = JSON.stringify({ account });

            const requestOptions = {
                method: 'POST',
                headers: this.headers,
                body: raw
            };

            return await Fetch(baseURL + '/api/form/update-account', requestOptions)
                .then((response) => response.json())
                .then((result) => result)
                .catch((error) => {
                    console.error('Send code error:', error);
                    return { success: false, message: '信箱更新失敗' };
                });
        };

        /**
         * 發送驗證碼
         * @param {string} email - 目標 Email
         * @returns {Promise<Response | {success: boolean, message?: string}>} API 回應
         */
        sendCodeApi = async (email) => {
            const raw = JSON.stringify({ email });

            const requestOptions = {
                method: 'POST',
                headers: this.headers,
                body: raw
            };

            return await Fetch(baseURL + '/api/form/sendCode', requestOptions)
                .then((response) => response.json())
                .then((result) => result)
                .catch((error) => {
                    console.error('Send code error:', error);
                    return { success: false, message: '碼驗證發送失敗' };
                });
        };

        /**
         * 驗證驗證碼
         * @param {string} code - 使用者輸入的驗證碼
         * @returns {Promise<Response | {success: boolean, message?: string}>} API 回應
         */
        checkCodeApi = async (code) => {
            const raw = JSON.stringify({ code });

            const requestOptions = {
                method: 'POST',
                headers: this.headers,
                body: raw
            };

            return await Fetch(baseURL + '/api/form/checkCode', requestOptions)
                .then((response) => response.json())
                .then((result) => result)
                .catch((error) => {
                    console.error('Check code error:', error);
                    return { success: false, message: '驗證碼驗證失敗' };
                });
        };
    }

    /**
     * 驗證碼 Modal 流程管理
     * @description 管理驗證碼發送/重送倒數/驗證與顯示資訊
     */
    class ComfirmCodeManager extends API {
        /** DOM 元素 */
        codeModalEl = document.querySelector('#ComfirmCodeModal');
        codeForm = document.querySelector('#ComfirmCodeModal #ComfirmCodeForm');
        verifyEmailEl = document.querySelector('#ComfirmCodeModal #verifyEmail');
        resendCodeBtn = document.querySelector('#ComfirmCodeModal #resendCodeBtn');
        resendCountdown = document.querySelector('#ComfirmCodeModal #resendCountdown');
        codeInput = document.querySelector('#ComfirmCodeForm #loginVerifyCode');
        infoTextEl = document.querySelector('#ComfirmCodeForm #loginVerifyCode + .info-text');
        /** 倒數 */
        resendCountdownTimer;
        resendCountdownSeconds = 0;
        codeFormCallbackFn = () => {};
        triggerValidation = () => {};

        /**
         * 初始化
         * @description 建立實例後綁定「重送驗證碼」按鈕事件
         */
        constructor() {
            super();
            this.sendCodeClick();
        }

        /**
         * 初始化驗證碼流程（顯示遮罩信箱、送出驗證碼、開始倒數）
         * @param {string} email - 要驗證的 Email
         * @returns {{success: boolean, maskedEmail?: string, message?: string}} 初始化結果
         */
        initComfirmCode = (email) => {
            const maskedEmail = this.maskEmail(email);
            try {
                this.sendCodeApi(email);

                // 隱藏部分 email
                if (this.verifyEmailEl) {
                    this.verifyEmailEl.textContent = maskedEmail;
                    this.verifyEmailEl.setAttribute('data-email', email);
                }

                // 清空驗證碼輸入框
                if (this.codeForm) this.codeForm.reset();

                // 開始重發倒數
                this.startResendCountdown();

                return { success: true, maskedEmail };
            } catch (error) {
                toastEl.dispatchEvent(
                    new CustomEvent('fire', {
                        detail: { title: '錯誤', text: '驗證碼發送失敗，請重試' }
                    })
                );
                console.error('Send code error:', error);
                return { success: false, message: '驗證碼發送失敗，請重試' };
            }
        };

        /**
         * 建立驗證碼表單驗證器
         * @description 建立後會把 `triggerValidation` 綁定到此 validator，供外部顯示錯誤訊息
         * @returns {FormValidator}
         */
        codeValidator = () => {
            const validator = new FormValidator(this.codeForm, {
                asyncValidators: {
                    /**
                     * 驗證碼非同步驗證
                     * @description 非同步驗證，而不在 submit 步驟，表單送出只做 next step
                     * @description 優勢：回傳的錯誤訊息會直接顯示在 input 底下，不需要多餘步驟
                     * @description 但該部分也可挪到 onValidSubmit 後驗證
                     * @param {HTMLInputElement} input - 驗證碼 input
                     * @returns {Promise<true | {feedback: string}>} 驗證結果
                     */
                    verifyCode: async (input) => {
                        const result = await this.checkCodeApi(input.value);
                        return result.success ? true : { feedback: result.message || result.detail || '驗證碼錯誤' };
                    }
                },
                onValidSubmit: () => {
                    this.codeFormCallbackFn && this.codeFormCallbackFn();
                }
            });
            this.triggerValidation = validator.triggerValidation.bind(validator);
            return validator;
        };

        /**
         * 隱藏部分 Email
         * @param {string} email - 原始 Email
         * @returns {string} 遮罩後 Email
         */
        maskEmail = (email) => {
            if (!email) return '';
            const parts = email.split('@');
            if (parts.length !== 2) return email;

            const name = parts[0];
            const domain = parts[1];

            if (name.length <= 2) {
                return name.charAt(0) + '***@' + domain;
            }

            const visiblePart = name.substring(0, 2);
            return visiblePart + '***@' + domain;
        };

        /**
         * 開始重發倒數
         * @description 期間隱藏重送按鈕並顯示倒數秒數
         */
        startResendCountdown = () => {
            this.resendCountdownSeconds = 60;
            this.toggleCountdownDisplay(true);
            this.updateCountdownDisplay();

            if (this.resendCountdownTimer) {
                clearInterval(this.resendCountdownTimer);
                this.resendCountdownTimer = undefined;
            }

            this.resendCountdownTimer = setInterval(() => {
                this.resendCountdownSeconds--;
                if (this.resendCountdownSeconds <= 0) {
                    clearInterval(this.resendCountdownTimer);
                    this.toggleCountdownDisplay(false);
                } else {
                    this.updateCountdownDisplay();
                }
            }, 1000);
        };

        /**
         * 切換倒數/重送按鈕顯示
         * @param {boolean} show - 是否顯示倒數
         */
        toggleCountdownDisplay = (show) => {
            if (show) {
                if (this.resendCodeBtn) this.resendCodeBtn.style.display = 'none';
                if (this.resendCountdown) this.resendCountdown.style.display = 'inline';
            } else {
                if (this.resendCodeBtn) this.resendCodeBtn.style.display = 'inline';
                if (this.resendCountdown) this.resendCountdown.style.display = 'none';
            }
        };

        /**
         * 更新倒數顯示
         */
        updateCountdownDisplay = () => {
            if (!this.resendCountdown) return;
            this.resendCountdown.textContent = `(${this.resendCountdownSeconds} 秒後可重新發送)`;
        };

        /**
         * 更新提示文字
         * @param {string} text - 要顯示的提示文字（不傳則回復原始文字）
         */
        updateInfoText = (text) => {
            if (this.infoTextEl) {
                if (text) {
                    this.infoTextEl.setAttribute('data-original-message', this.infoTextEl.textContent);
                    this.infoTextEl.textContent = text;
                } else {
                    const originalMessage = this.infoTextEl.getAttribute('data-original-message') || '';
                    if (originalMessage) this.infoTextEl.textContent = originalMessage;
                }
            }
        };

        /**
         * 模態框關閉時的清理工作
         * @description 清除倒數、重置 UI 與 callback
         */
        codeModalHiddenClear = () => {
            clearInterval(this.resendCountdownTimer);
            this.resendCountdownSeconds = 0;
            this.toggleCountdownDisplay(false);
            this.updateCountdownDisplay();
            if (this.codeForm) this.codeForm.reset();
            if (this.verifyEmailEl) this.verifyEmailEl.textContent = '';
            this.updateInfoText();
            this.codeFormCallbackFn = () => {};
        };

        /**
         * 執行發送驗證碼
         * @param {string} email - 要發送的 Email
         * @param {FormValidator} validator - 表單驗證器（保留參數以維持現有呼叫方式）
         * @returns {Promise<void>}
         */
        sendCode = async (email, validator) => {
            if (!this.resendCodeBtn || this.resendCodeBtn.classList.contains('disabled') || this.resendCodeBtn.disabled) return;
            try {
                this.resendCodeBtn.classList.add('disabled');
                this.resendCodeBtn.disabled = true;
                await this.sendCodeApi(email);

                // 重新開始倒數
                this.startResendCountdown();
            } catch (error) {
                console.error('Resend code error:', error);
                if (typeof this.triggerValidation === 'function') {
                    const errorMessage = error.message || error.detail || '驗證碼發送失敗，請重試';
                    this.triggerValidation(this.codeInput, true, errorMessage);
                }
            } finally {
                if (this.resendCodeBtn.classList && this.resendCodeBtn.classList.contains('disabled')) {
                    this.resendCodeBtn.classList.remove('disabled');
                }
                this.resendCodeBtn.disabled = false;
            }
        };

        /**
         * 發送驗證碼按鈕事件綁定
         * @param {{email?: string}} data - 可選的初始化資料
         */
        sendCodeClick = (data) => {
            this.resendCodeBtn.addEventListener('click', async () => {
                try {
                    const { email = this.verifyEmailEl.getAttribute('data-email') } = data || {};
                    await this.sendCode(email);
                    // 顯示成功訊息
                    this.updateInfoText('驗證碼已重新發送');
                } catch (error) {
                    console.error('Send code click error:', error);
                    this.updateInfoText();
                }
            });
        };
    }

    /**
     * 信箱變更流程管理
     * @description 管理「發送驗證碼」→「輸入驗證碼確認」→「輸入新信箱」→「再次驗證確認」的流程
     */
    class EmailUpdateManager extends ComfirmCodeManager {
        span = document.getElementById('account-management-email');
        updateModalBtn = document.querySelector('button[data-bs-toggle="modal"][data-bs-target="#UpdateEmailSendCodeModal"]');
        email = this.updateModalBtn?.getAttribute('data-email') || '';
        // Modal 元素
        modals = {
            confirm: this.codeModalEl,
            update: document.querySelector('#UpdateEmailSendCodeModal'),
            reset: document.querySelector('#ResetEmailModal'),
            toast: document.querySelector('#toastModal')
        };

        // Form 元素
        forms = {
            confirm: this.codeForm,
            update: document.querySelector('#UpdateEmailSendCodeForm'),
            reset: document.querySelector('#ResetEmailForm')
        };
        /**
         * 建構函式
         * @description 初始化所有 Modal 和 Form 元素，並綁定事件監聽器
         */
        constructor() {
            super();
            this.bindEvents();
        }


        /**
         * 建立重設信箱表單驗證器
         * @description 使用 async 驗證呼叫更新信箱 API，成功後進入下一步驗證碼流程
         * @returns {FormValidator}
         */
        validator = () =>
            new FormValidator(this.forms.reset, {
                asyncValidators: {
                    /**
                     * 更新信箱非同步驗證
                     * @description 非同步驗證，驗證信箱格式/是否可用，表單送出只做 next step
                     * @description 優勢：回傳的錯誤訊息會直接顯示在 input 底下，不需要多餘步驟
                     * @description 但該部分也可挪到 onValidSubmit 後驗證
                     * @param {HTMLInputElement} input - email 欄位
                     * @returns {Promise<true | {feedback: string}>} 驗證結果
                     */
                    updateEmail: async (input) => {
                        const result = await this.updateAccountApi(input.value);
                        return result.success ? true : { feedback: result.message || result.detail || '信箱更新失敗，請重試' };
                    }
                },
                /**
                 * 重設信箱表單通過驗證後的送出處理
                 * @param {{controls: Record<string, HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>}} payload - 表單資料
                 */
                onValidSubmit: ({ controls }) => {
                    // 取得 email Element
                    const emailEl = controls['email'];
                    // 檢查 email Element 是否存在
                    if (!emailEl) return;
                    // 取得 email 值，並設定到 this.email
                    this.email = emailEl.value;
                    // 執行重設信箱
                    this.handleResetSubmit();
                }
            });
        /**
         * 綁定所有事件監聽器
         * @description 為各個 Form 和 Modal 綁定相應的事件處理器
         */
        async bindEvents() {
            // 發送驗證碼表單提交
            this.forms.update?.addEventListener('submit', async (e) => await this.handleUpdateSubmit(e));

            // Modal 關閉事件
            this.modals.update?.addEventListener('show.bs.modal', (e) => this.handleUpdateShow(e));
            this.modals.confirm?.addEventListener('hidden.bs.modal', () => this.handleConfirmHidden());
            this.modals.reset?.addEventListener('hidden.bs.modal', () => this.handleResetHidden());

            // 驗證器
            this.codeValidator && this.codeValidator();
            this.validator && this.validator();

            // 更新信箱資訊
            await this.updateEmailInfo();
        }

        /**
         * 處理發送驗證碼表單提交
         * @param {Event} e - 表單提交事件
         * @description 隱藏發送驗證碼 Modal，顯示確認驗證碼 Modal
         */
        async handleUpdateSubmit(e) {
            e.preventDefault();
            // 隱藏發送驗證碼 Modal
            this.hideModal('update');
            // 初始化驗證碼 pop up 與 設定驗證碼下一步動作 與 顯示確認驗證碼 Modal
            this.initComfirmCode(this.email);
            this.codeFormCallbackFn = () => this.handleNextStep(this.modals.reset);
            this.showModal('confirm');
        }

        /**
         * 處理重設信箱表單提交
         * @description 隱藏重設 Email Modal，設定完成步驟並顯示確認 Modal
         */
        async handleResetSubmit() {
            // 隱藏重設 Email Modal
            this.hideModal('reset');
            // 初始化驗證碼 pop up 與 設定驗證碼下一步動作 與 顯示確認驗證碼 Modal
            this.initComfirmCode(this.email);
            this.codeFormCallbackFn = () => this.handleFinishStep();
            this.showModal('confirm');
        }

        /**
         * 處理下一步驟
         * @param {HTMLElement | string} target - 目標 Modal 元素或 selector
         * @description 隱藏確認 Modal，顯示目標 Modal
         */
        handleNextStep(target) {
            const targetModal = target instanceof HTMLElement ? target : document.querySelector(target);
            if (targetModal) {
                this.hideModal('confirm');
                targetModal.dispatchEvent(new Event('show'));
            }
        }

        /**
         * 處理完成步驟
         * @description 顯示成功 Toast 訊息
         */
        handleFinishStep() {
            this.updateEmailInfo(this.email);
            this.modals.toast?.dispatchEvent(
                new CustomEvent('fire', {
                    detail: {
                        icon: 'success',
                        title: '信箱已成功變更',
                        text: '您的聯絡信箱已成功變更',
                        link: {
                            primaryText: '關閉',
                            primaryVariant: 'blue',
                            cancel: () => {
                                this.modals.toast?.dispatchEvent(new CustomEvent('hide'));
                            }
                        }
                    }
                })
            );
        }

        /**
         * 處理更新信箱 Modal 顯示
         * @param {Event} e - Modal 顯示事件
         * @description 更新 email 屬性，並顯示發送驗證碼 Modal
         */
        handleUpdateShow(e) {
            const relatedTarget = e.relatedTarget;
            const email = relatedTarget?.getAttribute('data-email');
            if (email) this.email = email;
        }

        /**
         * 處理確認 Modal 關閉事件
         * @description 重設確認表單
         */
        handleConfirmHidden() {
            this.codeModalHiddenClear();
        }

        /**
         * 處理重設 Modal 關閉事件
         * @description 重設重設表單
         */
        handleResetHidden() {
            this.forms.reset?.reset();
        }

        /**
         * 顯示指定的 Modal
         * @param {string} modalName - Modal 名稱
         * @description 觸發指定 Modal 的顯示事件
         */
        showModal(modalName) {
            this.modals[modalName]?.dispatchEvent(new Event('show'));
        }

        /**
         * 隱藏指定的 Modal
         * @param {string} modalName - Modal 名稱
         * @description 觸發指定 Modal 的隱藏事件
         */
        hideModal(modalName) {
            this.modals[modalName]?.dispatchEvent(new Event('hide'));
        }

        /**
         * 更新信箱資訊
         * @param {string} email - 指定要顯示的 email（不傳則會向後端取回）
         * @description 更新 span 元素的文本內容
         */
        async updateEmailInfo(email) {
            let emailValue = email;
            if (!email) emailValue = await this.getAccountApi();
            if (this.updateModalBtn) this.updateModalBtn.setAttribute('data-email', emailValue);
            if (this.span) this.span.textContent = emailValue;
        }
    }

    // 等待 DOM 加載完成後初始化信箱變更管理器
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', new EmailUpdateManager());
    } else {
        new EmailUpdateManager();
    }
</script>

---
/** Common Component */
/** InputGroup */
import InputGroup from '@components/common/form/group/inputGroup.astro';
/** Input */
import Input from '@components/common/form/input/input.astro';
/** Select */
import Select from '@components/common/form/select/customSelect.astro';
/** Button */
import Button from '@components/common/button/button.astro';
/** Style */
import './form.scss';

export interface Props {
    IDName?: string;
    className?: className;
    attribute?: attribute;
    style?: { [key: string]: string };
}

const { IDName = 'basicInfoForm', className, style, attribute = {} } = Astro.props as Props;
---

<form
    id={IDName}
    class:list={[
        className,
        ':uno-basic-info-form: grid grid-cols-1 md:grid-cols-2 gap-2rem md:gap-1.25rem xl:gap-1.5rem needs-validation'
    ]}
    style={style}
    {...attribute}
    data-needs-loading="true"
    data-report-validity="false"
    novalidate
    action=""
>
    <div class=":uno-section-form-grid-item: flex flex-col gap-1.5rem">
        <strong class=":uno-section-form-grid-title: font-tt-medium font-medium text-gray-900 text-20 lh-20">基本資料</strong>
        <InputGroup inputID="name" label="姓名" errorText="請輸入您的姓名" error block>
            <Input id="name" name="name" />
        </InputGroup>
        <InputGroup inputID="phone" label="手機號碼" errorText="請輸入您的手機號碼" error block>
            <Input id="phone" name="phone" type="tel" inputmode="tel" maxLength={10} />
        </InputGroup>
        <InputGroup inputID="email" label="電子信箱" errorText="請輸入您的電子郵件" error block>
            <Input id="email" type="email" name="email" inputmode="email" autocomplete="email" />
        </InputGroup>
        <InputGroup inputID="howToKnow" label="您是如何得知 ExpertHub 網站？" block>
            <Select
                id="howToKnow"
                name="howToKnow"
                data={[
                    { text: 'ASUS 業務邀請', value: 'ASUS 業務邀請' },
                    { text: '合作夥伴推薦', value: '合作夥伴推薦' },
                    { text: '社群媒體', value: '社群媒體' },
                    { text: '線上搜尋（Google 等）', value: '線上搜尋（Google 等）' },
                    { text: '網路廣告', value: '網路廣告' },
                    { text: '媒體報導', value: '媒體報導' },
                    { text: '參與華碩相關活動／研討會', value: '參與華碩相關活動／研討會' },
                    { text: 'LINE 官方帳號', value: 'LINE 官方帳號' },
                    { text: '其他來源', value: '其他來源' }
                ]}
                value="ASUS 業務邀請"
            />
        </InputGroup>
    </div>
    <div class=":uno-section-form-grid-item: flex flex-col gap-1.5rem">
        <strong class=":uno-section-form-grid-title: font-tt-medium font-medium text-gray-900 text-20 lh-20">公司資料</strong>
        <InputGroup inputID="companyName" label="公司名稱" errorText="請輸入公司的名稱" error block>
            <Input id="companyName" name="companyName" />
        </InputGroup>
        <InputGroup inputID="companyTaxId" label="公司統編" errorText="請輸入公司的統編" error block>
            <Input id="companyTaxId" name="companyTaxId" type="text" inputmode="numeric" minLength={8} maxLength={8} />
        </InputGroup>
        <InputGroup inputID="companyDepartment" label="公司部門" block>
            <Select
                id="companyDepartment"
                name="companyDepartment"
                data={[
                    { text: 'IT部門', value: 'IT部門' },
                    { text: '財務部門', value: '財務部門' }
                ]}
                value="IT部門"
            />
        </InputGroup>
        <InputGroup inputID="companyPosition" label="公司職稱" errorText="請輸入在公司的職稱" error block>
            <Input id="companyPosition" name="companyPosition" />
        </InputGroup>
        <InputGroup inputID="companyIndustry" label="產業類別" block>
            <Select
                id="companyIndustry"
                name="companyIndustry"
                data={[
                    { text: '雲端與基礎設施', value: '雲端與基礎設施' },
                    { text: '企業應用', value: '企業應用' },
                    { text: '資料中心', value: '資料中心' },
                    { text: '儲存', value: '儲存' },
                    { text: '安全', value: '安全' },
                    { text: '儲存', value: '儲存' }
                ]}
                value="IT部門"
            />
        </InputGroup>
        <div class=":uno-form-button-container: flex items-center justify-end mt-0.5rem">
            <Button
                type={'submit'}
                className=":uno-basic-info-form-button: md:max-w-9.75rem"
                size="lg"
                title="送出"
                variant="blue"
                block
            >
                確認修改
            </Button>
        </div>
    </div>
</form>

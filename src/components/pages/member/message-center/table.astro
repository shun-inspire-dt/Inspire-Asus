---
/** Common Component */
/** Tables */
import Tables, { type Props as TablesProps } from '@components/common/tables/tables.astro';
import MobileTd from './MobileTd.astro';
/** Style */
import './table.scss';

export interface Props {
    IDName?: string;
    className?: className;
    attribute?: attribute;
    style?: { [key: string]: string };
    data?: TablesProps['data'];
    field?: TablesProps['field'];
    mobileTable?: TablesProps['mobileTable'];
    empty?: boolean;
}

const {
    IDName = 'MessageCenter',
    className,
    style,
    attribute = {},
    data = [],
    field = [],
    mobileTable = 'md',
    empty = false
} = Astro.props as Props;
---

<Tables
    IDName={IDName}
    data={data}
    field={field}
    className={[':uno-message-center-tables: group', { 'empty-tables': empty }, className]}
    mobileTable={mobileTable}
    MobileComponent={MobileTd}
    style={style}
    attribute={{ 'data-empty': empty ? true : undefined, ...attribute }}
/>

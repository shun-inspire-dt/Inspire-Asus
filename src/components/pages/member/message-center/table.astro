---
/** Common Component */
/** Tables */
import Tables, { type Props as TablesProps } from '@components/common/tables/tables.astro';
import MobileTd from './MobileTd.astro';
/** Style */
import './table.scss';

export interface Props {
    IDName?: string;
    className?: className;
    attribute?: attribute;
    style?: { [key: string]: string };
    data?: TablesProps['data'];
    field?: TablesProps['field'];
}

const { IDName = 'MessageCenter', className, style, attribute = {}, data = [], field = [] } = Astro.props as Props;
---

<Tables
    IDName={IDName}
    data={data}
    field={field}
    className={[className, ':uno-message-center-tables:']}
    mobileTable="md"
    MobileComponent={MobileTd}
    style={style}
    {...attribute}
/>

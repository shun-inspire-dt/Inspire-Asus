---
/** Common Components - 通用組件 */
/** Offcanvas Base Component - Offcanvas 基礎組件 */
import MyOffcanvas from '@components/common/offcanvas/offcanvas.astro';
/** Main Component */
import AcctSideNav, { type Props as AcctSideNavProps } from './acctSideNav.astro';
/** Style */
import './navOffcanvas.scss';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    activeTab?: AcctSideNavProps['active'];
    activeCollapse?: AcctSideNavProps['activeCollapse'];
}

const { IDName = 'memberNav', className, style, attribute = {}, activeTab, activeCollapse } = Astro.props as Props;
---

<MyOffcanvas
    IDName={IDName}
    postion="top"
    hideHeader
    className={['member-nav-offcanvas', className]}
    attribute={attribute}
    style={{ '--bs-offcanvas-height': 'calc(var(--header-height) + 50px + 17rem)', ...style }}
>
    <AcctSideNav type="default" padding="width" active={activeTab} activeCollapse={activeCollapse} />
</MyOffcanvas>

<script>
    const setOffcanvasHeight = () => {
        let header = document.querySelector('.header') as HTMLElement;
        let offcanvas = document.querySelector('#memberNavOffcanvas') as HTMLElement;
        let offcanvasTrigger = document.querySelector('button[data-bs-target="#memberNavOffcanvas"]') as HTMLElement;
        let collapseNav = offcanvas?.querySelector('.acct-side-nav') as HTMLElement;
        let headerHeight = header?.getBoundingClientRect().height || 0;
        let buttonHeight = offcanvasTrigger?.getBoundingClientRect().height || 0;
        let navHeight = collapseNav?.getBoundingClientRect().height || 0;
        let offcanvasHeight = headerHeight + buttonHeight + navHeight;
        offcanvas.style.setProperty('--bs-offcanvas-height', `${offcanvasHeight}px`);
    };

    window.addEventListener('resize', setOffcanvasHeight);
    setOffcanvasHeight();
</script>

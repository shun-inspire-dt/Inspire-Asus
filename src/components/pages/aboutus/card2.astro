---
/** Common Component */
/** Picture */
import Picture, { type Props as PictureProps } from '@components/common/images/picture.astro';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    title?: string;
    text?: string;
    img?: string;
    imgBreakpoints?: PictureProps['breakpoints'];
    width?: string | number;
}

const {
    IDName,
    className,
    style,
    attribute = {},
    title = '嚴選多元方案',
    text = '集合雲端、AI、行銷、營運等數位工具，讓企業在同一平台快速找到最合適的解決方案。',
    img, // 響應式圖片斷點設定，依照不同螢幕尺寸載入對應圖片
    // 支援多種像素密度 (1x, 1.5x, 2x) 提供更清晰的顯示效果
    imgBreakpoints = [
        {
            width: 1280, // 桌面版斷點 (1280px+)
            img: '/assets/images/pages/aboutus-BG-2', // 向後相容的預設圖片
            densities: {
                '1x': '/assets/images/pages/aboutus-BG-2', // 標準解析度
                '1.5x': '/assets/images/pages/aboutus-BG-2', // 1.5倍解析度
                '2x': '/assets/images/pages/aboutus-BG-2' // 2倍解析度（高解析度螢幕）
            }
        },
        {
            width: 731, // 平板版斷點 (731px-1279px)
            img: '/assets/images/pages/aboutus-BG-2',
            densities: {
                '1x': '/assets/images/pages/aboutus-BG-2',
                '1.5x': '/assets/images/pages/aboutus-BG-2',
                '2x': '/assets/images/pages/aboutus-BG-2'
            }
        },
        {
            width: 0, // 手機版斷點 (730px 以下)
            img: '/assets/images/pages/aboutus-BG-2',
            densities: {
                '1x': '/assets/images/pages/aboutus-BG-2',
                '1.5x': '/assets/images/pages/aboutus-BG-2',
                '2x': '/assets/images/pages/aboutus-BG-2'
            }
        }
    ],
    width
} = Astro.props as Props;

const cardStyle = {
    ...(width ? { '--card-width': (!isNaN(width as number) ? `${parseFloat(width as string) / 16}rem` : width).toString() } : {}),
    ...style
};
---

<div
    id={IDName}
    class:list={[
        className,
        ':uno-aboutus-card-2: max-w-[var(--card-width,100%)] lg:aspect-203/130 flex flex-col gap-1.5rem lg:gap-0rem pb-2rem last:pb-0rem lg:pb-0rem relative lg:rounded-xl overflow-hidden'
    ]}
    style={cardStyle}
    {...attribute}
>
    <div class=":uno-aboutus-card-2-image-container: w-full aspect-328/183 lg:aspect-203/130 relative z-1 rounded-xl overflow-hidden">
        <Picture
            img={img}
            className=":uno-aboutus-card-2-image: size-full object-cover object-center"
            breakpoints={imgBreakpoints}
            alt={title}
            loading="lazy"
            decoding="async"
            noWebp
        />
    </div>
    <div class=":uno-aboutus-card-2-container: w-full lg:h-full lg:absolute lg:inset-0 z-2 lg:bg-[linear-gradient(180deg,rgba(11,16,33,0)_48.73%,rgba(11,16,33,0.8)_75.29%)] lg:hover:bg-[rgba(11,16,33,0.8)] group transition-colors duration-300 ease-in-out">
        <div class=":uno-aboutus-card-2-content: size-full flex flex-col items-center justify-center gap-0.75rem lg:p-2rem lg:absolute lg:inset-x-0 lg:top-[calc(100%-(5.125rem+((100%-8.875rem)/2)))] group-hover:top-0 transition-all duration-300 ease-in-out">
            <strong class=":uno-aboutus-card-2-title: text-gray-900 lg:text-white font-tt-medium text-24 lg:text-18 lh-24 lg:lh-18 font-medium text-center">{title}</strong>
            <p class=":uno-aboutus-card-2-text: text-gray-900 lg:text-white font-roboto text-subtitle lg:text-sm lh-18 lg:lh-14 font-normal text-center lg:opacity-0 group-hover:opacity-100 transition-opacity duration-300 ease-in-out">{text}</p>
        </div>
    </div>
</div>
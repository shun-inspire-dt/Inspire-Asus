---
/** Common Component */
/** Picture */
import Picture, { type Props as PictureProps } from '@components/common/images/picture.astro';
/** Link */
import ALink from '@components/common/link/link.astro';
import A from '@components/common/link/a.astro';
/** Calendar */
import Calendar from '@components/common/icons/arrows/calendar.astro';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    title?: string;
    label?: string;
    breif?: string;
    date?: string;
    logoImage?: string;
    img?: string;
    link?: string;
    imgBreakpoints?: PictureProps['breakpoints'];
    width?: string | number;
    showDate?: boolean;
    showLabel?: boolean;
    showBreif?: boolean;
    showLogo?: boolean;
    showBottomBorder?: boolean;
    last?: boolean;
}

const {
    IDName,
    className,
    style,
    attribute = {},
    title = '華碩商用師電腦市佔開局奪冠！',
    label = '科技與製造',
    breif = '市調機構IDC最新報告，華碩商用電腦再次拿下2025年!',
    date = '2025/11/07',
    logoImage = '/assets/logos/Business-Vertical-Light',
    img = '/assets/images/pages/Article-card-image-2.png',
    link = '',
    width = '100%',
    showDate = true,
    showLabel = true,
    showBreif = true,
    showLogo = true,
    showBottomBorder = true,
    last = false,
    // 響應式圖片斷點設定，依照不同螢幕尺寸載入對應圖片
    // 支援多種像素密度 (1x, 1.5x, 2x) 提供更清晰的顯示效果
    imgBreakpoints = [
        {
            width: 1280, // 桌面版斷點 (1280px+)
            img: '/assets/images/pages/Article-card-image-2', // 向後相容的預設圖片
            densities: {
                '1x': '/assets/images/pages/Article-card-image-2', // 標準解析度
                '1.5x': '/assets/images/pages/Article-card-image-2', // 1.5倍解析度
                '2x': '/assets/images/pages/Article-card-image-2' // 2倍解析度（高解析度螢幕）
            }
        },
        {
            width: 731, // 平板版斷點 (731px-1279px)
            img: '/assets/images/pages/Article-card-image-2',
            densities: {
                '1x': '/assets/images/pages/Article-card-image-2',
                '1.5x': '/assets/images/pages/Article-card-image-2',
                '2x': '/assets/images/pages/Article-card-image-2'
            }
        },
        {
            width: 0, // 手機版斷點 (730px 以下)
            img: '/assets/images/pages/Article-card-image-2',
            densities: {
                '1x': '/assets/images/pages/Article-card-image-2',
                '1.5x': '/assets/images/pages/Article-card-image-2',
                '2x': '/assets/images/pages/Article-card-image-2'
            }
        }
    ]
} = Astro.props as Props;

const cardStyle = {
    ...(width ? { '--card-width': (!isNaN(width as number) ? `${parseFloat(width as string) / 16}rem` : width).toString() } : {}),
    ...style
};
---

<A
    IDName={IDName}
    link={link}
    className={[
        className,
        ':uno-collection-har-card: max-w-[var(--card-width,100%)] lt-lg:max-w-17.5rem flex flex-col lg:flex-row items-start gap-1.25rem overflow-hidden group',
        { ':uno-collection-har-card-bottom-border: lg:pb-2rem lg:border-b-1px lg:border-gray-200': showBottomBorder && !last },
        { ':uno-collection-har-card-last: lg:pb-0 lg:border-b-0': last && showBottomBorder }
    ]}
    style={cardStyle}
    attribute={attribute}
    title={title}
>
    <div
        class=":uno-collection-har-card-image-container: w-full lg:w-12.5rem flex-none aspect-7/4 lg:aspect-square relative rounded-xl overflow-hidden"
    >
        <Picture
            className=":uno-collection-har-card-image: size-full absolute inset-0 object-center object-cover origin-center"
            img={img}
            alt={title}
            loading="lazy"
            decoding="async"
            breakpoints={imgBreakpoints}
            noWebp
        />
    </div>
    <div class=":uno-collection-har-card-content: flex flex-col lg:pb-1.25rem lg:pr-2rem">
        {
            showDate && (
                <div class=":uno-collection-har-card-date: flex items-center gap-0.25rem mb-0.75rem">
                    <Calendar />
                    <span class=":uno-collection-har-card-date-text: text-gray-700 font-roboto text-base leading-16-sh font-normal">
                        {date}
                    </span>
                </div>
            )
        }
        <div class=":uno-collection-har-card-head: flex flex-col">
            {
                title && (
                    <strong class=":uno-collection-har-card-title: text-gray-900 font-tt-normal text-subtitle leading-125 font-medium hover:underline-0.0625rem hover:underline hover:underline-offset-3">
                        {title}
                    </strong>
                )
            }
            {
                Boolean(showLabel && label) && (
                    <span
                        class=":uno-collection-har-card-label: mt-0.75rem text-gray-700 font-roboto text-base leading-120 font-normal"
                        set:html={label}
                    />
                )
            }
            {
                Boolean(showBreif && breif) && (
                    <span
                        class=":uno-collection-har-card-breif: mt-1.125rem text-gray-900 font-roboto text-base leading-140 font-normal line-clamp-3"
                        set:html={breif}
                    />
                )
            }
        </div>
        <div class=":uno-collection-har-card-footer: flex flex-col">
            {
                showLogo && (
                    <div class=":uno-collection-har-card-logo: w-5.25rem h-2.625rem aspect-2/1 mt-0.75rem [&_img]:size-full [&_img]:object-center-left [&_img]:object-contain">
                        <Picture img={logoImage} alt={title} type="svg" loading="lazy" decoding="async" noWebp />
                    </div>
                )
            }
            <ALink
                link={link}
                className=":uno-collection-har-card-link: mt-1rem"
                title={'了解更多'}
                size="16"
                showArrow
                Tag="span"
            />
        </div>
    </div>
</A>

---
/** Common Component */
/** Picture */
import Picture, { type Props as PictureProps } from '@components/common/images/picture.astro';
/** Link */
import ALink from '@components/common/link/link.astro';
import A from '@components/common/link/a.astro';
/** PlayBack */
import PlayBack from '@components/common/playBack/playBack.astro';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    title?: string;
    breif?: string;
    logoImage?: string;
    img?: string;
    link?: string;
    linkText?: string;
    showLinkArrow?: boolean;
    imgBreakpoints?: PictureProps['breakpoints'];
    width?: string | number;
    showPlayBack?: boolean;
}

const {
    IDName,
    className,
    style,
    attribute = {},
    title = 'iShops - 開店平台！',
    breif = '一站式開店平台，全面強化您的商業運營，增加企業營收，讓企業變得更好，仿造IG的限時動態風格。',
    logoImage = '/assets/logos/Business-Vertical-Light',
    img = '/assets/images/pages/solutions-bg-1',
    link = '',
    linkText = '了解更多',
    showLinkArrow = true,
    width = '100%',
    showPlayBack = true,
    // 響應式圖片斷點設定，依照不同螢幕尺寸載入對應圖片
    // 支援多種像素密度 (1x, 1.5x, 2x) 提供更清晰的顯示效果
    imgBreakpoints = [
        {
            width: 1280, // 桌面版斷點 (1280px+)
            img: '/assets/images/pages/solutions-bg-1', // 向後相容的預設圖片
            densities: {
                '1x': '/assets/images/pages/solutions-bg-1', // 標準解析度
                '1.5x': '/assets/images/pages/solutions-bg-1', // 1.5倍解析度
                '2x': '/assets/images/pages/solutions-bg-1' // 2倍解析度（高解析度螢幕）
            }
        },
        {
            width: 731, // 平板版斷點 (731px-1279px)
            img: '/assets/images/pages/solutions-bg-1',
            densities: {
                '1x': '/assets/images/pages/solutions-bg-1',
                '1.5x': '/assets/images/pages/solutions-bg-1',
                '2x': '/assets/images/pages/solutions-bg-1'
            }
        },
        {
            width: 0, // 手機版斷點 (730px 以下)
            img: '/assets/images/pages/solutions-bg-1',
            densities: {
                '1x': '/assets/images/pages/solutions-bg-1',
                '1.5x': '/assets/images/pages/solutions-bg-1',
                '2x': '/assets/images/pages/solutions-bg-1'
            }
        }
    ]
} = Astro.props as Props;

const cardStyle = {
    ...(width ? { '--card-width': (!isNaN(width as number) ? `${parseFloat(width as string) / 16}rem` : width).toString() } : {}),
    ...style
};
---

<div
    id={IDName}
    class:list={[
        className,
        ':uno-solutions-card: max-w-[var(--card-width,100%)] border border-gray-500 rounded-xl overflow-hidden group'
    ]}
    style={cardStyle}
    {...attribute}
>
    <div class=":uno-solutions-card-image-container: relative aspect-190/107 overflow-hidden">
        <Picture
            img={img}
            className=":uno-solutions-card-image: size-full absolute inset-0 object-center object-cover group-hover:scale-110 transition-transform duration-300 origin-center"
            alt={title}
            loading="lazy"
            decoding="async"
            breakpoints={imgBreakpoints}
            noWebp
        />
        {
            showPlayBack && (
                <div class=":uno-solutions-card-play-back: absolute top-0 left-0 size-full bg-transparent flex items-center justify-center z-2">
                    <PlayBack
                        size="48"
                        attribute={{
                            title,
                            'data-toggle': 'video',
                            'data-bs-toggle': 'modal',
                            'data-bs-target': '#VideoModal',
                            'data-auto': 'false',
                            'data-video-id': 'EEwDOMs5Xio'
                        }}
                    />
                </div>
            )
        }
    </div>
    <div class=":uno-solutions-card-content: flex flex-col p-1.5rem bg-white rounded-b-xl">
        <div class=":uno-solutions-card-head: flex flex-col">
            {
                title && (
                    <A link={link} title={title}>
                        <strong class=":uno-solutions-card-title: text-gray-900 font-tt-medium text-subtitle leading-125 font-medium hover:underline-0.0625rem hover:underline hover:underline-offset-3">
                            {title}
                        </strong>
                    </A>
                )
            }
            {
                breif && (
                    <span class=":uno-solutions-card-breif: mt-0.75rem text-gray-900 font-roboto text-base leading-140 font-normal line-clamp-3">
                        {breif}
                    </span>
                )
            }
        </div>
        <div class=":uno-solutions-card-footer: flex flex-col">
            <div
                class=":uno-solutions-card-logo: w-5.25rem h-2.625rem aspect-2/1 mt-0.75rem [&_img]:size-full [&_img]:object-center-left [&_img]:object-contain"
            >
                <Picture img={logoImage} alt={title} type="svg" loading="lazy" decoding="async" noWebp />
            </div>
            <ALink
                link={link}
                className=":uno-solutions-card-link: mt-1rem"
                title={linkText}
                size="16"
                showArrow={showLinkArrow}
            />
        </div>
    </div>
</div>

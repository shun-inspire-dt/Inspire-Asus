---
/** Common Component */
import MySectionForm from '@components/pages/member/auth/form.astro';
import Divider from '@components/pages/member/auth/divider.astro';
import LoginButton from '@components/pages/member/auth/button.astro';
/** InputGroup */
import InputGroup from '@components/common/form/group/inputGroup.astro';
/** Input */
import Input from '@components/common/form/input/input.astro';
/** Input */
import PasswordInput from '@components/common/form/input/passwordInput.astro';
/** Button */
import Button from '@components/common/button/button.astro';
/** CheckboxGroup */
import CheckboxGroup from '@components/common/section/checkboxGroup.astro';
/** Checkbox */
import Checkbox from '@components/common/form/checkboxs/checkbox.astro';
import CheckboxErrorText from '@components/common/form/checkboxs/errorText.astro';
/** Link */
import ALink from '@components/common/link/link.astro';
/** Style */
import './form.scss';

export interface Props {
    IDName?: string;
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
}

const { IDName, className, style, attribute = {} } = Astro.props as Props;
---

<MySectionForm
    IDName={IDName}
    title="會員註冊"
    className={['needs-validation', className]}
    style={style}
    attribute={{ novalidate: '', 'data-report-validity': 'false', ...attribute }}
>
    <div
        class=":uno-thrid-party-registers: w-full flex flex-col md:flex-row md:items-center md:justify-center flex-wrap gap-0.75rem [&>button]:[--btn-min-width:100%] md:[&>button]:[--btn-min-width:11.875rem]"
    >
        <LoginButton type="google" />
        <LoginButton type="microsoft" />
    </div>
    <Divider>或選擇其他方式註冊</Divider>
    <InputGroup label="帳號" infoText="請輸入電子郵件" error block>
        <Input id="account" type="email" inputmode="email" required />
    </InputGroup>
    <InputGroup
        label="密碼"
        infoText="密碼需包括8至25位大小寫字母、數字及符號，且不能包含空格。"
        errorText="密碼需包括8至25位大小寫字母、數字及符號，且不能包含空格。"
        error
        block
    >
        <PasswordInput
            inputId="password"
            inputAttribute={{ pattern: `(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^A-Za-z0-9])[!-~]{8,25}` }}
            required
        />
    </InputGroup>
    <InputGroup label="確認密碼" infoText="請您再次輸入您的密碼" error block>
        <PasswordInput
            inputId="confirm-password"
            inputAttribute={{
                'data-valid': 'confirm',
                'data-target': '#password'
            }}
            required
        />
    </InputGroup>
    <CheckboxGroup>
        <Fragment slot="title">我同意以下所有條款和隱私權政策</Fragment>
        <Checkbox required>
            我已閱讀並同意華碩 <b>ASUS EXPERTHUB</b> "<ALink
                link="https://asusexperthub.com/service/terms"
                showArrow={false}
                extend>使用者條款</ALink
            >"
        </Checkbox>
        <CheckboxErrorText error />
        <Checkbox required>
            我已閱讀並同意華碩 <b>ASUS EXPERTHUB</b> "<ALink
                link="https://asusexperthub.com/service/privacy"
                showArrow={false}
                extend>隱私權條款</ALink
            >"
        </Checkbox>
        <CheckboxErrorText error />
        <Checkbox>我願意收到華碩相關新聞、產品及服務更新之訊息或行銷廣告。(非必填)</Checkbox>
        <Checkbox>我願意收到華碩雲端的相關新聞、產品及服務更新之訊息或行銷廣告。(非必填)</Checkbox>
    </CheckboxGroup>
    <Button type="submit" variant="blue" title="立即註冊" block>立即註冊</Button>
</MySectionForm>

---
/** Common Component */
import MySectionForm from '@components/pages/member/auth/form.astro';
/** InputGroup */
import InputGroup from '@components/common/form/group/inputGroup.astro';
/** PasswordInput */
import PasswordInput from '@components/common/form/input/passwordInput.astro';
/** Button */
import Button from '@components/common/button/button.astro';
/** Style */
import './form.scss';

export interface Props {
    IDName?: string;
    className?: className;
    attribute?: attribute;
    style?: { [key: string]: string };
}

const { IDName, className, style, attribute = {} } = Astro.props as Props;
---

<MySectionForm id={IDName} title="重設密碼" class:list={[className]} style={style} {...attribute} action='/reset-password'>
    <InputGroup label="新密碼" infoText="密碼需包括8至25位大小寫字母、數字及符號，且不能包含空格。" block>
        <PasswordInput />
    </InputGroup>
    <InputGroup label="再次輸入您的新密碼" infoText="請再次輸入密碼" block>
        <PasswordInput />
    </InputGroup>
    <Button type="submit" variant="blue" title="確認變更" block>確認變更</Button>
</MySectionForm>

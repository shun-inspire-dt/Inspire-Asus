---
/** Common Component */
import MySectionForm from '@components/pages/member/auth/form.astro';
/** InputGroup */
import InputGroup from '@components/common/form/group/inputGroup.astro';
/** PasswordInput */
import PasswordInput from '@components/common/form/input/passwordInput.astro';
/** Button */
import Button from '@components/common/button/button.astro';
/** Style */
import './form.scss';

export interface Props {
    IDName?: string;
    className?: className;
    attribute?: attribute;
    style?: { [key: string]: string };
}

const { IDName = 'UpdatePassword', className, style, attribute = {} } = Astro.props as Props;
---

<MySectionForm
    IDName={IDName}
    title="重設密碼"
    className={['needs-validation', className]}
    style={style}
    attribute={{ novalidate: '', 'data-needs-loading': 'true', 'data-report-validity': 'false', ...attribute }}
>
    <InputGroup label="新密碼" infoText="密碼需包括8至25位大小寫字母、數字及符號，且不能包含空格。" error errorText="" block>
        <PasswordInput
            inputId="password"
            inputAttribute={{ pattern: `(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^A-Za-z0-9])[!-~]{8,25}` }}
            required
        />
    </InputGroup>
    <InputGroup label="再次輸入您的新密碼" infoText="請再次輸入密碼" error errorText="" block>
        <PasswordInput
            inputId="confirm-password"
            required
            inputAttribute={{
                'data-valid': 'confirm',
                'data-target': '#password',
                'data-valid-feedback': '與新密碼不符合'
            }}
        />
    </InputGroup>
    <Button type="submit" variant="blue" title="確認變更" block>確認變更</Button>
</MySectionForm>

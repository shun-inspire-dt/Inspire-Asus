<script is:inline define:vars={{ baseURL: import.meta.env.API_BASE_URL }}>
    const authClient = new AuthClient({ baseURL, cookies });
    const Fetch = authClient.fetchWithAuth.bind(authClient);
    /** ---------- 實作 ---------- */
    // 全局 Toast 實例
    const toastEl = document.getElementById('toastModal');

    /**
     * API 請求封裝
     * @description 統一處理此頁面「重設密碼」流程所需的 API 呼叫與 headers 設定
     */
    class API {
        headers = new Headers({
            'Content-Type': 'application/json',
            Authorization: `Bearer ${authClient.cookies.get('access_token')}`
        });

        /**
         * 更新密碼（重設密碼）
         * @param {string} password - 新密碼
         * @returns {Promise<Response | {success: boolean, message?: string}>} API 回應（依後端格式回傳）
         */
        updatePasswordApi = async (password) => {
            const raw = JSON.stringify({ password });

            const requestOptions = {
                method: 'POST',
                headers: this.headers,
                body: raw
            };

            return await Fetch(baseURL + '/api/form/strict-update-password', requestOptions)
                .then((response) => response.json())
                .then((result) => result)
                .catch((error) => {
                    throw new Error(error.message || error.detail || '密碼重設過程中發生錯誤');
                });
        };
    }

    /**
     * 重設密碼流程管理
     * @description 負責表單驗證、呼叫 API、並以 Toast 呈現結果
     */
    class ResetPassword extends API {
        form = document.getElementById('UpdatePasswordForm');

        /**
         * 初始化
         * @description 建立實例後立即綁定事件
         */
        constructor() {
            super();
            this.bindEvent();
        }

        /**
         * 事件
         */
        bindEvent = () => {
            /** 驗證器 */
            this.validator && this.validator();
        };

        /**
         * 建立表單驗證器
         * @description 使用 FormValidator 綁定 submit 驗證與 onValidSubmit 行為
         * @returns {FormValidator}
         */
        validator = () =>
            new FormValidator(this.form, {
                /**
                 * 表單通過驗證後的送出處理
                 * @param {{controls: Record<string, HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>}} payload - 表單資料
                 * @param {{triggerValidation?: Function}} helpers - FormValidator 提供的 helper（例如 triggerValidation）
                 * @returns {Promise<void>}
                 */
                onValidSubmit: async ({ controls }, { triggerValidation } = {}) => {
                    try {
                        const { 'confirm-password': RpasswordEl, password: passwordEl } = controls || {};

                        const result = await this.updatePasswordApi(RpasswordEl.value);
                        if (result.success) {
                            toastEl.dispatchEvent(
                                new CustomEvent('fire', {
                                    detail: {
                                        icon: 'success',
                                        title: result.message || '密碼重設成功，請重新登入',
                                        link: {
                                            primaryText: '重新登入',
                                            primaryLink: '/login',
                                            primaryVariant: 'blue'
                                        },
                                        close: () => {
                                            this.form.reset();
                                        }
                                    }
                                })
                            );
                        /**
                         * 密碼與舊密碼相同
                         * 範例 API 會回傳特殊 code: 'PASSWORD_SAME_AS_OLD'
                         */
                        } else if (result.error_code === 'PASSWORD_SAME_AS_OLD') {
                            RpasswordEl.value = '';
                            passwordEl.value = '';
                            if (typeof triggerValidation === 'function') {
                                triggerValidation(passwordEl, true, result.message || '新密碼不得與舊密碼輸入相同');
                                triggerValidation(RpasswordEl, true, '新密碼與確認密碼不一致');
                            }
                        } else {
                            throw new Error(result.message || result.detail || '密碼重設過程中發生錯誤');
                        }
                    } catch (error) {
                        console.error('Password check error:', error.message);
                        toastEl.dispatchEvent(
                            new CustomEvent('fire', {
                                detail: { title: '錯誤', text: error.message || error.detail || '密碼重設過程中發生錯誤' }
                            })
                        );
                    }
                }
            });
    }

    // 等待 DOM 加載完成後初始化
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => new ResetPassword());
    } else {
        new ResetPassword();
    }
</script>
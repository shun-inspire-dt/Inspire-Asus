---
/** Common Component */
/** Picture */
import Picture from '@components/common/images/picture.astro';
/** Select */
import Select from '@components/common/form/select/select.astro';
/** Link */
import ALink from '@components/common/link/link.astro';
/** Link */
import A from '@components/common/link/a.astro';

export interface Props {
    className?: any;
    attribute?: attribute;
    style?: { [key: string]: string };
    id?: string;
    title?: string;
    label?: string;
    brief?: string;
    amount?: number;
    img?: string;
}

const { id, className, style, attribute = {}, title, label, brief, amount = 1, img } = Astro.props as Props;
---

<div
    id={id}
    class:list={[
        className,
        ':uno-inquery-card: w-full flex flex-col md:flex-row md:items-start gap-1rem xl:gap-1.5rem p-1.5rem md:p-2rem bg-gray-50 rounded-lg'
    ]}
    style={style}
    {...attribute}
>
    <Picture
        img={img}
        className=":uno-inquery-card-img: w-full aspect-video md:w-15rem xl:flex-none object-cover object-center"
        width={232}
        height={131}
        alt={title}
        noWebp
    />
    <div class=":uno-inquery-card-body: w-full md:w-[calc(100%-15rem)] flex flex-col xl:flex-row gap-1rem xl:gap-1.5rem">
        <div class=":uno-inquery-card-content: flex flex-col gap-0.75rem">
            <A link={`/solution/${id}`} className=":uno-inquery-card-link: hover:underline hover:underline-offset-3" title={title}>
                <strong
                    class=":uno-inquery-card-title: text-gray-900 font-tt-medium text-18 xl:text-20 lh-120 font-medium text-left"
                >
                    {title}
                </strong>
            </A>
            <span class=":uno-inquery-card-label: text-gray-900 font-roboto text-14 lh-140 text-left">{label}</span>
            <span class=":uno-inquery-card-brief: text-gray-900 font-roboto text-16 lh-140 text-left line-clamp-3">{brief}</span>
        </div>
        <div
            class=":uno-inquery-card-controller: xl:w-9.75rem flex items-center justify-between xl:justify-start xl:flex-none gap-1.5rem"
        >
            <Select
                id={`inquery-amount-${id}`}
                className={':uno-inquery-card-select: max-w-7.5rem xl:max-w-6.25rem flex-none'}
                value={amount}
                data={Array.from({ length: 10 }, (_, i) => ({ value: i + 1, text: i + 1 }))}
                title={`數量 ${amount}`}
                attribute={{ 'data-id': id }}
            />
            <ALink title="移除" className={':uno-inquery-card-remove: flex-none'} attribute={{ 'data-id': id }}>移除</ALink>
        </div>
    </div>
</div>

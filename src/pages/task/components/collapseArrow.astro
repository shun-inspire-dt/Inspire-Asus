---
/** Layout */
import Layout from '@layouts/layouts.astro';
/** Components */
import CollapseArrowComponent from '@components/common/collapse/collapseArrow.astro';
import CollapseSelectComponent from '@components/common/collapse/collapseSelect.astro';

// 測試用的選項數據
const sampleOptions = [
    { value: 'option1', label: '選項一' },
    { value: 'option2', label: '選項二' },
    { value: 'option3', label: '選項三' },
    { value: 'option4', label: '選項四', disabled: true },
    { value: 'option5', label: '選項五' }
];

const fruitOptions = [
    { value: 'apple', label: '蘋果' },
    { value: 'banana', label: '香蕉' },
    { value: 'orange', label: '橘子' },
    { value: 'grape', label: '葡萄' }
];
---

<Layout IDName="collapse-arrow-test">
    <main class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold mb-8">Collapse 組件測試</h1>

        <!-- 基本使用範例 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">基本使用</h2>
            <div class="grid grid-cols-2 gap-6">
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">Expand (預設)</h3>
                    <CollapseArrowComponent type="expand" />
                </div>
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">Collapse</h3>
                    <CollapseArrowComponent type="collapse" />
                </div>
            </div>
        </section>

        <!-- 尺寸變體 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">尺寸變體</h2>
            <div class="grid grid-cols-4 gap-4">
                <div class="p-4 border rounded-lg text-center">
                    <h4 class="text-sm font-medium mb-2">Size 12</h4>
                    <CollapseArrowComponent type="expand" size="12" />
                    <div class="mt-2">
                        <CollapseArrowComponent type="collapse" size="12" />
                    </div>
                </div>
                <div class="p-4 border rounded-lg text-center">
                    <h4 class="text-sm font-medium mb-2">Size 14</h4>
                    <CollapseArrowComponent type="expand" size="14" />
                    <div class="mt-2">
                        <CollapseArrowComponent type="collapse" size="14" />
                    </div>
                </div>
                <div class="p-4 border rounded-lg text-center">
                    <h4 class="text-sm font-medium mb-2">Size 16 (預設)</h4>
                    <CollapseArrowComponent type="expand" size="16" />
                    <div class="mt-2">
                        <CollapseArrowComponent type="collapse" size="16" />
                    </div>
                </div>
                <div class="p-4 border rounded-lg text-center">
                    <h4 class="text-sm font-medium mb-2">Size 24</h4>
                    <CollapseArrowComponent type="expand" size="24" />
                    <div class="mt-2">
                        <CollapseArrowComponent type="collapse" size="24" />
                    </div>
                </div>
            </div>
        </section>

        <!-- 字體變體 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">字體變體</h2>
            <div class="grid grid-cols-2 gap-6">
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">Roboto (預設)</h3>
                    <div class="space-y-2">
                        <CollapseArrowComponent type="expand" font="roboto" />
                        <CollapseArrowComponent type="collapse" font="roboto" />
                    </div>
                </div>
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">TT Font</h3>
                    <div class="space-y-2">
                        <CollapseArrowComponent type="expand" font="tt" />
                        <CollapseArrowComponent type="collapse" font="tt" />
                    </div>
                </div>
            </div>
        </section>

        <!-- 字重變體 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">字重變體</h2>
            <div class="grid grid-cols-3 gap-4">
                <div class="p-4 border rounded-lg text-center">
                    <h4 class="text-sm font-medium mb-2">Regular (預設)</h4>
                    <CollapseArrowComponent type="expand" weight="regular" />
                    <div class="mt-2">
                        <CollapseArrowComponent type="collapse" weight="regular" />
                    </div>
                </div>
                <div class="p-4 border rounded-lg text-center">
                    <h4 class="text-sm font-medium mb-2">Medium</h4>
                    <CollapseArrowComponent type="expand" weight="medium" />
                    <div class="mt-2">
                        <CollapseArrowComponent type="collapse" weight="medium" />
                    </div>
                </div>
                <div class="p-4 border rounded-lg text-center">
                    <h4 class="text-sm font-medium mb-2">Bold</h4>
                    <CollapseArrowComponent type="expand" weight="bold" />
                    <div class="mt-2">
                        <CollapseArrowComponent type="collapse" weight="bold" />
                    </div>
                </div>
            </div>
        </section>

        <!-- 狀態變體 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">狀態變體</h2>
            <div class="grid grid-cols-2 gap-6">
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">Expand 狀態</h3>
                    <div class="space-y-4">
                        <div>
                            <span class="text-sm text-gray-600">Default:</span>
                            <CollapseArrowComponent type="expand" status="default" />
                        </div>
                        <div>
                            <span class="text-sm text-gray-600">Hover:</span>
                            <CollapseArrowComponent type="expand" status="hover" />
                        </div>
                        <div>
                            <span class="text-sm text-gray-600">Pressed:</span>
                            <CollapseArrowComponent type="expand" status="pressed" />
                        </div>
                        <div>
                            <span class="text-sm text-gray-600">Disabled:</span>
                            <CollapseArrowComponent type="expand" status="disabled" disabled={true} />
                        </div>
                    </div>
                </div>
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">Collapse 狀態</h3>
                    <div class="space-y-4">
                        <div>
                            <span class="text-sm text-gray-600">Default:</span>
                            <CollapseArrowComponent type="collapse" status="default" />
                        </div>
                        <div>
                            <span class="text-sm text-gray-600">Hover:</span>
                            <CollapseArrowComponent type="collapse" status="hover" />
                        </div>
                        <div>
                            <span class="text-sm text-gray-600">Pressed:</span>
                            <CollapseArrowComponent type="collapse" status="pressed" />
                        </div>
                        <div>
                            <span class="text-sm text-gray-600">Disabled:</span>
                            <CollapseArrowComponent type="collapse" status="disabled" disabled={true} />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Web Font vs SVG -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">Web Font vs SVG</h2>
            <div class="grid grid-cols-2 gap-6">
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">SVG 箭頭 (預設)</h3>
                    <div class="space-y-2">
                        <CollapseArrowComponent type="expand" webFontInstalled={false} />
                        <CollapseArrowComponent type="collapse" webFontInstalled={false} />
                    </div>
                </div>
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">Web Font 箭頭</h3>
                    <div class="space-y-2">
                        <CollapseArrowComponent type="expand" webFontInstalled={true} />
                        <CollapseArrowComponent type="collapse" webFontInstalled={true} />
                    </div>
                </div>
            </div>
        </section>

        <!-- 自訂內容 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">自訂內容</h2>
            <div class="grid grid-cols-2 gap-6">
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">自訂文字</h3>
                    <div class="space-y-2">
                        <CollapseArrowComponent type="expand">展開內容</CollapseArrowComponent>
                        <CollapseArrowComponent type="collapse">收合內容</CollapseArrowComponent>
                    </div>
                </div>
                <div class="p-4 border rounded-lg">
                    <h3 class="text-lg font-medium mb-4">英文內容</h3>
                    <div class="space-y-2">
                        <CollapseArrowComponent type="expand">Show More</CollapseArrowComponent>
                        <CollapseArrowComponent type="collapse">Show Less</CollapseArrowComponent>
                    </div>
                </div>
            </div>
        </section>

        <!-- 互動測試 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">互動測試</h2>
            <div class="p-6 border rounded-lg">
                <p class="text-gray-600 mb-4">將滑鼠懸停在按鈕上查看 hover 效果，點擊查看 focus 效果：</p>
                <div class="space-y-4">
                    <CollapseArrowComponent type="expand" size="16" />
                    <CollapseArrowComponent type="collapse" size="16" />
                </div>
            </div>
        </section>

        <!-- 組合範例 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">組合範例</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                <div class="p-4 border rounded-lg">
                    <h4 class="text-sm font-medium mb-2">小尺寸 + Medium 字重</h4>
                    <CollapseArrowComponent type="expand" size="12" weight="medium" />
                </div>
                <div class="p-4 border rounded-lg">
                    <h4 class="text-sm font-medium mb-2">大尺寸 + Bold 字重</h4>
                    <CollapseArrowComponent type="collapse" size="24" weight="bold" />
                </div>
                <div class="p-4 border rounded-lg">
                    <h4 class="text-sm font-medium mb-2">TT 字體 + 中等尺寸</h4>
                    <CollapseArrowComponent type="expand" font="tt" size="18" />
                </div>
            </div>
        </section>

        <!-- 使用說明 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">使用說明</h2>
            <div class="bg-gray-50 p-6 rounded-lg">
                <h3 class="text-lg font-medium mb-4">屬性說明</h3>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b">
                                <th class="text-left py-2 px-4">屬性</th>
                                <th class="text-left py-2 px-4">類型</th>
                                <th class="text-left py-2 px-4">預設值</th>
                                <th class="text-left py-2 px-4">說明</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b">
                                <td class="py-2 px-4 font-mono">type</td>
                                <td class="py-2 px-4">'expand' | 'collapse'</td>
                                <td class="py-2 px-4">'expand'</td>
                                <td class="py-2 px-4">摺疊類型，expand 顯示向下箭頭，collapse 顯示向上箭頭</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2 px-4 font-mono">size</td>
                                <td class="py-2 px-4">'12' | '13' | '14' | '16' | '18' | '20' | '24'</td>
                                <td class="py-2 px-4">'16'</td>
                                <td class="py-2 px-4">字體大小</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2 px-4 font-mono">font</td>
                                <td class="py-2 px-4">'roboto' | 'tt'</td>
                                <td class="py-2 px-4">'roboto'</td>
                                <td class="py-2 px-4">字體家族</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2 px-4 font-mono">weight</td>
                                <td class="py-2 px-4">'regular' | 'medium' | 'bold'</td>
                                <td class="py-2 px-4">'regular'</td>
                                <td class="py-2 px-4">字體粗細</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2 px-4 font-mono">status</td>
                                <td class="py-2 px-4">'default' | 'hover' | 'pressed' | 'disabled'</td>
                                <td class="py-2 px-4">'default'</td>
                                <td class="py-2 px-4">按鈕狀態</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2 px-4 font-mono">webFontInstalled</td>
                                <td class="py-2 px-4">boolean</td>
                                <td class="py-2 px-4">false</td>
                                <td class="py-2 px-4">是否使用 Web Font 箭頭</td>
                            </tr>
                            <tr>
                                <td class="py-2 px-4 font-mono">disabled</td>
                                <td class="py-2 px-4">boolean</td>
                                <td class="py-2 px-4">false</td>
                                <td class="py-2 px-4">是否禁用按鈕</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="text-lg font-medium mt-6 mb-4">互動狀態說明</h3>
                <ul class="space-y-2 text-sm">
                    <li><strong>Default:</strong> 預設狀態，文字顏色為 gray-900 (#181818)</li>
                    <li><strong>Hover:</strong> 懸停狀態，文字顏色保持 gray-900，但添加底線裝飾</li>
                    <li><strong>Pressed (Focus):</strong> 聚焦狀態，文字顏色為 gray-900，無底線</li>
                    <li><strong>Disabled:</strong> 禁用狀態，文字顏色為 gray-300 (#b3b3b3)，透明度 50%</li>
                </ul>
            </div>
        </section>

        <!-- CollapseSelect 組件測試 -->
        <section class="mb-12">
            <h2 class="text-3xl font-semibold mb-8 border-t pt-8">CollapseSelect 組件測試</h2>
            
            <!-- 基本使用範例 -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">基本使用</h3>
                <div class="grid grid-cols-2 gap-6">
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">Expand Select (預設)</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            options={sampleOptions}
                            name="basic-expand"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">Collapse Select</h4>
                        <CollapseSelectComponent 
                            type="collapse" 
                            options={fruitOptions}
                            name="basic-collapse"
                            value="apple"
                        />
                    </div>
                </div>
            </section>

            <!-- 尺寸變體 -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">尺寸變體</h3>
                <div class="grid grid-cols-4 gap-4">
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-sm font-medium mb-2">Size 12</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            size="12" 
                            options={fruitOptions}
                            name="size-12"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-sm font-medium mb-2">Size 14</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            size="14" 
                            options={fruitOptions}
                            name="size-14"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-sm font-medium mb-2">Size 16 (預設)</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            size="16" 
                            options={fruitOptions}
                            name="size-16"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-sm font-medium mb-2">Size 24</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            size="24" 
                            options={fruitOptions}
                            name="size-24"
                        />
                    </div>
                </div>
            </section>

            <!-- 字體變體 -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">字體變體</h3>
                <div class="grid grid-cols-2 gap-6">
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">Roboto (預設)</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            font="roboto" 
                            options={sampleOptions}
                            name="font-roboto"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">TT Font</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            font="tt" 
                            options={sampleOptions}
                            name="font-tt"
                        />
                    </div>
                </div>
            </section>

            <!-- 字重變體 -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">字重變體</h3>
                <div class="grid grid-cols-3 gap-4">
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-sm font-medium mb-2">Regular (預設)</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            weight="regular" 
                            options={fruitOptions}
                            name="weight-regular"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-sm font-medium mb-2">Medium</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            weight="medium" 
                            options={fruitOptions}
                            name="weight-medium"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-sm font-medium mb-2">Bold</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            weight="bold" 
                            options={fruitOptions}
                            name="weight-bold"
                        />
                    </div>
                </div>
            </section>

            <!-- 狀態變體 -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">狀態變體</h3>
                <div class="grid grid-cols-2 gap-6">
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">各種狀態</h4>
                        <div class="space-y-4">
                            <div>
                                <span class="text-sm text-gray-600 block mb-1">Default:</span>
                                <CollapseSelectComponent 
                                    type="expand" 
                                    status="default" 
                                    options={fruitOptions}
                                    name="status-default"
                                />
                            </div>
                            <div>
                                <span class="text-sm text-gray-600 block mb-1">Hover:</span>
                                <CollapseSelectComponent 
                                    type="expand" 
                                    status="hover" 
                                    options={fruitOptions}
                                    name="status-hover"
                                />
                            </div>
                            <div>
                                <span class="text-sm text-gray-600 block mb-1">Disabled:</span>
                                <CollapseSelectComponent 
                                    type="expand" 
                                    status="disabled" 
                                    disabled={true}
                                    options={fruitOptions}
                                    name="status-disabled"
                                />
                            </div>
                        </div>
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">功能測試</h4>
                        <div class="space-y-4">
                            <div>
                                <span class="text-sm text-gray-600 block mb-1">必填欄位:</span>
                                <CollapseSelectComponent 
                                    type="expand" 
                                    required={true}
                                    options={fruitOptions}
                                    name="required-field"
                                />
                            </div>
                            <div>
                                <span class="text-sm text-gray-600 block mb-1">預設值:</span>
                                <CollapseSelectComponent 
                                    type="collapse" 
                                    value="banana"
                                    options={fruitOptions}
                                    name="default-value"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Web Font vs SVG -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">Web Font vs SVG</h3>
                <div class="grid grid-cols-2 gap-6">
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">SVG 箭頭 (預設)</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            webFontInstalled={false}
                            options={sampleOptions}
                            name="svg-arrow"
                        />
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">Web Font 箭頭</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            webFontInstalled={true}
                            options={sampleOptions}
                            name="webfont-arrow"
                        />
                    </div>
                </div>
            </section>

            <!-- 自訂內容 -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">自訂內容</h3>
                <div class="grid grid-cols-2 gap-6">
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">自訂標籤</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            options={fruitOptions}
                            name="custom-label"
                        >
                            請選擇您喜歡的水果
                        </CollapseSelectComponent>
                    </div>
                    <div class="p-4 border rounded-lg">
                        <h4 class="text-lg font-medium mb-4">自訂選項</h4>
                        <CollapseSelectComponent 
                            type="expand" 
                            name="custom-options"
                        >
                            <option value="" disabled selected>選擇顏色</option>
                            <option value="red">紅色</option>
                            <option value="blue">藍色</option>
                            <option value="green">綠色</option>
                            <option value="yellow">黃色</option>
                        </CollapseSelectComponent>
                    </div>
                </div>
            </section>

            <!-- 使用說明 -->
            <section class="mb-12">
                <h3 class="text-2xl font-semibold mb-6">使用說明</h3>
                <div class="bg-gray-50 p-6 rounded-lg">
                    <h4 class="text-lg font-medium mb-4">CollapseSelect 屬性說明</h4>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="border-b">
                                    <th class="text-left py-2 px-4">屬性</th>
                                    <th class="text-left py-2 px-4">類型</th>
                                    <th class="text-left py-2 px-4">預設值</th>
                                    <th class="text-left py-2 px-4">說明</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-b">
                                    <td class="py-2 px-4 font-mono">type</td>
                                    <td class="py-2 px-4">'expand' | 'collapse'</td>
                                    <td class="py-2 px-4">'expand'</td>
                                    <td class="py-2 px-4">摺疊類型，expand 顯示向下箭頭，collapse 顯示向上箭頭</td>
                                </tr>
                                <tr class="border-b">
                                    <td class="py-2 px-4 font-mono">options</td>
                                    <td class="py-2 px-4">Array&lt;&#123;value, label, disabled?&#125;&gt;</td>
                                    <td class="py-2 px-4">[]</td>
                                    <td class="py-2 px-4">選項列表</td>
                                </tr>
                                <tr class="border-b">
                                    <td class="py-2 px-4 font-mono">name</td>
                                    <td class="py-2 px-4">string</td>
                                    <td class="py-2 px-4">-</td>
                                    <td class="py-2 px-4">select 元素的 name 屬性</td>
                                </tr>
                                <tr class="border-b">
                                    <td class="py-2 px-4 font-mono">value</td>
                                    <td class="py-2 px-4">string | number</td>
                                    <td class="py-2 px-4">-</td>
                                    <td class="py-2 px-4">預設選中的值</td>
                                </tr>
                                <tr class="border-b">
                                    <td class="py-2 px-4 font-mono">required</td>
                                    <td class="py-2 px-4">boolean</td>
                                    <td class="py-2 px-4">false</td>
                                    <td class="py-2 px-4">是否為必填欄位</td>
                                </tr>
                                <tr class="border-b">
                                    <td class="py-2 px-4 font-mono">multiple</td>
                                    <td class="py-2 px-4">boolean</td>
                                    <td class="py-2 px-4">false</td>
                                    <td class="py-2 px-4">是否允許多選</td>
                                </tr>
                                <tr>
                                    <td class="py-2 px-4 font-mono">disabled</td>
                                    <td class="py-2 px-4">boolean</td>
                                    <td class="py-2 px-4">false</td>
                                    <td class="py-2 px-4">是否禁用選擇框</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <h4 class="text-lg font-medium mt-6 mb-4">互動狀態說明</h4>
                    <ul class="space-y-2 text-sm">
                        <li><strong>Default:</strong> 預設狀態，邊框顏色為 gray-300 (#b3b3b3)</li>
                        <li><strong>Hover:</strong> 懸停狀態，邊框顏色變為 gray-900 (#181818)</li>
                        <li><strong>Focus:</strong> 聚焦狀態，邊框顏色為 blue-500 (#3b82f6)，帶有藍色陰影</li>
                        <li><strong>Disabled:</strong> 禁用狀態，背景色為 gray-50，透明度 50%</li>
                    </ul>
                </div>
            </section>
        </section>
    </main>
</Layout>


---
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Global Components */

/** Common Components */
import Script from '@components/common/article/relative.js.astro';
/** Main Components */
import Article from '@components/pages/news/[id]/article.astro';
import Relative from '@components/pages/news/[id]/relative.astro';
/** Style */
import '@scss/pages/news/[...id].scss';

export async function getStaticPaths() {
    return Array.from({ length: 10 }).map((_, index) => ({ params: { id: index } }));
}
const { id } = Astro.params;

export const prerender = true;
---

<Layouts IDName="NewsDetail" minMarginHeader footerPages={['最新消息']}>
    <Article />
    <Relative />
</Layouts>
<Script />

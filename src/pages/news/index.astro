---
/** Data */
import { data as FilterData } from '@components/pages/news/filter';
import { data as ArticleData } from '@components/pages/news/data';
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Global Components */

/** Common Components */
import Banner from '@components/common/banner/banner.astro';
import Follower from '@components/common/follower/follower.astro';
/** Main Components */
import Articles from '@components/pages/news/articles.astro';
import ArticlesList from '@components/common/article/articlesList.astro';
import Card from '@components/pages/news/card.astro';
import Script from '@components/pages/news/script.copy.astro';
import ScriptInline from '@components/pages/news/scipt-inline.astro';
/** Style */
import '@scss/pages/news.scss';
---

<Layouts IDName="News" footerShowBorderTop footerPages={['最新消息']}>
    <Banner img="news-banner" title="最新消息" />
    <Articles />
    <ArticlesList
        IDName="NewsList"
        title="最新消息"
        total={10}
        sortDate={[
            { text: '推薦文章', value: '0' },
            { text: '最新消息', value: '1' }
        ]}
        category={FilterData}
    >
        {
            ArticleData.map((x) => (
                <Card
                    title={x.title}
                    date={x.date}
                    breif={x.breif}
                    label={x.label}
                    img={x.img}
                    link={x.link}
                    linkText={x.linkText}
                    showLogo={false}
                />
            ))
        }
    </ArticlesList>
</Layouts>
<Follower />
<ScriptInline data={ArticleData} />
<Script />

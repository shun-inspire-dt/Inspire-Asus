---
/** Data */
import { data as FilterData } from '@components/pages/solutions/filter';
import { data as ArticleData } from '@components/pages/solutions/data';
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Global Components */

/** Common Components */
import Banner from '@components/common/banner/banner.astro';
import Follower from '@components/common/follower/follower.astro';
import Video from '@components/modal/video.astro';
/** Main Components */
import ArticlesList from '@components/common/article/articlesList.astro';
import Card from '@components/pages/solutions/card.astro';
import Script from '@components/pages/news/script.astro';
import ScriptInline from '@components/pages/news/scipt-inline.astro';
/** Style */
import '@scss/pages/solution.scss';
---

<Layouts IDName="Solution" footerPages={['解決方案']}>
    <Banner img="solutions-banner" title="解決方案" mode="dark" />
    <ArticlesList
        IDName="SolutionList"
        title="解決方案"
        total={10}
        sortDate={[
            { text: '新上市', value: '0' },
            { text: '解決方案', value: '1' }
        ]}
        category={FilterData}
        mode="white"
    >
        {
            ArticleData.map((x, index) => (
                <Card
                    title={x.title}
                    breif={x.breif}
                    img={x.img}
                    logoImage={x.logoImage}
                    logoImageType={x.logoImageType}
                    link={x.link}
                    linkText={x.linkText}
                    showPlayBack={index % 2 === 0}
                />
            ))
        }
    </ArticlesList>
</Layouts>
<Follower />
<Video />
<ScriptInline data={ArticleData} />
<Script />

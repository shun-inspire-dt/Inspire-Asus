---
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Global Components */

/** Common Components */
import Script from '@components/common/article/relative.js.astro';
import Video from '@components/modal/video.astro';
/** Main Components */
import Top from '@components/pages/solutions/[id]/top.astro';
import Feature from '@components/pages/solutions/[id]/feature.astro';
import Relative from '@components/pages/solutions/[id]/relative.astro';
import Follower from '@components/pages/solutions/[id]/follower.astro';
import Toast from '@components/pages/solutions/[id]/toast.astro';
import Back from '@components/pages/solutions/[id]/back.astro';
/** Style */
import '@scss/pages/solutions/[...id].scss';

export async function getStaticPaths() {
    return Array.from({ length: 10 }).map((_, index) => ({ params: { id: index } }));
}
const { id } = Astro.params;

export const prerender = true;
---

<Layouts IDName="SolutionsDetail" minMarginHeader footerPages={['解決方案']}>
    <Top />
    <Feature />
    <Relative />
    <Back />
</Layouts>
<Follower />
<Script />
<Toast />
<Video />

<script is:inline>
    const specInputs = document.querySelectorAll('input[type="checkbox"][name="product-config"]');
    specInputs.forEach((input) => {
        input.addEventListener('change', () => {
            const value = input.value;
            const option = input.getAttribute('data-option');
            const follower = document.querySelector('#SolutionsFollower');
            const field = follower?.querySelector('input[type="hidden"][data-option]');
            if (field) {
                field.value = value;
                const span = field?.nextElementSibling;
                if (span) span.textContent = option;
            }
        });
    });
</script>
<script is:inline>
    const toastTriggerForm = document.querySelector('#SolutionsFollower form');
    const toast = document.querySelector('#addToCartToast');
    document.addEventListener('DOMContentLoaded', () => {
        if (toastTriggerForm) {
            toastTriggerForm.addEventListener('submit', (e) => {
                e.preventDefault();
                /** TODO: */
                if (toast) toast.dispatchEvent(new CustomEvent('call.toast'));
            });
        }
    });
</script>
<script>
    import { Toast } from 'bootstrap';

    const toast = document.querySelector('#addToCartToast') as HTMLElement;
    const toastBootstrap = new Toast(toast!);
    toast.addEventListener('call.toast', () => {
        toastBootstrap.show();
    });
    toast.addEventListener('hide.toast', () => {
        toastBootstrap.hide();
    });
</script>
<script is:inline>
    // 載入 YouTube IFrame API
    if (!window.YT) {
        const tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        const firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
    }

    let player;
    let triggerButton;
    
    // YouTube API 準備完成後的回調函數
    window.onYouTubeIframeAPIReady = function() {
        player = new YT.Player('youtube-player', {
            events: {
                'onReady': onPlayerReady
            }
        });
    };

    function onPlayerReady(event) {
        // 播放器準備完成
    }

    const modal = document.getElementById('VideoModal');
    
    modal.addEventListener('show.bs.modal', (e) => {
        triggerButton = e.relatedTarget;
        if (triggerButton && !triggerButton.classList.contains('active')) {
            triggerButton.classList.add('active');
        }
    });
    
    modal.addEventListener('hidden.bs.modal', (e) => {
        if (triggerButton && triggerButton.classList.contains('active')) {
            triggerButton.classList.remove('active');
        }
        triggerButton = null;
        
        // 使用 YouTube API 暫停影片
        if (player && typeof player.pauseVideo === 'function') {
            player.pauseVideo();
        }
    });
</script>
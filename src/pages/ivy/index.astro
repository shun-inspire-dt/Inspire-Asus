---
/** Data */
import { data as FilterData } from '@components/pages/ivy/filter';
import { data as ArticleData } from '@components/pages/ivy/data';
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Global Components */

/** Common Components */
import Banner from '@components/common/banner/banner.astro';
import Follower from '@components/common/follower/follower.astro';
/** Main Components */
import ArticlesList from '@components/common/article/articlesList.astro';
import Card from '@components/pages/news/card.astro';
import Script from '@components/pages/news/script.astro';
import ScriptInline from '@components/pages/news/scipt-inline.astro';
/** Style */
import '@scss/pages/ivy.scss';
---

<Layouts IDName="Ivy" footerPages={['合作夥伴']}>
    <Banner img="ivy-banner" title="合作夥伴" />
    <ArticlesList
        IDName="IvyList"
        title="合作夥伴"
        total={10}
        sortDate={[
            { text: '新上市', value: '0' },
            { text: '合作夥伴', value: '1' }
        ]}
        category={FilterData}
        mode="white"
    >
        {
            ArticleData.map((x) => (
                <Card
                    title={x.title}
                    date={x.date}
                    breif={x.breif}
                    img={x.img}
                    link={x.link}
                    linkText={x.linkText}
                    showLogo={false}
                    showLabel={false}
                />
            ))
        }
    </ArticlesList>
</Layouts>
<Follower />
<ScriptInline data={ArticleData} />
<Script />

---
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Global Components */

/** Common Components */
import Script from '@components/common/article/relative.js.astro';
import Nav from '@components/common/section/nav.astro';
import Video from '@components/modal/video.astro';
/** Main Components */
import Info from '@components/pages/ivy/[id]/info.astro';
import Follower from '@components/pages/ivy/[id]/follower.astro';
import Article from '@components/pages/ivy/[id]/article.astro';
import Relative from '@components/pages/ivy/[id]/relative.astro';
/** Style */
import '@scss/pages/ivy/[...id].scss';

export async function getStaticPaths() {
    return Array.from({ length: 10 }).map((_, index) => ({ params: { id: index } }));
}
const { id } = Astro.params;

export const prerender = true;

const navId = `scroll-spy-${Math.random().toString(36).substr(2, 9)}`;
---

<Layouts IDName="IvyDetail" minMarginHeader footerPages={['合作夥伴']}>
    <Nav
        IDName={navId}
        data={[
            { title: '公司介紹', link: '#IvyInformation' },
            { title: '解決方案', link: '#IvyArticle' },
            { title: '最新消息', link: '#IvyRelativeSwiperContainer' },
        ]}
    />
    <div data-bs-spy="scroll" data-bs-root-margin="0px 0px 0px" data-bs-target={`#${navId}`} data-bs-smooth-scroll="true">
        <Info />
        <Article />
        <Relative />
    </div>
</Layouts>
<Script />
<Video />

<script is:inline>
    // 載入 YouTube IFrame API
    if (!window.YT) {
        const tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        const firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
    }

    let player;
    let triggerButton;
    
    // YouTube API 準備完成後的回調函數
    window.onYouTubeIframeAPIReady = function() {
        player = new YT.Player('youtube-player', {
            events: {
                'onReady': onPlayerReady
            }
        });
    };

    function onPlayerReady(event) {
        // 播放器準備完成
    }

    const modal = document.getElementById('VideoModal');
    
    modal.addEventListener('show.bs.modal', (e) => {
        triggerButton = e.relatedTarget;
        if (triggerButton && !triggerButton.classList.contains('active')) {
            triggerButton.classList.add('active');
        }
    });
    
    modal.addEventListener('hidden.bs.modal', (e) => {
        if (triggerButton && triggerButton.classList.contains('active')) {
            triggerButton.classList.remove('active');
        }
        triggerButton = null;
        
        // 使用 YouTube API 暫停影片
        if (player && typeof player.pauseVideo === 'function') {
            player.pauseVideo();
        }
    });
</script>


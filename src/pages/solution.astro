---
/** Data */
import { data } from '@components/pages/solutions/filter';
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Global Components */

/** Common Components */
import Banner from '@components/common/banner/banner.astro';
import Follower from '@components/common/follower/follower.astro';
/** Main Components */
import ArticlesList from '@components/common/section/articlesList.astro';
import Card from '@components/pages/solutions/card.astro';
/** Style */
import '@scss/pages/solution.scss';
---

<Layouts IDName="Solution">
    <Banner img="solutions-banner" title="解決方案" mode="dark" />
    <ArticlesList
        IDName="SolutionList"
        title="解決方案"
        total={10}
        sortDate={[
            { text: '新上市', value: '0' },
            { text: '解決方案', value: '1' }
        ]}
        category={data}
        mode="white"
    >
        {Array.from({ length: 10 }).map((_, index) => <Card showPlayBack={index % 2 === 0} />)}
    </ArticlesList>
    <Follower />
</Layouts>

---
/**
 * Pagination 組件完整範例頁面
 * 展示各種 pagination 狀態和使用方式
 */
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Pagination Component */
import PaginationComponent from '@components/common/pagination/pagination.astro';
---

<Layouts IDName="pagination">
    <div class="container-fluid mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold mb-8">Pagination 組件完整範例</h1>

        <!-- Light 主題 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">Light 主題</h2>
            <div class="space-y-8">
                <!-- 基本使用 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">基本使用</h3>
                    <div class="p-4 border border-gray-200 rounded-lg bg-white">
                        <PaginationComponent 
                            active={1}
                            total={10}
                            mode="Light"
                        />
                    </div>
                </div>

                <!-- 中間頁面 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">中間頁面</h3>
                    <div class="p-4 border border-gray-200 rounded-lg bg-white">
                        <PaginationComponent 
                            active={5}
                            total={10}
                            mode="Light"
                        />
                    </div>
                </div>

                <!-- 最後頁面 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">最後頁面</h3>
                    <div class="p-4 border border-gray-200 rounded-lg bg-white">
                        <PaginationComponent 
                            active={10}
                            total={10}
                            mode="Light"
                        />
                    </div>
                </div>

                <!-- 大量頁面 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">大量頁面 (100頁)</h3>
                    <div class="p-4 border border-gray-200 rounded-lg bg-white">
                        <PaginationComponent 
                            active={50}
                            total={100}
                            mode="Light"
                        />
                    </div>
                </div>
            </div>
        </section>

        <!-- Dark 主題 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">Dark 主題</h2>
            <div class="space-y-8">
                <!-- 基本使用 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">基本使用</h3>
                    <div class="p-4 border border-gray-600 rounded-lg bg-gray-800">
                        <PaginationComponent 
                            active={1}
                            total={10}
                            mode="Dark"
                        />
                    </div>
                </div>

                <!-- 中間頁面 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">中間頁面</h3>
                    <div class="p-4 border border-gray-600 rounded-lg bg-gray-800">
                        <PaginationComponent 
                            active={5}
                            total={10}
                            mode="Dark"
                        />
                    </div>
                </div>

                <!-- 最後頁面 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">最後頁面</h3>
                    <div class="p-4 border border-gray-600 rounded-lg bg-gray-800">
                        <PaginationComponent 
                            active={10}
                            total={10}
                            mode="Dark"
                        />
                    </div>
                </div>

                <!-- 大量頁面 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">大量頁面 (100頁)</h3>
                    <div class="p-4 border border-gray-600 rounded-lg bg-gray-800">
                        <PaginationComponent 
                            active={50}
                            total={100}
                            mode="Dark"
                        />
                    </div>
                </div>
            </div>
        </section>

        <!-- 自訂配置 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">自訂配置</h2>
            <div class="space-y-8">
                <!-- 少量可見頁面 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">少量可見頁面 (5頁)</h3>
                    <div class="p-4 border border-gray-200 rounded-lg bg-white">
                        <PaginationComponent 
                            active={10}
                            total={50}
                            mode="Light"
                            visiblePages={5}
                        />
                    </div>
                </div>

                <!-- 不顯示省略號 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">不顯示省略號</h3>
                    <div class="p-4 border border-gray-200 rounded-lg bg-white">
                        <PaginationComponent 
                            active={3}
                            total={8}
                            mode="Light"
                        />
                    </div>
                </div>
            </div>
        </section>

        <!-- 使用說明 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">使用說明</h2>
            <div class="bg-gray-50 p-6 rounded-lg">
                <h3 class="text-lg font-medium mb-4">鍵盤操作</h3>
                <ul class="space-y-2 text-sm">
                    <li><kbd class="px-2 py-1 bg-gray-200 rounded">Tab</kbd> - 移動到下一個可聚焦元素</li>
                    <li><kbd class="px-2 py-1 bg-gray-200 rounded">Shift + Tab</kbd> - 移動到上一個可聚焦元素</li>
                    <li><kbd class="px-2 py-1 bg-gray-200 rounded">Enter</kbd> - 激活當前聚焦的連結</li>
                </ul>
                
                <h3 class="text-lg font-medium mt-6 mb-4">互動狀態</h3>
                <ul class="space-y-2 text-sm">
                    <li><strong>Active 狀態：</strong> 字重變為 Medium (500)，文字顏色變為 gray-900 (Light) / white (Dark)</li>
                    <li><strong>Hover 狀態：</strong> 文字顏色變為 gray-900 (Light) / white (Dark)，添加底線裝飾 (underline, offset: 3px, thickness: 1px)</li>
                    <li><strong>Focus 狀態：</strong> 文字顏色變為 gray-600 (Light) / gray-400 (Dark)，顯示 24x24px 藍色聚焦框 (border: 2px solid blue-400)</li>
                    <li><strong>Disabled 狀態：</strong> 透明度 50%，禁用指標事件</li>
                </ul>
                
                <h3 class="text-lg font-medium mt-6 mb-4">主要功能</h3>
                <ul class="space-y-2 text-sm">
                    <li><strong>主題支援：</strong> 支援 Light 和 Dark 兩種主題模式</li>
                    <li><strong>響應式設計：</strong> 適配各種螢幕尺寸</li>
                    <li><strong>無障礙支援：</strong> 完整的 ARIA 屬性和鍵盤導航</li>
                    <li><strong>省略號顯示：</strong> 自動處理大量頁面的顯示</li>
                    <li><strong>可自訂配置：</strong> 可調整可見頁面數量和省略號顯示</li>
                </ul>

                <h3 class="text-lg font-medium mt-6 mb-4">組件屬性</h3>
                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead>
                            <tr class="border-b">
                                <th class="text-left py-2">屬性</th>
                                <th class="text-left py-2">類型</th>
                                <th class="text-left py-2">預設值</th>
                                <th class="text-left py-2">說明</th>
                            </tr>
                        </thead>
                        <tbody class="space-y-1">
                            <tr class="border-b">
                                <td class="py-2"><code>active</code></td>
                                <td>number</td>
                                <td>1</td>
                                <td>當前頁碼 (1-based)</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>total</code></td>
                                <td>number</td>
                                <td>12</td>
                                <td>總頁數</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>mode</code></td>
                                <td>"Light" | "Dark"</td>
                                <td>"Light"</td>
                                <td>主題模式</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>showEllipsis</code></td>
                                <td>boolean</td>
                                <td>true</td>
                                <td>是否顯示省略號</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>visiblePages</code></td>
                                <td>number</td>
                                <td>7</td>
                                <td>可見頁碼數量</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="text-lg font-medium mt-6 mb-4">CSS 變數自訂</h3>
                <div class="bg-gray-50 p-4 rounded-lg">
                    <h4 class="font-medium mb-2">主要變數</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                        <div>
                            <strong>尺寸相關：</strong>
                            <ul class="mt-1 space-y-1">
                                <li><code>--pagination-item-width</code> - 頁碼項目寬度</li>
                                <li><code>--pagination-item-height</code> - 頁碼項目高度</li>
                                <li><code>--pagination-arrow-size</code> - 箭頭尺寸</li>
                            </ul>
                        </div>
                        <div>
                            <strong>顏色相關：</strong>
                            <ul class="mt-1 space-y-1">
                                <li><code>--pagination-color</code> - 一般文字顏色</li>
                                <li><code>--pagination-color-active</code> - 活躍文字顏色</li>
                                <li><code>--pagination-arrow-color</code> - 箭頭顏色</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layouts>

<style>
    kbd {
        font-family: monospace;
        font-size: 0.875em;
    }
    
    code {
        background-color: #f3f4f6;
        padding: 2px 4px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 0.875em;
    }

    table {
        border-collapse: collapse;
    }
    
    th, td {
        border-bottom: 1px solid #e5e7eb;
        padding: 0.5rem 1rem 0.5rem 0;
        text-align: left;
    }
    
    th {
        font-weight: 600;
        background-color: #f9fafb;
    }
</style>

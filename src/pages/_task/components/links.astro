---
/** Link 組件測試頁面 */
import Layouts from '../../../layouts/layouts.astro';
import Link from '../../../components/common/link/link.astro';
import Input from '../../../components/common/form/input/input.astro';
import PasswordInput from '../../../components/common/form/input/passwordInput.astro';
---

<Layouts IDName="test-components-links">
    <div class="container-fluid mx-auto p-8">
        <h1 class="text-3xl font-bold mb-8">連結組件示範</h1>

        <!-- 基本連結示範 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">基本連結 (Basic Links)</h2>
            <div class="space-y-4">
                <div>
                    <p class="text-sm text-gray-600 mb-2">一般連結</p>
                    <Link link="/example" title="一般連結" />
                </div>
                <div>
                    <p class="text-sm text-gray-600 mb-2">外部連結</p>
                    <Link link="https://example.com" extend={true} target="_blank" title="外部連結" />
                </div>
            </div>
        </section>

        <!-- 箭頭連結尺寸示範 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">箭頭連結尺寸 (Arrow Link Sizes)</h2>
            <div class="grid grid-cols-7 gap-4 items-center">
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-2">12px</p>
                    <Link showArrow={true} size="12" font="roboto" weight="regular" title="Label" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-2">13px</p>
                    <Link showArrow={true} size="13" font="roboto" weight="regular" title="Label" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-2">14px</p>
                    <Link showArrow={true} size="14" font="roboto" weight="regular" title="Label" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-2">16px</p>
                    <Link showArrow={true} size="16" font="roboto" weight="regular" title="Label" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-2">18px</p>
                    <Link showArrow={true} size="18" font="roboto" weight="regular" title="Label" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-2">20px</p>
                    <Link showArrow={true} size="20" font="roboto" weight="regular" title="Label" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-2">24px</p>
                    <Link showArrow={true} size="24" font="roboto" weight="regular" title="Label" />
                </div>
            </div>
        </section>

        <!-- 字體變體示範 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">字體變體 (Font Variants)</h2>
            <div class="grid grid-cols-2 gap-8">
                <div>
                    <h3 class="text-lg font-medium mb-4">Roboto 字體</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-sm text-gray-600 mb-1">Regular</p>
                            <Link showArrow={true} size="18" font="roboto" weight="regular" title="Roboto Regular" />
                        </div>
                        <div>
                            <p class="text-sm text-gray-600 mb-1">Medium</p>
                            <Link showArrow={true} size="18" font="roboto" weight="medium" title="Roboto Medium" />
                        </div>
                        <div>
                            <p class="text-sm text-gray-600 mb-1">Bold</p>
                            <Link showArrow={true} size="18" font="roboto" weight="bold" title="Roboto Bold" />
                        </div>
                    </div>
                </div>
                <div>
                    <h3 class="text-lg font-medium mb-4">TT Norms Pro 字體</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-sm text-gray-600 mb-1">Regular</p>
                            <Link showArrow={true} size="18" font="tt" weight="regular" title="TT Norms Pro Regular" />
                        </div>
                        <div>
                            <p class="text-sm text-gray-600 mb-1">Medium</p>
                            <Link showArrow={true} size="18" font="tt" weight="medium" title="TT Norms Pro Medium" />
                        </div>
                        <div>
                            <p class="text-sm text-gray-600 mb-1">Bold</p>
                            <Link showArrow={true} size="18" font="tt" weight="bold" title="TT Norms Pro Bold" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 狀態示範 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">連結狀態 (Link States)</h2>
            <div class="grid grid-cols-5 gap-6">
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-4">Default</p>
                    <Link showArrow={true} size="18" font="roboto" weight="regular" status="default" title="Default State" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-4">Hover (CSS)</p>
                    <Link showArrow={true} size="18" font="roboto" weight="regular" status="hover" title="Hover State" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-4">Hover (Class)</p>
                    <Link showArrow={true} size="18" font="roboto" weight="regular" className="hover" title="Hover Class" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-4">Pressed</p>
                    <Link showArrow={true} size="18" font="roboto" weight="regular" status="pressed" title="Pressed State" />
                </div>
                <div class="text-center">
                    <p class="text-sm text-gray-600 mb-4">Disabled</p>
                    <Link showArrow={true} size="18" font="roboto" weight="regular" status="disabled" title="Disabled State" />
                </div>
            </div>
        </section>

        <!-- 混合示範 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">混合示範 (Mixed Examples)</h2>
            <div class="space-y-6">
                <div>
                    <h3 class="text-lg font-medium mb-3">不同尺寸的 TT 字體</h3>
                    <div class="space-y-2">
                        <Link showArrow={true} size="14" font="tt" weight="regular" title="14px TT Regular" />
                        <Link showArrow={true} size="16" font="tt" weight="medium" title="16px TT Medium" />
                        <Link showArrow={true} size="20" font="tt" weight="regular" title="20px TT Regular" />
                        <Link showArrow={true} size="24" font="tt" weight="regular" title="24px TT Regular" />
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-medium mb-3">實際使用案例</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-sm text-gray-600 mb-1">導航連結</p>
                            <Link
                                showArrow={true}
                                size="16"
                                font="roboto"
                                weight="regular"
                                link="/products"
                                title="查看所有產品"
                            />
                        </div>
                        <div>
                            <p class="text-sm text-gray-600 mb-1">行動呼籲</p>
                            <Link showArrow={true} size="18" font="roboto" weight="medium" link="/signup" title="立即註冊" />
                        </div>
                        <div>
                            <p class="text-sm text-gray-600 mb-1">外部資源</p>
                            <Link
                                showArrow={true}
                                size="14"
                                font="tt"
                                weight="regular"
                                link="https://docs.example.com"
                                extend={true}
                                target="_blank"
                                title="查看文檔"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 箭頭類型對比 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">箭頭類型對比 (Arrow Types)</h2>
            <div class="grid grid-cols-3 gap-8">
                <div>
                    <h3 class="text-lg font-medium mb-3">SVG 箭頭</h3>
                    <div class="space-y-2 space-x-5">
                        <Link showArrow={true} webFontInstalled={false} size="16" font="roboto" weight="regular" title="了解更多" />
                        <Link showArrow={true} webFontInstalled={false} size="18" font="roboto" weight="medium" title="查看詳情" />
                        <Link showArrow={true} webFontInstalled={false} size="20" font="tt" weight="regular" title="前往頁面" />
                    </div>
                </div>
                <div>
                    <h3 class="text-lg font-medium mb-3">Web Font 箭頭</h3>
                    <div class="space-y-2 space-x-5">
                        <Link showArrow={true} webFontInstalled={true} size="16" font="roboto" weight="regular" title="了解更多" />
                        <Link showArrow={true} webFontInstalled={true} size="18" font="roboto" weight="medium" title="查看詳情" />
                        <Link showArrow={true} webFontInstalled={true} size="20" font="tt" weight="regular" title="前往頁面" />
                    </div>
                </div>
                <div>
                    <h3 class="text-lg font-medium mb-3">無箭頭</h3>
                    <div class="space-y-2 space-x-5">
                        <Link showArrow={false} size="16" font="roboto" weight="regular" title="了解更多" />
                        <Link showArrow={false} size="18" font="roboto" weight="medium" title="查看詳情" />
                        <Link showArrow={false} size="20" font="tt" weight="regular" title="前往頁面" />
                    </div>
                </div>
            </div>
        </section>

        <!-- Input 組件範例 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">Input 組件範例 (Input Components)</h2>
            <div class="grid grid-cols-1 gap-8">
                
                <!-- 基本輸入框 -->
                <div>
                    <h3 class="text-lg font-medium mb-3">基本輸入框</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <Input size="xl" placeholder="XL 尺寸輸入框" />
                        <Input size="lg" placeholder="LG 尺寸輸入框" />
                        <Input size="md" placeholder="MD 尺寸輸入框" />
                        <Input size="sm" placeholder="SM 尺寸輸入框" />
                    </div>
                </div>

                <!-- 圖標輸入框 -->
                <div>
                    <h3 class="text-lg font-medium mb-3">圖標輸入框</h3>
                    <div class="grid grid-cols-1 gap-4 max-w-md">
                        <PasswordInput 
                            size="lg" 
                            placeholder="密碼輸入框（可切換顯示）" 
                        />
                        <Input 
                            size="lg" 
                            placeholder="搜尋輸入框"
                        />
                        <Input 
                            size="lg" 
                            placeholder="可清除輸入框" 
                            value="可以清除的內容"
                        />
                    </div>
                </div>

                <!-- 密碼輸入框專區 -->
                <div>
                    <h3 class="text-lg font-medium mb-3">密碼輸入框（可切換顯示/隱藏）</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <PasswordInput size="xl" placeholder="XL 密碼輸入框" />
                        <PasswordInput size="lg" placeholder="LG 密碼輸入框" />
                        <PasswordInput size="md" placeholder="MD 密碼輸入框" />
                        <PasswordInput size="sm" placeholder="SM 密碼輸入框" />
                    </div>
                </div>

                <!-- 密碼輸入框狀態 -->
                <div>
                    <h3 class="text-lg font-medium mb-3">密碼輸入框狀態</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <PasswordInput size="lg" status="selected" focus={true} placeholder="選中狀態密碼框" />
                        <PasswordInput size="lg" status="error" placeholder="錯誤狀態密碼框" />
                        <PasswordInput size="lg" status="disabled" disabled={true} placeholder="禁用狀態密碼框" />
                        <PasswordInput size="lg" showPassword={true} placeholder="預設顯示密碼" />
                    </div>
                </div>

                <!-- 狀態示範 -->
                <div>
                    <h3 class="text-lg font-medium mb-3">狀態示範</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <Input size="lg" status="selected" focus={true} placeholder="選中狀態" />
                        <Input size="lg" status="error" placeholder="錯誤狀態" />
                        <Input size="lg" status="disabled" disabled={true} placeholder="禁用狀態" />
                        <Input size="lg" placeholder="一般狀態" />
                    </div>
                </div>

            </div>
        </section>
    </div>
</Layouts>

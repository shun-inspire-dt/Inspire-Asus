---
/**
 * Checkbox 組件完整範例頁面
 * 展示各種 checkbox 狀態和使用方式
 */
/** Layouts */
import Layouts from '@layouts/layouts.astro';
/** Checkbox Component */
import CheckboxComponent from '@components/common/form/checkboxs/checkbox.astro';
---

<Layouts IDName="checkbox">
    <div class="container-fluid mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold mb-8">Checkbox 組件完整範例</h1>

        <!-- 基本使用 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">基本使用</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-4">
                    <h3 class="text-lg font-medium">預設狀態</h3>
                    <CheckboxComponent 
                        id="basic-1" 
                        name="basic" 
                        value="terms" 
                        label="我同意服務條款"
                    />
                    <CheckboxComponent 
                        id="basic-2" 
                        name="basic" 
                        value="newsletter" 
                        label="訂閱電子報"
                        checked={true}
                    />
                    <CheckboxComponent 
                        id="basic-3" 
                        name="basic" 
                        value="remember" 
                        label="記住我的選擇"
                    />
                </div>

                <div class="space-y-4">
                    <h3 class="text-lg font-medium">禁用狀態</h3>
                    <CheckboxComponent 
                        id="disabled-1" 
                        name="disabled" 
                        value="option1" 
                        label="禁用未選中"
                        disabled={true}
                    />
                    <CheckboxComponent 
                        id="disabled-2" 
                        name="disabled" 
                        value="option2" 
                        label="禁用已選中"
                        disabled={true}
                        checked={true}
                    />
                </div>

                <div class="space-y-4">
                    <h3 class="text-lg font-medium">半選禁用狀態</h3>
                    <CheckboxComponent 
                        id="disabled-1" 
                        name="disabled" 
                        value="option1" 
                        label="禁用未選中"
                        disabled={true}
                        indeterminate
                    />
                    <CheckboxComponent 
                        id="disabled-2" 
                        name="disabled" 
                        value="option2" 
                        label="禁用已選中"
                        disabled={true}
                        checked={true}
                        indeterminate
                    />
                </div>
            </div>
        </section>

        <!-- 唯讀狀態 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">唯讀狀態</h2>
            <div class="space-y-4">
                <CheckboxComponent 
                    id="readonly-1" 
                    name="readonly" 
                    value="option1" 
                    label="唯讀未選中（點擊無效）"
                    readonly={true}
                />
                <CheckboxComponent 
                    id="readonly-2" 
                    name="readonly" 
                    value="option2" 
                    label="唯讀已選中（點擊無效）"
                    readonly={true}
                    checked={true}
                />
            </div>
        </section>

        <!-- 圓角樣式 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">圓角樣式</h2>
            <div class="space-y-4">
                <CheckboxComponent 
                    id="rounded-1" 
                    name="rounded" 
                    value="option1" 
                    label="圓角複選框"
                    rounded={true}
                />
                <CheckboxComponent 
                    id="rounded-2" 
                    name="rounded" 
                    value="option2" 
                    label="圓角已選中"
                    rounded={true}
                    checked={true}
                />
            </div>
        </section>

        <!-- 半選狀態 (Indeterminate) -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">半選狀態 (Indeterminate)</h2>
            <div class="space-y-4">
                <p class="text-sm text-gray-600 mb-4">
                    半選狀態通常用於表示部分選中的狀態，例如父級複選框控制多個子級複選框時
                </p>
                
                <!-- 父子級聯動範例 -->
                <div class="border border-gray-200 rounded-lg p-4">
                    <CheckboxComponent 
                        id="parent-checkbox" 
                        name="parent" 
                        value="all" 
                        label="全選 (父級複選框)"
                        className="font-semibold"
                    />
                    
                    <!-- 子級複選框群組 -->
                    <div class="ml-6 mt-3 space-y-2" id="child-checkboxes">
                        <CheckboxComponent 
                            id="child-1" 
                            name="children" 
                            value="option1" 
                            label="選項 1"
                            className="child-checkbox"
                        />
                        <CheckboxComponent 
                            id="child-2" 
                            name="children" 
                            value="option2" 
                            label="選項 2"
                            className="child-checkbox"
                        />
                        <CheckboxComponent 
                            id="child-3" 
                            name="children" 
                            value="option3" 
                            label="選項 3"
                            className="child-checkbox"
                        />
                        <CheckboxComponent 
                            id="child-4" 
                            name="children" 
                            value="option4" 
                            label="選項 4"
                            className="child-checkbox"
                        />
                    </div>
                </div>

                <!-- 獨立半選狀態範例 -->
                <div class="mt-6">
                    <h3 class="text-lg font-medium mb-3">獨立半選狀態</h3>
                    <div class="space-y-2">
                        <CheckboxComponent 
                            id="indeterminate-1" 
                            name="indeterminate" 
                            value="mixed1" 
                            label="半選狀態範例 1"
                            indeterminate={true}
                        />
                        <CheckboxComponent 
                            id="indeterminate-2" 
                            name="indeterminate" 
                            value="mixed2" 
                            label="半選狀態範例 2"
                            indeterminate={true}
                        />
                        <button 
                            type="button" 
                            class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition-colors"
                            onclick="toggleIndeterminateStates()"
                        >
                            切換半選狀態
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <!-- 表單驗證 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">表單驗證</h2>
            <div class="space-y-4">
                <CheckboxComponent 
                    id="validation-1" 
                    name="validation" 
                    value="required" 
                    label="必填選項 *"
                    required={true}
                    validType="required"
                    validLabel="服務條款"
                    customInvalidText="請同意服務條款"
                />
                <CheckboxComponent 
                    id="validation-2" 
                    name="validation" 
                    value="custom" 
                    label="自訂驗證"
                    validClass="custom-valid"
                    customValidText="驗證成功！"
                    customInvalidText="請勾選此選項"
                />
            </div>
        </section>

        <!-- 條件必填 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">條件必填</h2>
            <div class="space-y-4">
                <p class="text-sm text-gray-600 mb-4">
                    勾選下方複選框會讓指定的輸入欄位變為必填
                </p>
                <CheckboxComponent 
                    id="conditional-trigger" 
                    name="conditional" 
                    value="trigger" 
                    label="需要額外資訊"
                    setRequired="#email-input,#phone-input"
                />
                <div class="mt-4 space-y-2">
                    <input 
                        id="email-input" 
                        type="email" 
                        placeholder="電子郵件（條件必填）"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md"
                    />
                    <input 
                        id="phone-input" 
                        type="tel" 
                        placeholder="電話號碼（條件必填）"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md"
                    />
                </div>
            </div>
        </section>

        <!-- 單選模式 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">單選模式</h2>
            <div class="space-y-4">
                <p class="text-sm text-gray-600 mb-4">
                    在容器上加 data-checkbox="radio" 讓複選框表現如單選按鈕
                </p>
                <div data-checkbox="radio" class="space-y-2">
                    <CheckboxComponent 
                        id="radio-1" 
                        name="radio-group" 
                        value="option1" 
                        label="選項一"
                    />
                    <CheckboxComponent 
                        id="radio-2" 
                        name="radio-group" 
                        value="option2" 
                        label="選項二"
                    />
                    <CheckboxComponent 
                        id="radio-3" 
                        name="radio-group" 
                        value="option3" 
                        label="選項三"
                    />
                </div>
            </div>
        </section>

        <!-- 插槽內容 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">插槽內容</h2>
            <div class="space-y-4">
                <CheckboxComponent 
                    id="slot-1" 
                    name="slot" 
                    value="rich-content"
                >
                    <span class="text-red-600 font-semibold">重要選項</span>
                    <span class="text-sm text-gray-500 ml-2">(必須勾選)</span>
                </CheckboxComponent>
                
                <CheckboxComponent 
                    id="slot-2" 
                    name="slot" 
                    value="html-content"
                >
                    我同意 
                    <a href="#" class="text-blue-600 underline">服務條款</a> 
                    和 
                    <a href="#" class="text-blue-600 underline">隱私政策</a>
                </CheckboxComponent>
            </div>
        </section>

        <!-- 自訂樣式 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">自訂樣式</h2>
            <div class="space-y-4">
                <CheckboxComponent 
                    id="custom-1" 
                    name="custom" 
                    value="large" 
                    label="大尺寸複選框"
                    className="custom-large-checkbox"
                    style={{
                        '--checkbox-size': '20px',
                        '--checkbox-height': '28px',
                        '--checkbox-font-size': '18px'
                    }}
                />
                
                <CheckboxComponent 
                    id="custom-2" 
                    name="custom" 
                    value="colored" 
                    label="自訂顏色（綠色主題）"
                    className="custom-colored-checkbox"
                    style={{
                        '--checkbox-checked-background-color': 'var(--color-green-600)',
                        '--checkbox-checked-border-color': 'var(--color-green-600)'
                    }}
                />
            </div>
        </section>

        <!-- 無障礙支援 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">無障礙支援</h2>
            <div class="space-y-4">
                <CheckboxComponent 
                    id="a11y-1" 
                    name="accessibility" 
                    value="aria-label" 
                    label="有 ARIA 標籤的複選框"
                    title="這是一個重要的選項"
                    aria={{
                        'aria-describedby': 'help-text-1'
                    }}
                />
                <p id="help-text-1" class="text-sm text-gray-600">
                    這個說明文字會被螢幕閱讀器讀取
                </p>
                
                <CheckboxComponent 
                    id="a11y-2" 
                    name="accessibility" 
                    value="required" 
                    label="必填欄位"
                    required={true}
                    aria={{
                        'aria-required': 'true',
                        'aria-invalid': 'false'
                    }}
                />
            </div>
        </section>

        <!-- 使用說明 -->
        <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">使用說明</h2>
            <div class="bg-gray-50 p-6 rounded-lg">
                <h3 class="text-lg font-medium mb-4">鍵盤操作</h3>
                <ul class="space-y-2 text-sm">
                    <li><kbd class="px-2 py-1 bg-gray-200 rounded">Space</kbd> - 切換選中狀態</li>
                    <li><kbd class="px-2 py-1 bg-gray-200 rounded">Tab</kbd> - 移動到下一個元素</li>
                    <li><kbd class="px-2 py-1 bg-gray-200 rounded">Shift + Tab</kbd> - 移動到上一個元素</li>
                </ul>
                
                <h3 class="text-lg font-medium mt-6 mb-4">特殊功能</h3>
                <ul class="space-y-2 text-sm">
                    <li><strong>條件必填：</strong> 使用 <code>setRequired</code> 屬性設定條件必填欄位</li>
                    <li><strong>單選模式：</strong> 在容器上加 <code>data-checkbox="radio"</code></li>
                    <li><strong>半選狀態：</strong> 使用 <code>indeterminate={true}</code> 屬性</li>
                    <li><strong>父子聯動：</strong> 父級複選框可控制多個子級複選框，自動顯示半選狀態</li>
                    <li><strong>表單驗證：</strong> 支援自訂驗證訊息和樣式</li>
                    <li><strong>插槽內容：</strong> 可放置 HTML 內容作為標籤</li>
                </ul>

                <h3 class="text-lg font-medium mt-6 mb-4">組件屬性</h3>
                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead>
                            <tr class="border-b">
                                <th class="text-left py-2">屬性</th>
                                <th class="text-left py-2">類型</th>
                                <th class="text-left py-2">預設值</th>
                                <th class="text-left py-2">說明</th>
                            </tr>
                        </thead>
                        <tbody class="space-y-1">
                            <tr class="border-b">
                                <td class="py-2"><code>id</code></td>
                                <td>string</td>
                                <td>-</td>
                                <td>複選框唯一識別碼</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>name</code></td>
                                <td>string</td>
                                <td>-</td>
                                <td>表單欄位名稱</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>value</code></td>
                                <td>string | number</td>
                                <td>-</td>
                                <td>複選框值</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>label</code></td>
                                <td>string</td>
                                <td>-</td>
                                <td>標籤文字內容</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>checked</code></td>
                                <td>boolean</td>
                                <td>false</td>
                                <td>是否預設選中</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>disabled</code></td>
                                <td>boolean</td>
                                <td>false</td>
                                <td>是否禁用</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>readonly</code></td>
                                <td>boolean</td>
                                <td>false</td>
                                <td>是否唯讀</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>required</code></td>
                                <td>boolean</td>
                                <td>false</td>
                                <td>是否必填</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>rounded</code></td>
                                <td>boolean</td>
                                <td>false</td>
                                <td>是否使用圓角樣式</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>indeterminate</code></td>
                                <td>boolean</td>
                                <td>false</td>
                                <td>是否為半選狀態</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-2"><code>setRequired</code></td>
                                <td>string</td>
                                <td>-</td>
                                <td>條件必填設定</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="text-lg font-medium mt-6 mb-4">CSS 變數自訂</h3>
                <div class="bg-gray-50 p-4 rounded-lg">
                    <h4 class="font-medium mb-2">主要變數</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                        <div>
                            <strong>尺寸相關：</strong>
                            <ul class="mt-1 space-y-1">
                                <li><code>--checkbox-size</code> - 複選框尺寸</li>
                                <li><code>--checkbox-height</code> - 容器高度</li>
                                <li><code>--checkbox-gap</code> - 間距</li>
                            </ul>
                        </div>
                        <div>
                            <strong>顏色相關：</strong>
                            <ul class="mt-1 space-y-1">
                                <li><code>--checkbox-background-color</code> - 背景色</li>
                                <li><code>--checkbox-border-color</code> - 邊框色</li>
                                <li><code>--checkbox-checked-background-color</code> - 選中背景色</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layouts>

<style>
    /* 自訂樣式範例 */
    .custom-large-checkbox {
        margin: 8px 0;
    }
    
    .custom-colored-checkbox:has(input:checked) .form-check-label {
        font-weight: 600;
    }
    
    kbd {
        font-family: monospace;
        font-size: 0.875em;
    }
    
    code {
        background-color: #f3f4f6;
        padding: 2px 4px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 0.875em;
    }

    table {
        border-collapse: collapse;
    }
    
    th, td {
        border-bottom: 1px solid #e5e7eb;
        padding: 0.5rem 1rem 0.5rem 0;
        text-align: left;
    }
    
    th {
        font-weight: 600;
        background-color: #f9fafb;
    }
</style>

<script>
    // 半選狀態相關功能
    
    /**
     * 切換獨立半選狀態
     */
    function toggleIndeterminateStates() {
        const indeterminateCheckboxes = [
            document.getElementById('indeterminate-1'),
            document.getElementById('indeterminate-2')
        ];
        
        indeterminateCheckboxes.forEach(element => {
            const checkbox = element as HTMLInputElement;
            if (checkbox && checkbox.type === 'checkbox') {
                // 循環切換：未選中 -> 半選 -> 選中 -> 未選中
                if (!checkbox.checked && !checkbox.indeterminate) {
                    // 設為半選狀態
                    checkbox.indeterminate = true;
                } else if (checkbox.indeterminate) {
                    // 從半選變為選中
                    checkbox.indeterminate = false;
                    checkbox.checked = true;
                } else if (checkbox.checked) {
                    // 從選中變為未選中
                    checkbox.checked = false;
                }
            }
        });
    }

    /**
     * 父子級複選框聯動功能
     */
    function setupParentChildCheckboxes() {
        const parentElement = document.getElementById('parent-checkbox');
        const parentCheckbox = parentElement as HTMLInputElement;
        const childCheckboxes = document.querySelectorAll('.child-checkbox input[type="checkbox"]') as NodeListOf<HTMLInputElement>;
        
        if (!parentCheckbox || childCheckboxes.length === 0) return;
        
        // 更新父級複選框狀態
        function updateParentState() {
            const checkedCount = Array.from(childCheckboxes).filter(cb => cb.checked).length;
            
            if (checkedCount === 0) {
                // 全部未選中
                parentCheckbox.checked = false;
                parentCheckbox.indeterminate = false;
            } else if (checkedCount === childCheckboxes.length) {
                // 全部選中
                parentCheckbox.checked = true;
                parentCheckbox.indeterminate = false;
            } else {
                // 部分選中 - 半選狀態
                parentCheckbox.checked = false;
                parentCheckbox.indeterminate = true;
            }
        }
        
        // 父級複選框點擊事件
        parentCheckbox.addEventListener('change', function() {
            const shouldCheck = this.checked;
            childCheckboxes.forEach(checkbox => {
                checkbox.checked = shouldCheck;
            });
            this.indeterminate = false;
        });
        
        // 子級複選框點擊事件
        childCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', updateParentState);
        });
        
        // 初始化狀態
        updateParentState();
    }
    
    // 頁面載入完成後初始化
    document.addEventListener('DOMContentLoaded', function() {
        setupParentChildCheckboxes();
    });
    
    // 將函數暴露到全域作用域供按鈕使用
    (window as any).toggleIndeterminateStates = toggleIndeterminateStates;
</script>
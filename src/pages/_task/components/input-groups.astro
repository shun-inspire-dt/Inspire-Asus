---
/**
 * InputGroup 組件測試頁面
 * 展示各種 InputGroup 組件的使用方式和配置
 */
/** Layouts */
import Layouts from '@layouts/layouts.astro';

/** 組件導入 */
import InputGroup from '../../../components/common/form/group/inputGroup.astro';
import InputWrapper from '../../../components/common/form/input/inputWrapper.astro';
import Textarea from '../../../components/common/form/textarea.astro';
import PasswordInput from '../../../components/common/form/input/passwordInput.astro';
---

<Layouts IDName="input-groups" className={['container-fluid py-12']}>
    <!-- 基礎使用範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">基礎使用範例</h2>

        <!-- 基本文字輸入 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">基本文字輸入</h3>
            <InputGroup label="使用者名稱" required={true} subTitle="請輸入您的使用者名稱" infoText="請輸入您的使用者名稱">
                <InputWrapper type="text" placeholder="請輸入使用者名稱" required={true} size="lg" />
            </InputGroup>
        </div>

        <!-- 電子郵件輸入 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">電子郵件輸入</h3>
            <InputGroup label="電子郵件" required={true} subTitle="我們會使用此郵件地址與您聯繫">
                <InputWrapper type="email" placeholder="example@email.com" required={true} size="lg" />
            </InputGroup>
        </div>

        <!-- 密碼輸入 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">密碼輸入</h3>
            <InputGroup label="密碼" required={true} subTitle="密碼長度至少 8 個字元">
                <PasswordInput placeholder="請輸入密碼" required={true} size="lg" minLength="8" />
            </InputGroup>
        </div>
    </section>

    <!-- 錯誤狀態範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">錯誤狀態範例</h2>

        <!-- 驗證錯誤 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">驗證錯誤狀態</h3>
            <InputGroup label="電子郵件" required={true} error={true} infoText="請輸入有效的電子郵件地址">
                <InputWrapper
                    type="email"
                    placeholder="example@email.com"
                    required={true}
                    size="lg"
                    status="error"
                    value="invalid-email"
                />
            </InputGroup>
        </div>

        <!-- 必填欄位錯誤 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">必填欄位錯誤</h3>
            <InputGroup label="姓名" required={true} error={true} infoText="此欄位為必填項目">
                <InputWrapper type="text" placeholder="請輸入您的姓名" required={true} size="lg" status="error" />
            </InputGroup>
        </div>
    </section>

    <!-- 不同尺寸範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">不同尺寸範例</h2>

        <!-- XL 尺寸 -->
        <div class="mb-6">
            <h3 class="text-lg font-medium mb-4">XL 尺寸 (56px)</h3>
            <InputGroup label="XL 輸入框" subTitle="這是 XL 尺寸的輸入框">
                <InputWrapper type="text" placeholder="XL 尺寸輸入框" size="xl" />
            </InputGroup>
        </div>

        <!-- LG 尺寸 -->
        <div class="mb-6">
            <h3 class="text-lg font-medium mb-4">LG 尺寸 (48px)</h3>
            <InputGroup label="LG 輸入框" subTitle="這是 LG 尺寸的輸入框">
                <InputWrapper type="text" placeholder="LG 尺寸輸入框" size="lg" />
            </InputGroup>
        </div>

        <!-- MD 尺寸 -->
        <div class="mb-6">
            <h3 class="text-lg font-medium mb-4">MD 尺寸 (40px)</h3>
            <InputGroup label="MD 輸入框" subTitle="這是 MD 尺寸的輸入框">
                <InputWrapper type="text" placeholder="MD 尺寸輸入框" size="md" />
            </InputGroup>
        </div>

        <!-- SM 尺寸 -->
        <div class="mb-6">
            <h3 class="text-lg font-medium mb-4">SM 尺寸 (36px)</h3>
            <InputGroup label="SM 輸入框" subTitle="這是 SM 尺寸的輸入框">
                <InputWrapper type="text" placeholder="SM 尺寸輸入框" size="sm" />
            </InputGroup>
        </div>
    </section>

    <!-- 特殊輸入類型範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">特殊輸入類型範例</h2>

        <!-- 搜尋輸入 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">搜尋輸入</h3>
            <InputGroup label="搜尋" subTitle="輸入關鍵字進行搜尋">
                <InputWrapper type="search" placeholder="搜尋內容..." size="lg" searchIcon={true} />
            </InputGroup>
        </div>

        <!-- 日期輸入 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">日期輸入</h3>
            <InputGroup label="出生日期" required={true} subTitle="請選擇您的出生日期">
                <InputWrapper type="date" required={true} size="lg" />
            </InputGroup>
        </div>

        <!-- 數字輸入 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">數字輸入</h3>
            <InputGroup label="年齡" subTitle="請輸入您的年齡">
                <InputWrapper type="number" placeholder="25" size="lg" inputAttribute={{ min: '1', max: '120' }} />
            </InputGroup>
        </div>

        <!-- 電話號碼輸入 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">電話號碼輸入</h3>
            <InputGroup label="電話號碼" required={true} subTitle="請輸入您的聯絡電話">
                <InputWrapper type="tel" placeholder="0912-345-678" required={true} size="lg" inputmode="tel" />
            </InputGroup>
        </div>
    </section>

    <!-- 禁用和唯讀狀態 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">禁用和唯讀狀態</h2>

        <!-- 禁用狀態 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">禁用狀態</h3>
            <InputGroup label="禁用輸入框" subTitle="此輸入框已被禁用">
                <InputWrapper type="text" placeholder="禁用的輸入框" disabled={true} size="lg" value="無法編輯的內容" />
            </InputGroup>
        </div>

        <!-- 唯讀狀態 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">唯讀狀態</h3>
            <InputGroup label="唯讀輸入框" subTitle="此輸入框為唯讀狀態">
                <InputWrapper type="text" readonly="readonly" size="lg" value="唯讀內容" />
            </InputGroup>
        </div>
    </section>

    <!-- 水平佈局範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">水平佈局範例</h2>

        <!-- 水平佈局 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">水平佈局</h3>
            <InputGroup label="姓名" required={true} inline={true} inputSize="lg">
                <InputWrapper type="text" placeholder="請輸入姓名" required={true} size="lg" />
            </InputGroup>
        </div>

        <!-- 水平佈局 + Textarea -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">水平佈局 + Textarea</h3>
            <InputGroup label="姓名" required={true} inline={true} inputSize="lg" inlineLabelCenter={false} inlineLabelPadding>
                <Textarea placeholder="請輸入姓名" required={true} size="lg" />
            </InputGroup>
        </div>

        <!-- 水平佈局 + 錯誤狀態 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">水平佈局 + 錯誤狀態</h3>
            <InputGroup
                label="電子郵件"
                required={true}
                error={true}
                infoText="電子郵件格式不正確"
                inline={true}
                inputSize="lg"
                inlineLabelCenter={false}
                inlineLabelPadding
            >
                <InputWrapper
                    type="email"
                    placeholder="example@email.com"
                    required={true}
                    size="lg"
                    status="error"
                    value="invalid@"
                />
            </InputGroup>
        </div>
    </section>

    <!-- 複雜表單範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">複雜表單範例</h2>

        <form class="space-y-6 max-w-2xl">
            <h3 class="text-lg font-medium mb-4">使用者註冊表單</h3>

            <!-- 姓名 -->
            <InputGroup label="姓名" required={true} subTitle="請輸入您的真實姓名">
                <InputWrapper type="text" name="fullName" placeholder="請輸入姓名" required={true} size="lg" />
            </InputGroup>

            <!-- 電子郵件 -->
            <InputGroup label="電子郵件" required={true} subTitle="我們會發送驗證郵件到此地址">
                <InputWrapper type="email" name="email" placeholder="example@email.com" required={true} size="lg" />
            </InputGroup>

            <!-- 密碼 -->
            <InputGroup label="密碼" required={true} subTitle="密碼長度至少 8 個字元，包含英文和數字">
                <PasswordInput name="password" placeholder="請輸入密碼" required={true} size="lg" minLength="8" />
            </InputGroup>

            <!-- 確認密碼 -->
            <InputGroup label="確認密碼" required={true} subTitle="請再次輸入相同的密碼">
                <PasswordInput name="confirmPassword" placeholder="請再次輸入密碼" required={true} size="lg" minLength="8" />
            </InputGroup>

            <!-- 電話號碼 -->
            <InputGroup label="電話號碼" subTitle="選填，用於重要通知">
                <InputWrapper type="tel" name="phone" placeholder="0912-345-678" size="lg" inputmode="tel" />
            </InputGroup>

            <!-- 出生日期 -->
            <InputGroup label="出生日期" subTitle="用於年齡驗證">
                <InputWrapper type="date" name="birthDate" size="lg" />
            </InputGroup>

            <!-- 提交按鈕 -->
            <div class="pt-4">
                <button
                    type="submit"
                    class="w-full bg-blue-600 text-white py-3 px-6 rounded-lg hover:bg-blue-700 transition-colors font-medium"
                >
                    註冊帳號
                </button>
            </div>
        </form>
    </section>

    <!-- 自定義樣式範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">自定義樣式範例</h2>

        <!-- 透明輸入框 -->
        <div class="mb-8 p-6 bg-gray-100 rounded-lg">
            <h3 class="text-lg font-medium mb-4">透明輸入框</h3>
            <InputGroup label="透明輸入框" subTitle="適用於特殊背景的輸入框">
                <InputWrapper type="text" placeholder="透明樣式輸入框" size="lg" transparent={true} />
            </InputGroup>
        </div>

        <!-- 自定義 CSS 類別 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">自定義 CSS 類別</h3>
            <InputGroup
                label="自定義樣式"
                subTitle="使用自定義 CSS 類別的輸入框"
                formGroupClassName="border-2 border-blue-200 rounded-lg p-4"
                labelClassName="text-blue-700 font-semibold"
                contentClassName="mt-2"
            >
                <InputWrapper
                    type="text"
                    placeholder="自定義樣式輸入框"
                    size="lg"
                    className="border-blue-300 focus:border-blue-500"
                />
            </InputGroup>
        </div>
    </section>

    <!-- 無障礙功能範例 -->
    <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 border-b pb-2">無障礙功能範例</h2>

        <!-- ARIA 標籤 -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">ARIA 標籤支援</h3>
            <InputGroup label="使用者名稱" required={true} subTitle="使用者名稱將用於登入系統" id="username-group">
                <InputWrapper
                    type="text"
                    name="username"
                    placeholder="請輸入使用者名稱"
                    required={true}
                    size="lg"
                    aria={{
                        'aria-describedby': 'username-help',
                        'aria-label': '使用者名稱輸入框'
                    }}
                />
            </InputGroup>
        </div>

        <!-- 錯誤訊息 ARIA -->
        <div class="mb-8">
            <h3 class="text-lg font-medium mb-4">錯誤訊息 ARIA 支援</h3>
            <InputGroup label="電子郵件" required={true} error={true} infoText="請輸入有效的電子郵件地址" id="email-group">
                <InputWrapper
                    type="email"
                    name="email"
                    placeholder="example@email.com"
                    required={true}
                    size="lg"
                    status="error"
                    value="invalid-email"
                    aria={{
                        'aria-describedby': 'email-error',
                        'aria-invalid': 'true',
                        'aria-label': '電子郵件輸入框'
                    }}
                />
            </InputGroup>
        </div>
    </section>
</Layouts>

---
/** Layouts */
import Layouts from '@layouts/layouts.astro';
---

<Layouts IDName="task" className="min-h-screen flex items-center justify-center p-6">
    <ul class="w-full max-w-lg mx-auto space-y-6 p-8 bg-white border border-gray-200 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 list-circle">
        <li class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2">
            Components
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/anything" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Anything
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/icons" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Icons
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/buttons" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Buttons
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/links" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Links
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/inputs" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Inputs
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/selects" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Selector
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/checkbox" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Checkbox
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/input-groups" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Input Groups
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/pagination" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Pagination
            </a>
        </li>
        <li class="ml-4">
            <a 
                href="/task/components/collapseArrow" 
                class="text-blue-600 hover:text-blue-800 underline decoration-2 underline-offset-3 hover:decoration-blue-800 transition-all duration-200 font-medium"
            >
                Collapse Components
            </a>
        </li>
    </ul>
</Layouts>
